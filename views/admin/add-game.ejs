<%- include('../partials/admin/header') %>
<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css">
<link rel="stylesheet" href="/globals.css">

<body class="bg-background-dark text-white antialiased h-screen flex overflow-hidden">

<%- include('../partials/admin/sidebar', { activeTab: 'add-game' }) %>

<main class="flex-1 flex flex-col h-full overflow-hidden bg-background-dark text-white">
  <form id="addGameForm" class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Page Header -->
    <header class="px-8 py-6 border-b border-border-dark flex items-center justify-between flex-shrink-0 bg-background-dark/50 backdrop-blur-sm z-10 sticky top-0">
      <div class="flex items-center gap-3">
        <span class="material-icons-outlined text-accent text-2xl">note_add</span>
        <h1 class="text-2xl font-bold text-white">New Game Addition</h1>
      </div>
      <div class="flex items-center gap-3 bg-surface-dark px-4 py-2 rounded-full border border-border-dark">
        <span id="standardLabel" class="text-sm font-medium text-accent">Standard</span>
        <div class="relative inline-block w-12 mr-2 align-middle select-none transition duration-200 ease-in">
          <input class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-accent border-4 border-surface-dark appearance-none cursor-pointer transform translate-x-0 transition-transform duration-200 ease-in-out bg-background-dark border border-border-dark text-white" id="toggle" type="checkbox"/>
          <label class="toggle-label block overflow-hidden h-6 rounded-full bg-border-dark cursor-pointer" for="toggle"></label>
        </div>
        <span id="legendsLabel" class="text-sm font-medium text-text-muted">Legends</span>
      </div>
    </header>
    
    <!-- Hidden Edition Type Input -->
    <input type="hidden" id="edition_type" name="edition_type" value="STANDARD" class="bg-background-dark border border-border-dark text-white" />

    <div class="flex-1 overflow-y-auto p-8 bg-background-dark text-white">
      <div class="max-w-6xl mx-auto space-y-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          
          <!-- Column 1: Core Details -->
          <section class="bg-surface-dark rounded-xl border border-border-dark p-6">
            <div class="flex items-center gap-2 mb-6 pb-4 border-b border-border-dark">
              <span class="material-icons-outlined text-accent text-sm">info</span>
              <h2 class="text-lg font-semibold text-white">Core Details</h2>
            </div>
            <div class="space-y-6">
              <!-- Title -->
              <div>
                <label class="block text-sm font-medium text-text-muted mb-2">Game Title</label>
                <input name="title" required class="w-full bg-background-dark border border-border-dark rounded-lg px-4 py-3 text-sm text-white placeholder-text-muted focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors" placeholder="Enter official game title..." type="text"/>
              </div>
              
              <!-- Publisher -->
              <div>
                <label class="block text-sm font-medium text-text-muted mb-2">Publisher</label>
                <div class="relative">
                  <select name="publisher" required class="w-full bg-background-dark border border-border-dark rounded-lg px-4 py-3 text-sm text-white appearance-none focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors cursor-pointer">
                    <option class="text-text-muted" disabled="" selected="" value="">Select Publisher...</option>
                    <% if (typeof publishers !== 'undefined' && publishers && publishers.length > 0) { %>
                      <% publishers.forEach(pub => { %>
                        <option value="<%= pub.name %>"><%= pub.name %></option>
                      <% }) %>
                    <% } else { %>
                      <option value="Electronic Arts">Electronic Arts</option>
                      <option value="Ubisoft">Ubisoft</option>
                      <option value="Sony Interactive Entertainment">Sony Interactive Entertainment</option>
                      <option value="Nintendo">Nintendo</option>
                      <option value="Activision Blizzard">Activision Blizzard</option>
                      <option value="Take-Two Interactive">Take-Two Interactive</option>
                    <% } %>
                  </select>
                  <span class="material-icons-outlined absolute right-3 top-1/2 -translate-y-1/2 text-text-muted pointer-events-none text-sm">arrow_drop_down</span>
                </div>
              </div>
              
              <!-- Core Grid: Release Year -->
              <div>
                <label class="block text-sm font-medium text-text-muted mb-2">Release Year</label>
                <input name="release_year" required class="w-full bg-background-dark border border-border-dark rounded-lg px-4 py-3 text-sm text-white placeholder-text-muted focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors" placeholder="YYYY" type="number" min="1950" max="2100"/>
              </div>
              
              <!-- Category -->
              <div>
                <label class="block text-sm font-medium text-text-muted mb-2">Primary Category</label>
                <div class="relative">
                  <select name="category" required class="w-full bg-background-dark border border-border-dark rounded-lg px-4 py-3 text-sm text-white appearance-none focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors cursor-pointer">
                    <option disabled="" selected="" value="">Select category...</option>
                    <% if (typeof categories !== 'undefined' && categories && categories.length > 0) { %>
                      <% categories.forEach(cat => { %>
                        <option value="<%= cat._id %>" data-status="<%= cat.status %>"><%= cat.name %><%= cat.status === 'Hidden' ? ' (Unlisted)' : '' %></option>
                      <% }) %>
                    <% } %>
                  </select>
                  <span class="material-icons-outlined absolute right-3 top-1/2 -translate-y-1/2 text-text-muted pointer-events-none text-sm">arrow_drop_down</span>
                </div>
              </div>
              
              <!-- Supported Platforms -->
              <div>
                <label class="block text-sm font-medium text-text-muted mb-2">Supported Platforms</label>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-4 bg-background-dark border border-border-dark rounded-lg px-4 py-3" id="platformsContainer">
                  <label class="flex items-center gap-2 cursor-pointer text-sm text-white">
                    <input type="checkbox" name="platforms[]" value="PC" class="platform-checkbox rounded bg-background-dark border border-border-dark text-white text-accent focus:ring-accent">
                    <span>PC</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer text-sm text-white">
                    <input type="checkbox" name="platforms[]" value="PlayStation 5" class="platform-checkbox rounded bg-background-dark border border-border-dark text-white text-accent focus:ring-accent">
                    <span>PlayStation 5</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer text-sm text-white">
                    <input type="checkbox" name="platforms[]" value="Xbox Series X|S" class="platform-checkbox rounded bg-background-dark border border-border-dark text-white text-accent focus:ring-accent">
                    <span>Xbox Series X|S</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer text-sm text-white">
                    <input type="checkbox" name="platforms[]" value="PlayStation 4" class="platform-checkbox rounded bg-background-dark border border-border-dark text-white text-accent focus:ring-accent">
                    <span>PlayStation 4</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer text-sm text-white">
                    <input type="checkbox" name="platforms[]" value="Xbox One" class="platform-checkbox rounded bg-background-dark border border-border-dark text-white text-accent focus:ring-accent">
                    <span>Xbox One</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer text-sm text-white">
                    <input type="checkbox" id="otherPlatformsToggle" class="rounded bg-background-dark border border-border-dark text-white text-accent focus:ring-accent">
                    <span>Other</span>
                  </label>
                </div>
                
                <!-- Dynamic Other Platforms Searchable Dropdown -->
                <div id="otherPlatformsContainer" class="hidden mt-3 p-4 bg-background-dark/50 border border-border-dark rounded-lg space-y-3 relative">
                  <label class="block text-xs font-medium text-text-muted">Search & Add Legacy/Extended Platforms</label>
                  <div class="relative">
                    <input type="text" id="otherPlatformsSearch" placeholder="Type platform name (e.g. Switch, PS3, Wii)..." class="w-full bg-background-dark border border-border-dark rounded-lg px-4 py-2.5 text-sm text-white placeholder-text-muted focus:outline-none focus:border-accent">
                    <div id="otherPlatformsDropdown" class="hidden absolute left-0 right-0 mt-1 max-h-48 overflow-y-auto bg-surface-dark border border-border-dark rounded-lg shadow-xl z-20">
                      <!-- Dropdown options rendered dynamically -->
                    </div>
                  </div>
                </div>

                <!-- Configure Stock per Platform -->
                <div id="platformStocksSection" class="hidden mt-4">
                  <label class="block text-sm font-medium text-text-muted mb-2">Configure Stock per Platform</label>
                  <div id="platformStocksContainer" class="flex flex-col gap-3 bg-background-dark border border-border-dark rounded-lg p-4">
                    <!-- Dynamic stock rows render here -->
                  </div>
                </div>
              </div>
            </div>
          </section>
          
          <!-- Column 2: Media Gallery & Description -->
          <section class="bg-surface-dark rounded-xl border border-border-dark p-6 flex flex-col justify-between">
            <div>
              <div class="flex items-center gap-2 mb-6 pb-4 border-b border-border-dark">
                <span class="material-icons-outlined text-accent text-sm">perm_media</span>
                <h2 class="text-lg font-semibold text-white">Media &amp; Summary</h2>
              </div>
              <div class="space-y-6">
                <!-- Cover Art -->
                <div>
                  <label class="block text-sm font-medium text-text-muted mb-2">Cover Art</label>
                  <div id="coverUploadContainer" onclick="document.getElementById('coverInput').click()" class="border-2 border-dashed border-border-dark rounded-xl p-8 flex flex-col items-center justify-center text-center cursor-pointer hover:border-text-muted transition-colors bg-background-dark/50">
                    <span class="material-icons-outlined text-4xl text-text-muted mb-2">cloud_upload</span>
                    <p class="text-sm font-medium text-white mb-1">Upload Cover Image</p>
                    <p class="text-xs text-text-muted">JPEG, PNG or WEBP (Max 5MB)</p>
                    <input type="file" id="coverInput" accept="image/*" class="hidden bg-background-dark border border-border-dark text-white">
                  </div>
                  <!-- Preview container -->
                  <div id="coverPreviewContainer" class="mt-4 hidden text-center">
                    <img id="coverPreview" class="max-h-48 rounded object-cover mx-auto border border-border-dark mb-3" />
                    <div class="flex gap-2 justify-center">
                      <button type="button" id="replaceCoverBtn" class="px-3 py-1.5 text-xs bg-surface-dark border border-border-dark hover:bg-border-dark/50 text-white rounded-lg transition-colors flex items-center gap-1.5">
                        <span class="material-icons-outlined text-xs">cached</span> Replace
                      </button>
                      <button type="button" id="removeCoverBtn" class="px-3 py-1.5 text-xs bg-[#f92a40]/10 hover:bg-[#f92a40]/20 text-pixel-red rounded-lg transition-colors flex items-center gap-1.5">
                        <span class="material-icons-outlined text-xs">delete</span> Remove
                      </button>
                    </div>
                  </div>
                </div>
                
                <!-- Media Gallery -->
                <div>
                  <label class="block text-sm font-medium text-text-muted mb-2">Media Gallery (Min 3 Screenshots/Videos, Max 5)</label>
                  <div class="border-2 border-dashed border-border-dark rounded-xl p-6 bg-background-dark/50 hover:border-text-muted transition-colors">
                    <div id="galleryPreviews" class="flex flex-wrap gap-3 items-center justify-start">
                      <!-- Stateful thumbnail previews will render here -->
                      
                      <!-- Persistent "+" placeholder button at the end -->
                      <button type="button" id="galleryAddBtn" onclick="document.getElementById('galleryInput').click()" class="w-16 h-16 rounded-lg border-2 border-dashed border-border-dark hover:border-accent hover:text-accent flex flex-col items-center justify-center text-text-muted transition-colors cursor-pointer bg-background-dark/30">
                        <span class="material-icons-outlined text-xl">add</span>
                        <span class="text-[8px] mt-1">Add Media</span>
                      </button>
                    </div>
                    <input type="file" id="galleryInput" accept="image/*,video/*" multiple class="hidden bg-background-dark border border-border-dark text-white">
                  </div>
                </div>
                
                <!-- Game Description -->
                <div>
                  <label class="block text-sm font-medium text-text-muted mb-2">Game Description</label>
                  <textarea name="description" required class="w-full bg-background-dark border border-border-dark rounded-lg px-4 py-3 text-sm text-white placeholder-text-muted focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors resize-none" placeholder="Write a compelling overview of the game..." rows="4"></textarea>
                </div>
              </div>
            </div>
          </section>
        </div>
        
        <!-- Row 2: Hybrid System Requirements Grid -->
        <section class="bg-surface-dark rounded-xl border border-border-dark p-6">
          <div class="flex items-center gap-2 mb-6 pb-4 border-b border-border-dark">
            <span class="material-icons-outlined text-accent text-sm">settings_system_daydream</span>
            <h2 class="text-lg font-semibold text-white">Hardware Requirements</h2>
          </div>
          
          <div id="requirementsTabs" class="flex flex-wrap gap-2 mb-6 border-b border-border-dark pb-2">
            <!-- Tabs generated dynamically -->
          </div>
          
          <div id="requirementsContent">
            <!-- Form blocks generated dynamically -->
          </div>
          
          <div id="noPlatformsMessage" class="text-text-muted text-sm text-center py-6">
            Please select at least one supported platform above to configure requirements.
          </div>
        </section>
      </div>
    </div>

    <!-- Footer containing action buttons -->
    <footer class="px-8 py-4 border-t border-border-dark flex items-center justify-end gap-4 bg-background-dark/50 backdrop-blur-sm flex-shrink-0 z-10 sticky bottom-0">
      <button id="cancelBtn" class="px-6 py-2.5 text-sm font-medium text-white hover:bg-surface-hover border border-border-dark rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-background-dark focus:ring-border-dark" type="button">
        Cancel Intake
      </button>
      <button id="submitBtn" class="px-6 py-2.5 text-sm font-medium text-background-dark bg-accent hover:bg-accent/90 rounded-lg transition-colors flex items-center gap-2 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-background-dark focus:ring-accent" type="submit">
        <span class="material-icons-outlined text-sm">save</span>
        Publish Game to Library
      </button>
    </footer>
  </form>
</main>

<!-- Preset Options Datalists -->
<datalist id="architecture-presets">
  <option value="64-bit"></option>
  <option value="32-bit"></option>
</datalist>
<datalist id="os-presets">
  <option value="Windows 10"></option>
  <option value="Windows 11"></option>
  <option value="macOS"></option>
  <option value="Ubuntu"></option>
</datalist>
<datalist id="processor-presets">
  <option value="Intel Core i5"></option>
  <option value="Intel Core i7"></option>
  <option value="AMD Ryzen 5"></option>
</datalist>
<datalist id="memory-presets">
  <option value="4 GB RAM"></option>
  <option value="8 GB RAM"></option>
  <option value="16 GB RAM"></option>
  <option value="32 GB RAM"></option>
</datalist>
<datalist id="graphics-presets">
  <option value="NVIDIA GTX 1060"></option>
  <option value="NVIDIA RTX 3060"></option>
  <option value="AMD RX 580"></option>
</datalist>
<datalist id="storage-presets">
  <option value="50 GB available space"></option>
  <option value="100 GB available space"></option>
</datalist>

<!-- Cropper.js Workspace Modal overlay -->
<div id="cropperWorkspace" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-background-dark/95 backdrop-blur-sm p-4">
  <div class="bg-surface-dark border border-border-dark rounded-xl max-w-2xl w-full p-6 flex flex-col gap-4 shadow-2xl">
    <div class="flex items-center justify-between border-b border-border-dark pb-3">
      <h3 class="text-lg font-semibold text-white" id="cropperTitle">Crop Cover Image</h3>
      <button type="button" id="closeCropperBtn" class="text-text-muted hover:text-white transition-colors">
        <span class="material-icons-outlined">close</span>
      </button>
    </div>
    <div class="relative w-full max-h-[50vh] bg-background-dark flex items-center justify-center overflow-hidden rounded-lg border border-border-dark">
      <img id="cropperImage" class="max-w-full max-h-[45vh] object-contain" />
    </div>
    <div class="flex gap-3 justify-end border-t border-border-dark pt-3">
      <button type="button" id="cancelCropBtn" class="px-5 py-2 text-sm text-white hover:bg-surface-hover border border-border-dark rounded-lg transition-colors">
        Cancel
      </button>
      <button type="button" id="saveCropBtn" class="px-5 py-2 text-sm text-background-dark bg-accent hover:bg-accent/90 font-medium rounded-lg transition-colors">
        Apply Crop
      </button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
<script>
  // Edition toggle syncing & Dynamic theme switching
  const toggle = document.getElementById('toggle');
  const editionInput = document.getElementById('edition_type');
  const standardLabel = document.getElementById('standardLabel');
  const legendsLabel = document.getElementById('legendsLabel');
  
  toggle.addEventListener('change', function() {
    if (this.checked) {
      this.classList.remove('translate-x-0');
      this.classList.add('translate-x-6');
      editionInput.value = 'LEGENDARY';
      document.documentElement.setAttribute('data-theme', 'legendary');
      
      // Swap label active/inactive styling
      standardLabel.classList.remove('text-accent');
      standardLabel.classList.add('text-text-muted');
      legendsLabel.classList.remove('text-text-muted');
      legendsLabel.classList.add('text-accent');
    } else {
      this.classList.remove('translate-x-6');
      this.classList.add('translate-x-0');
      editionInput.value = 'STANDARD';
      document.documentElement.removeAttribute('data-theme');
      
      // Swap label active/inactive styling
      standardLabel.classList.remove('text-text-muted');
      standardLabel.classList.add('text-accent');
      legendsLabel.classList.remove('text-accent');
      legendsLabel.classList.add('text-text-muted');
    }
  });

  // Cancel redirection
  document.getElementById('cancelBtn').addEventListener('click', function() {
    window.location.href = '/admin/products';
  });
  
  // Media cropping state variables
  let croppedCoverBlob = null;
  let croppedGalleryBlobs = [];
  let cropper = null;
  let currentCropType = 'cover'; 
  let currentGalleryIndex = 0;
  let galleryQueue = [];

  const cropperWorkspace = document.getElementById('cropperWorkspace');
  const cropperImage = document.getElementById('cropperImage');
  const cropperTitle = document.getElementById('cropperTitle');
  const closeCropperBtn = document.getElementById('closeCropperBtn');
  const cancelCropBtn = document.getElementById('cancelCropBtn');
  const saveCropBtn = document.getElementById('saveCropBtn');

  const coverInput = document.getElementById('coverInput');
  const galleryInput = document.getElementById('galleryInput');

  const coverPreviewContainer = document.getElementById('coverPreviewContainer');
  const coverPreview = document.getElementById('coverPreview');
  const galleryPreviews = document.getElementById('galleryPreviews');

  // Trigger Cropper initialization inside overlay
  function startCropper(imageSrc, type, index = 0) {
    currentCropType = type;
    currentGalleryIndex = index;
    
    if (type === 'cover') {
      cropperTitle.textContent = 'Crop Cover Image (3:4 Ratio)';
    } else {
      cropperTitle.textContent = `Crop Gallery Image ${index + 1} of ${galleryQueue.length} (16:9 Ratio)`;
    }
    
    cropperImage.src = imageSrc;
    cropperWorkspace.classList.remove('hidden');
    
    if (cropper) {
      cropper.destroy();
    }
    
    cropper = new Cropper(cropperImage, {
      aspectRatio: type === 'cover' ? 3/4 : 16/9,
      viewMode: 1,
      dragMode: 'move',
      autoCropArea: 0.9,
      responsive: true,
      restore: false,
      guides: true,
      center: true,
      highlight: false,
      cropBoxMovable: true,
      cropBoxResizable: true,
      toggleDragModeOnDblclick: false
    });
  }

  function closeCropper() {
    cropperWorkspace.classList.add('hidden');
    if (cropper) {
      cropper.destroy();
      cropper = null;
    }
  }

  // Replace and Remove cover button listeners
  document.getElementById('replaceCoverBtn').addEventListener('click', function() {
    document.getElementById('coverInput').click();
  });

  document.getElementById('removeCoverBtn').addEventListener('click', function() {
    croppedCoverBlob = null;
    document.getElementById('coverInput').value = '';
    document.getElementById('coverPreviewContainer').classList.add('hidden');
    document.getElementById('coverUploadContainer').classList.remove('hidden');
  });

  // Cover image listener
  coverInput.addEventListener('change', function(e) {
    const files = e.target.files;
    if (files && files.length > 0) {
      const file = files[0];
      const reader = new FileReader();
      reader.onload = function(evt) {
        startCropper(evt.target.result, 'cover');
      };
      reader.readAsDataURL(file);
    }
  });

  // Render gallery thumbnails dynamically
  function renderGalleryPreviews() {
    const container = document.getElementById('galleryPreviews');
    container.innerHTML = '';
    
    croppedGalleryBlobs.forEach((blob, idx) => {
      const thumb = document.createElement('div');
      thumb.className = 'w-16 h-16 rounded-lg bg-surface-dark border border-border-dark flex items-center justify-center overflow-hidden relative group';
      
      if (blob instanceof File && blob.type.startsWith('video/')) {
        const videoIcon = document.createElement('span');
        videoIcon.className = 'material-icons-outlined text-accent text-2xl';
        videoIcon.textContent = 'videocam';
        thumb.appendChild(videoIcon);
        
        const badge = document.createElement('span');
        badge.className = 'absolute bottom-1 right-1 bg-black/60 text-[8px] text-white px-1 rounded';
        badge.textContent = `Video`;
        thumb.appendChild(badge);
      } else {
        const img = document.createElement('img');
        img.src = URL.createObjectURL(blob);
        img.className = 'w-full h-full object-cover';
        thumb.appendChild(img);
      }
      
      // Delete button
      const deleteBtn = document.createElement('button');
      deleteBtn.type = 'button';
      deleteBtn.className = 'absolute inset-0 bg-black/75 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity text-red-500 cursor-pointer border-none rounded-lg';
      deleteBtn.innerHTML = '<span class="material-icons-outlined text-sm">delete_outline</span>';
      deleteBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        croppedGalleryBlobs.splice(idx, 1);
        renderGalleryPreviews();
      });
      thumb.appendChild(deleteBtn);
      
      container.appendChild(thumb);
    });
    
    // Persistent "+" placeholder button at the end (shown only if < 5 items)
    if (croppedGalleryBlobs.length < 5) {
      const plusBtn = document.createElement('button');
      plusBtn.type = 'button';
      plusBtn.id = 'galleryAddBtn';
      plusBtn.onclick = () => document.getElementById('galleryInput').click();
      plusBtn.className = 'w-16 h-16 rounded-lg border-2 border-dashed border-border-dark hover:border-accent hover:text-accent flex flex-col items-center justify-center text-text-muted transition-colors cursor-pointer bg-background-dark/30';
      plusBtn.innerHTML = '<span class="material-icons-outlined text-xl">add</span><span class="text-[8px] mt-1">Add Media</span>';
      container.appendChild(plusBtn);
    }
  }

  // Gallery multi-file listener
  galleryInput.addEventListener('change', function(e) {
    const files = Array.from(e.target.files);
    if (files.length === 0) return;
    
    if (croppedGalleryBlobs.length + files.length > 5) {
      Swal.fire({
        title: 'Limit Exceeded',
        text: 'You can upload a maximum of 5 images/videos to the game gallery.',
        icon: 'error',
        confirmButtonColor: '#2cb5e8'
      });
      galleryInput.value = '';
      return;
    }
    
    galleryQueue = files;
    
    // Begin queuing
    cropNextGalleryImage(0);
  });

  function cropNextGalleryImage(index) {
    currentGalleryIndex = index;
    if (index < galleryQueue.length) {
      const file = galleryQueue[index];
      
      // If the file is a video, bypass the cropper and push directly
      if (file.type.startsWith('video/')) {
        croppedGalleryBlobs.push(file);
        renderGalleryPreviews();
        
        // Proceed to next file
        cropNextGalleryImage(index + 1);
      } else {
        // It's an image. Crop it.
        const reader = new FileReader();
        reader.onload = function(evt) {
          startCropper(evt.target.result, 'gallery', index);
        };
        reader.readAsDataURL(file);
      }
    } else {
      closeCropper();
      galleryInput.value = ''; // clear input so change fires on same files again
    }
  }

  // Save crop click listener
  saveCropBtn.addEventListener('click', function() {
    if (!cropper) return;
    
    const canvas = cropper.getCroppedCanvas({
      width: currentCropType === 'cover' ? 600 : 1280,
      height: currentCropType === 'cover' ? 800 : 720
    });
    
    canvas.toBlob(function(blob) {
      if (currentCropType === 'cover') {
        croppedCoverBlob = blob;
        coverPreview.src = URL.createObjectURL(blob);
        coverPreviewContainer.classList.remove('hidden');
        document.getElementById('coverUploadContainer').classList.add('hidden');
        closeCropper();
      } else {
        croppedGalleryBlobs.push(blob);
        renderGalleryPreviews();
        
        // Next image in queue
        const nextIndex = currentGalleryIndex + 1;
        if (nextIndex < galleryQueue.length) {
          cropNextGalleryImage(nextIndex);
        } else {
          closeCropper();
          galleryInput.value = '';
        }
      }
    }, 'image/png');
  });

  // Cancel crop
  cancelCropBtn.addEventListener('click', function() {
    closeCropper();
    if (currentCropType === 'cover') {
