  function updateHardwareRequirementsUI() {
    // Collect all selected platforms
    const checkedBoxes = Array.from(document.querySelectorAll('.platform-checkbox:checked')).map(cb => cb.value);
    const selected = [...checkedBoxes];

    if (selected.length === 0) {
      noPlatformsMessage.classList.remove('hidden');
      requirementsTabs.classList.add('hidden');
      requirementsContent.classList.add('hidden');
      requirementsTabs.innerHTML = '';
      requirementsContent.innerHTML = '';
      activePlatformTab = '';
      return;
    }

    noPlatformsMessage.classList.add('hidden');
    requirementsTabs.classList.remove('hidden');
    requirementsContent.classList.remove('hidden');

    // Remove platforms that are no longer selected
    const renderedBlocks = Array.from(requirementsContent.querySelectorAll('.platform-req-form'));
    renderedBlocks.forEach(block => {
      const p = block.dataset.platform;
      if (!selected.includes(p)) {
        block.remove();
      }
    });

    // Render blocks for newly selected platforms
    selected.forEach(platform => {
      let block = requirementsContent.querySelector(`.platform-req-form[data-platform="${platform}"]`);
      if (!block) {
        const tempDiv = document.createElement('div');
        if (platform === 'PC') {
          tempDiv.innerHTML = getPCRequirementsHTML(platform);
        } else {
          const defaults = consoleDefaults[platform] || { os: `${platform} System OS`, storage: "50 GB", graphics: "1080p Support" };
          tempDiv.innerHTML = getConsoleRequirementsHTML(platform, defaults);
        }
        requirementsContent.appendChild(tempDiv.firstElementChild);
      }
    });

    // Ensure activePlatformTab is valid
    if (!selected.includes(activePlatformTab)) {
      activePlatformTab = selected[0];
    }

    // Render Tabs
    requirementsTabs.innerHTML = '';
    selected.forEach(platform => {
      const tabBtn = document.createElement('button');
      tabBtn.type = 'button';
      tabBtn.className = `px-4 py-2 text-xs font-semibold rounded-lg border transition-colors cursor-pointer ${
        platform === activePlatformTab 
          ? 'bg-accent text-background-dark border-accent' 
          : 'bg-transparent text-text-muted border-border-dark hover:text-white'
      }`;
      tabBtn.textContent = platform;
      tabBtn.addEventListener('click', function() {
        activePlatformTab = platform;
        showActivePlatformForm();
      });
      requirementsTabs.appendChild(tabBtn);
    });

    showActivePlatformForm();
    updatePlatformStocksUI();
  }

  const platformStocksSection = document.getElementById('platformStocksSection');
