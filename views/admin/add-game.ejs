    );
    
    if (filtered.length === 0) {
      const noResult = document.createElement('div');
      noResult.className = 'px-4 py-2 text-xs text-text-muted';
      noResult.textContent = 'No matching platforms';
      otherDropdown.appendChild(noResult);
      return;
