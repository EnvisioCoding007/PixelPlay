            <input type="number" min="0" step="0.01" required 
              data-platform="${platform}"
              data-field="price"
              name="platform_price_${platform}" 
              id="price_${slug}" 
              value="${savedPrice}" 
              class="w-24 bg-surface-dark border border-border-dark rounded px-2 py-1 text-sm text-white focus:outline-none focus:border-accent text-right" 
              placeholder="0.00" />
          </div>
        </div>
      `;
      platformStocksContainer.appendChild(row);
    });
  }

  function showActivePlatformForm() {
    // Update tab styles
    const tabButtons = Array.from(requirementsTabs.querySelectorAll('button'));
    tabButtons.forEach(btn => {
      if (btn.textContent === activePlatformTab) {
        btn.className = 'px-4 py-2 text-xs font-semibold rounded-lg border bg-accent text-background-dark border-accent cursor-pointer';
      } else {
        btn.className = 'px-4 py-2 text-xs font-semibold rounded-lg border bg-transparent text-text-muted border-border-dark hover:text-white cursor-pointer';
      }
    });

    // Show only the active form block
    const blocks = Array.from(requirementsContent.querySelectorAll('.platform-req-form'));
    blocks.forEach(block => {
      if (block.dataset.platform === activePlatformTab) {
        block.classList.remove('hidden');
      } else {
        block.classList.add('hidden');
      }
    });
  }

  // Initialize requirements UI empty state
  updateHardwareRequirementsUI();

  // Cancel redirection
  document.getElementById('cancelBtn').addEventListener('click', function() {
    window.location.href = '/admin/products';
  });

  // Form Submit Interceptor & AJAX poster
  const form = document.getElementById('addGameForm');
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const categorySelect = form.category;
    const selectedOption = categorySelect ? categorySelect.options[categorySelect.selectedIndex] : null;
    const isCategoryUnlisted = selectedOption ? selectedOption.getAttribute('data-status') === 'Hidden' : false;
    
    if (isCategoryUnlisted) {
      Swal.fire({
        title: 'Validation Error',
        text: 'This game is linked to an unlisted category. Please change the game category to list the game.',
        icon: 'error',
        confirmButtonColor: '#2cb5e8'
      });
      return;
    }

    if (!croppedCoverBlob) {
      Swal.fire({
        title: 'Validation Error',
        text: 'Please select and crop a Cover Art image.',
        icon: 'error',
        confirmButtonColor: '#2cb5e8'
      });
      return;
    }
    
    if (croppedGalleryBlobs.length < 3) {
      Swal.fire({
        title: 'Validation Error',
        text: `Please select at least 3 files for the Media Gallery. Current: ${croppedGalleryBlobs.length}`,
        icon: 'error',
        confirmButtonColor: '#2cb5e8'
      });
      return;
    }
    
    if (croppedGalleryBlobs.length > 5) {
      Swal.fire({
        title: 'Validation Error',
        text: 'Game gallery cannot have more than 5 images/videos.',
        icon: 'error',
        confirmButtonColor: '#2cb5e8'
      });
      return;
    }
    
    const formData = new FormData();
    
    // Core parameters
    formData.append('title', form.title.value);
    formData.append('publisher', form.publisher.value);
    formData.append('release_year', form.release_year.value);
    formData.append('category', form.category.value);
    formData.append('edition_type', form.edition_type.value);
    formData.append('description', form.description.value);
    let totalStock = 0;
    let firstPlatformPrice = 0;
    let hasFirstPlat = false;
    // Platforms checkbox mapping (both standard and other platforms badges are scanned)
    form.querySelectorAll('input[name="platforms[]"]:checked').forEach(cb => {
      const platform = cb.value;
      const slug = platform.replace(/[^a-zA-Z0-9]/g, '_');
      const stockInput = document.getElementById(`stock_${slug}`);
      const priceInput = document.getElementById(`price_${slug}`);
      const stockVal = parseInt(stockInput ? stockInput.value : '0') || 0;
      const priceVal = parseFloat(priceInput ? priceInput.value : '0.00') || 0;
      totalStock += stockVal;
      if (!hasFirstPlat) {
        firstPlatformPrice = priceVal;
        hasFirstPlat = true;
      }
      formData.append(`platform_stock_${platform}`, stockVal);
      formData.append(`platform_price_${platform}`, Math.round(priceVal * 100));
      formData.append('platforms[]', platform);
    });
    formData.append('stock', totalStock);
    formData.append('price', Math.round(firstPlatformPrice * 100));
    
    // Dynamic System Requirements mapping — read only from the currently visible (active) platform block
    const activeReqBlock = document.querySelector('.platform-req-form:not(.hidden)');
    if (activeReqBlock) {
      const getVal = (dataReq) => {
        const input = activeReqBlock.querySelector(`[data-req="${dataReq}"]`);
        return input ? input.value : '';
      };
      
      formData.append('system_requirements.minimum.architecture', getVal('minimum.architecture'));
      formData.append('system_requirements.minimum.os', getVal('minimum.os'));
      formData.append('system_requirements.minimum.processor', getVal('minimum.processor'));
      formData.append('system_requirements.minimum.memory', getVal('minimum.memory'));
      formData.append('system_requirements.minimum.graphics', getVal('minimum.graphics'));
      formData.append('system_requirements.minimum.storage', getVal('minimum.storage'));
      formData.append('system_requirements.minimum.sound_card', getVal('minimum.sound_card'));
      formData.append('system_requirements.minimum.additional_notes', getVal('minimum.additional_notes'));
      
      formData.append('system_requirements.recommended.architecture', getVal('recommended.architecture'));
      formData.append('system_requirements.recommended.os', getVal('recommended.os'));
      formData.append('system_requirements.recommended.processor', getVal('recommended.processor'));
      formData.append('system_requirements.recommended.memory', getVal('recommended.memory'));
      formData.append('system_requirements.recommended.graphics', getVal('recommended.graphics'));
      formData.append('system_requirements.recommended.storage', getVal('recommended.storage'));
      formData.append('system_requirements.recommended.sound_card', getVal('recommended.sound_card'));
      formData.append('system_requirements.recommended.additional_notes', getVal('recommended.additional_notes'));
    } else {
      // Fallback
      formData.append('system_requirements.minimum.architecture', '64-bit');
      formData.append('system_requirements.minimum.os', 'N/A');
      formData.append('system_requirements.minimum.processor', 'N/A');
      formData.append('system_requirements.minimum.memory', 'N/A');
      formData.append('system_requirements.minimum.graphics', 'N/A');
      formData.append('system_requirements.minimum.storage', 'N/A');
      formData.append('system_requirements.minimum.sound_card', '');
      formData.append('system_requirements.minimum.additional_notes', '');
      
      formData.append('system_requirements.recommended.architecture', '64-bit');
      formData.append('system_requirements.recommended.os', 'N/A');
      formData.append('system_requirements.recommended.processor', 'N/A');
      formData.append('system_requirements.recommended.memory', 'N/A');
      formData.append('system_requirements.recommended.graphics', 'N/A');
      formData.append('system_requirements.recommended.storage', 'N/A');
      formData.append('system_requirements.recommended.sound_card', '');
      formData.append('system_requirements.recommended.additional_notes', '');
    }
    
    // Attach cropped blobs
    formData.append('cover_image', croppedCoverBlob, 'cover.png');
    croppedGalleryBlobs.forEach((blob, idx) => {
      if (blob instanceof File) {
        const ext = blob.name.split('.').pop() || 'mp4';
        formData.append('gallery', blob, `gallery-${idx}.${ext}`);
      } else {
        formData.append('gallery', blob, `gallery-${idx}.png`);
      }
    });
    
    try {
      const submitBtn = document.getElementById('submitBtn');
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="material-icons-outlined animate-spin text-sm">sync</span> Publishing...';
      
      const response = await fetch('/admin/products', {
        method: 'POST',
        body: formData
      });
      
      let result = null;
      const contentType = response.headers.get('content-type');
      if (contentType && contentType.includes('application/json')) {
        result = await response.json();
      }
      
      if (response.ok && result && result.success) {
        await Swal.fire({
          title: 'Success!',
          text: 'Game published successfully!',
          icon: 'success',
          confirmButtonColor: '#2cb5e8'
        });
        window.location.href = '/admin/products';
      } else {
        const errMsg = result && result.message 
          ? result.message 
          : `Server returned status ${response.status} (${response.statusText || 'Unknown Error'})`;
        Swal.fire({
          title: 'Publish Failed',
          text: 'Error publishing game: ' + errMsg,
          icon: 'error',
          confirmButtonColor: '#2cb5e8'
        });
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<span class="material-icons-outlined text-sm">save</span> Publish Game to Library';
      }
    } catch (err) {
      console.error('Submission error:', err);
      Swal.fire({
        title: 'Error',
        text: 'Failed to submit form: ' + err.message,
        icon: 'error',
        confirmButtonColor: '#2cb5e8'
      });
      const submitBtn = document.getElementById('submitBtn');
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<span class="material-icons-outlined text-sm">save</span> Publish Game to Library';
    }
  });
</script>

<%- include('../partials/admin/footer') %>