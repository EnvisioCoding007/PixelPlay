    filtered.forEach(platform => {
      // Don't show in dropdown if it's already selected
      const isAlreadySelected = Array.from(document.querySelectorAll('input[name="platforms[]"]'))
        .some(cb => cb.value === platform);
      
      if (isAlreadySelected) return;

      const item = document.createElement('div');
      item.className = 'px-4 py-2 text-sm text-white hover:bg-accent hover:text-background-dark cursor-pointer transition-colors';
