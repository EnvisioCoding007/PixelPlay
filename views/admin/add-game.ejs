    platformStocksContainer.innerHTML = '';
    checkedBoxes.forEach(platform => {
      const slug = platform.replace(/[^a-zA-Z0-9]/g, '_');
      const savedStock = currentStockValues[platform] !== undefined ? currentStockValues[platform] : '0';
      const savedPrice = currentPriceValues[platform] !== undefined ? currentPriceValues[platform] : '0.00';

      const row = document.createElement('div');
      row.className = 'flex items-center justify-between gap-4 py-2 border-b border-border-dark last:border-b-0';
      row.innerHTML = `
        <span class="text-sm font-medium text-white">${platform}</span>
