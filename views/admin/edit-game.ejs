<%- include('../partials/admin/header') %>
<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet"/>
<link rel="stylesheet" href="/globals.css">

<body class="bg-background-dark text-white antialiased h-screen flex overflow-hidden">
<%- include('../partials/admin/sidebar', { activeTab: 'listed-games' }) %>

<main class="flex-1 flex flex-col h-full overflow-hidden bg-background-dark text-white">
  <form id="gameEditForm" class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Page Header -->
    <header class="px-8 py-6 border-b border-border-dark flex items-center justify-between flex-shrink-0 bg-background-dark/50 backdrop-blur-sm z-10 sticky top-0">
      <div class="flex items-center gap-3">
        <span class="material-icons-outlined text-accent text-2xl">edit</span>
        <h1 class="text-2xl font-bold text-white">Edit Game: <%= product.title %></h1>
      </div>
      <div class="flex items-center gap-6">
        <!-- Status / Listing Toggle -->
        <div class="flex items-center gap-3 bg-surface-dark px-4 py-2 rounded-full border border-border-dark">
          <span id="statusLabel" class="text-sm font-medium <%= product.status === 'Hidden' ? 'text-text-muted' : 'text-accent' %>">Listed</span>
          <div class="relative inline-block w-12 mr-2 align-middle select-none transition duration-200 ease-in">
            <input class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-accent border-4 border-surface-dark appearance-none cursor-pointer transform <%= product.status === 'Hidden' ? 'translate-x-6' : 'translate-x-0' %> transition-transform duration-200 ease-in-out bg-background-dark border border-border-dark text-white" id="statusToggle" type="checkbox" <%= product.status === 'Hidden' ? 'checked' : '' %>/>
            <label class="toggle-label block overflow-hidden h-6 rounded-full bg-border-dark cursor-pointer" for="statusToggle"></label>
          </div>
          <span id="unlistLabel" class="text-sm font-medium <%= product.status === 'Hidden' ? 'text-accent' : 'text-text-muted' %>">Unlisted</span>
        </div>

        <!-- Edition Type Toggle -->
        <div class="flex items-center gap-3 bg-surface-dark px-4 py-2 rounded-full border border-border-dark">
          <span id="standardLabel" class="text-sm font-medium <%= product.edition_type === 'LEGENDARY' ? 'text-text-muted' : 'text-accent' %>">Standard</span>
          <div class="relative inline-block w-12 mr-2 align-middle select-none transition duration-200 ease-in">
            <input class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-accent border-4 border-surface-dark appearance-none cursor-pointer transform <%= product.edition_type === 'LEGENDARY' ? 'translate-x-6' : 'translate-x-0' %> transition-transform duration-200 ease-in-out bg-background-dark border border-border-dark text-white" id="toggle" type="checkbox" <%= product.edition_type === 'LEGENDARY' ? 'checked' : '' %>/>
            <label class="toggle-label block overflow-hidden h-6 rounded-full bg-border-dark cursor-pointer" for="toggle"></label>
          </div>
          <span id="legendsLabel" class="text-sm font-medium <%= product.edition_type === 'LEGENDARY' ? 'text-accent' : 'text-text-muted' %>">Legends</span>
        </div>
      </div>
    </header>
    
    <!-- Hidden Edition Type & Status Inputs -->
    <input type="hidden" id="edition_type" name="edition_type" value="<%= product.edition_type || 'STANDARD' %>" class="bg-background-dark border border-border-dark text-white" />
    <input type="hidden" id="status" name="status" value="<%= product.status || 'Live' %>" class="bg-background-dark border border-border-dark text-white" />

    <div class="flex-1 overflow-y-auto p-8 bg-background-dark text-white">
      <div class="max-w-6xl mx-auto space-y-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          
          <!-- Column 1: Core Details -->
          <section class="bg-surface-dark rounded-xl border border-border-dark p-6">
            <div class="flex items-center gap-2 mb-6 pb-4 border-b border-border-dark">
              <span class="material-icons-outlined text-accent text-sm">info</span>
              <h2 class="text-lg font-semibold text-white">Core Details</h2>
            </div>
            
            <div class="space-y-5">
              <!-- Game Title -->
              <div>
                <label class="block text-sm font-medium text-text-muted mb-2">Game Title</label>
                <input name="title" required value="<%= product.title %>" class="w-full bg-background-dark border border-border-dark rounded-lg px-4 py-3 text-sm text-white placeholder-text-muted focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors" placeholder="e.g. Cyberpunk 2077" type="text"/>
              </div>

              <!-- Publisher -->
              <div>
                <label class="block text-sm font-medium text-text-muted mb-2">Publisher</label>
                <div class="relative">
                  <select name="publisher" required class="w-full bg-background-dark border border-border-dark rounded-lg px-4 py-3 text-sm text-white appearance-none focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors cursor-pointer">
                    <option class="text-text-muted" disabled="" value="">Select Publisher...</option>
                    <% 
                      const defaultPublishers = ['Electronic Arts', 'Ubisoft', 'Sony Interactive Entertainment', 'Nintendo', 'Activision Blizzard', 'Take-Two Interactive'];
                      const dbPublisherNames = (typeof publishers !== 'undefined' && publishers) ? publishers.map(p => p.name) : [];
                      const combinedPublishers = Array.from(new Set([...defaultPublishers, ...dbPublisherNames, product.publisher].filter(Boolean))).sort();
                      combinedPublishers.forEach(pub => {
                    %>
                      <option value="<%= pub %>" <%= product.publisher === pub ? 'selected' : '' %>><%= pub %></option>
                    <% }) %>
                  </select>
                  <span class="material-icons-outlined absolute right-3 top-1/2 -translate-y-1/2 text-text-muted pointer-events-none text-sm">arrow_drop_down</span>
                </div>
              </div>
              
              <!-- Core Grid: Release Year -->
              <div>
                <label class="block text-sm font-medium text-text-muted mb-2">Release Year</label>
                <input name="release_year" required value="<%= product.release_year %>" class="w-full bg-background-dark border border-border-dark rounded-lg px-4 py-3 text-sm text-white placeholder-text-muted focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors" placeholder="e.g. 2023" type="number" min="1950" max="2100"/>
              </div>
              
              <!-- Category -->
              <div>
                <label class="block text-sm font-medium text-text-muted mb-2">Primary Category</label>
                <div class="relative">
                  <select name="category" required class="w-full bg-background-dark border border-border-dark rounded-lg px-4 py-3 text-sm text-white appearance-none focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors cursor-pointer">
                    <option disabled="" value="">Select category...</option>
                    <% if (typeof categories !== 'undefined' && categories && categories.length > 0) { %>
                      <% categories.forEach(cat => { %>
                        <% 
                          const isSelected = product.category && 
                            (cat._id.toString() === product.category.toString() || cat.name === product.category);
                        %>
                        <option value="<%= cat._id %>" <%= isSelected ? 'selected' : '' %>><%= cat.name %></option>
                      <% }) %>
                    <% } %>
                  </select>
                  <span class="material-icons-outlined absolute right-3 top-1/2 -translate-y-1/2 text-text-muted pointer-events-none text-sm">arrow_drop_down</span>
                </div>
              </div>
              
              <!-- Supported Platforms -->
              <div>
                <label class="block text-sm font-medium text-text-muted mb-2">Supported Platforms</label>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-4 bg-background-dark border border-border-dark rounded-lg px-4 py-3" id="platformsContainer">
                  <% 
                    const standardPlatforms = ['PC', 'PlayStation 5', 'Xbox Series X|S', 'PlayStation 4', 'Xbox One'];
                    standardPlatforms.forEach(platform => {
                      const isChecked = product.platforms && product.platforms.includes(platform);
                  %>
                    <label class="flex items-center gap-2 cursor-pointer text-sm text-white">
                      <input type="checkbox" name="platforms[]" value="<%= platform %>" <%= isChecked ? 'checked' : '' %> class="platform-checkbox rounded bg-background-dark border border-border-dark text-white text-accent focus:ring-accent">
                      <span><%= platform %></span>
                    </label>
                  <% }) %>

                  <% 
                    if (product.platforms && product.platforms.length > 0) {
                      product.platforms.forEach(platform => {
                        if (!standardPlatforms.includes(platform)) {
                  %>
                    <label class="flex items-center gap-2 cursor-pointer text-sm text-white dynamic-platform-checkbox">
                      <input type="checkbox" name="platforms[]" value="<%= platform %>" checked class="platform-checkbox rounded bg-background-dark border border-border-dark text-white text-accent focus:ring-accent">
                      <span><%= platform %></span>
                    </label>
                  <% 
                        }
                      })
                    }
                  %>

                  <label class="flex items-center gap-2 cursor-pointer text-sm text-white">
                    <input type="checkbox" id="otherPlatformsToggle" <%= (product.platforms && product.platforms.some(p => !standardPlatforms.includes(p))) ? 'checked' : '' %> class="rounded bg-background-dark border border-border-dark text-white text-accent focus:ring-accent">
                    <span>Other</span>
                  </label>
                </div>
                
                <!-- Dynamic Other Platforms Searchable Dropdown -->
                <div id="otherPlatformsContainer" class="<%= (product.platforms && product.platforms.some(p => !standardPlatforms.includes(p))) ? '' : 'hidden' %> mt-3 p-4 bg-background-dark/50 border border-border-dark rounded-lg space-y-3 relative">
                  <label class="block text-xs font-medium text-text-muted">Search & Add Legacy/Extended Platforms</label>
                  <div class="relative">
                    <input type="text" id="otherPlatformsSearch" placeholder="Type platform name (e.g. Switch, PS3, Wii)..." class="w-full bg-background-dark border border-border-dark rounded-lg px-4 py-2.5 text-sm text-white placeholder-text-muted focus:outline-none focus:border-accent">
                    <div id="otherPlatformsDropdown" class="hidden absolute left-0 right-0 mt-1 max-h-48 overflow-y-auto bg-surface-dark border border-border-dark rounded-lg shadow-xl z-20">
                       <!-- Dropdown options rendered dynamically -->
                    </div>
                  </div>
                </div>

                <!-- Configure Stock per Platform -->
                <div id="platformStocksSection" class="hidden mt-4">
                  <label class="block text-sm font-medium text-text-muted mb-2">Configure Stock per Platform</label>
                  <div id="platformStocksContainer" class="flex flex-col gap-3 bg-background-dark border border-border-dark rounded-lg p-4">
                    <!-- Dynamic stock rows render here -->
                  </div>
                </div>

                <!-- Pre-load existing platform stocks -->
                <script id="existingPlatformStocks" type="application/json">
                  <%- JSON.stringify(product.platform_stock || []) %>
                </script>
              </div>
            </div>
          </section>

          <!-- Column 2: Media Gallery & Description -->
          <section class="bg-surface-dark rounded-xl border border-border-dark p-6 flex flex-col justify-between">
            <div>
              <div class="flex items-center gap-2 mb-6 pb-4 border-b border-border-dark">
                <span class="material-icons-outlined text-accent text-sm">perm_media</span>
                <h2 class="text-lg font-semibold text-white">Media &amp; Summary</h2>
              </div>
              <div class="space-y-6">
                <!-- Cover Art -->
                <div>
                  <label class="block text-sm font-medium text-text-muted mb-2">Cover Art</label>
                  <div onclick="document.getElementById('coverInput').click()" class="border-2 border-dashed border-border-dark rounded-xl p-8 flex flex-col items-center justify-center text-center cursor-pointer hover:border-text-muted transition-colors bg-background-dark/50 relative overflow-hidden h-48">
                    <img id="coverPreview" class="absolute inset-0 w-full h-full object-cover" src="<%= product.cover_image %>" />
                    <div class="absolute inset-0 bg-black/40 flex flex-col items-center justify-center text-center opacity-0 hover:opacity-100 transition-opacity">
                      <span class="material-icons-outlined text-4xl text-white mb-2">cloud_upload</span>
                      <p class="text-sm font-medium text-white mb-1">Change Cover Image</p>
                    </div>
                  </div>
                  <input type="file" id="coverInput" accept="image/*" class="hidden bg-background-dark border border-border-dark text-white">
                </div>
                
                <!-- Media Gallery -->
                <div>
                  <label class="block text-sm font-medium text-text-muted mb-2">Media Gallery (Min 1 Screenshot/Video)</label>
                  <div class="border-2 border-dashed border-border-dark rounded-xl p-6 bg-background-dark/50">
                    <div id="galleryPreviews" class="flex flex-wrap gap-3 items-center justify-start">
                      <!-- Existing gallery items -->
                      <% if (product.gallery && product.gallery.length > 0) { %>
                        <% product.gallery.forEach((url, idx) => { %>
                          <div class="relative w-16 h-16 rounded-md overflow-hidden flex-shrink-0 border border-border-dark gallery-item">
                            <img alt="Gallery thumbnail <%= idx + 1 %>" class="w-full h-full object-cover" src="<%= url %>"/>
                            <input type="hidden" name="existing_gallery[]" value="<%= url %>"/>
                            <button type="button" onclick="this.parentNode.remove()" class="absolute top-1 right-1 bg-black/70 rounded-full p-0.5 text-gray-300 hover:text-white hover:bg-red-500/80">
                              <svg class="h-3 w-3" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                                <path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                              </svg>
                            </button>
                          </div>
                        <% }) %>
                      <% } %>
                      
                      <!-- Persistent "+" placeholder button at the end -->
                      <button type="button" id="galleryAddBtn" onclick="document.getElementById('galleryInput').click()" class="w-16 h-16 rounded-lg border-2 border-dashed border-border-dark hover:border-accent hover:text-accent flex flex-col items-center justify-center text-text-muted transition-colors cursor-pointer bg-background-dark/30">
                        <span class="material-icons-outlined text-xl">add</span>
                        <span class="text-[8px] mt-1">Add Media</span>
                      </button>
                    </div>
                    <input type="file" id="galleryInput" accept="image/*,video/*" multiple class="hidden bg-background-dark border border-border-dark text-white" onchange="handleGalleryUpload(this)">
                  </div>
                </div>
                
                <!-- Game Description -->
                <div>
                  <label class="block text-sm font-medium text-text-muted mb-2">Game Description</label>
                  <textarea name="description" required class="w-full bg-background-dark border border-border-dark rounded-lg px-4 py-3 text-sm text-white placeholder-text-muted focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors resize-none" placeholder="Write a compelling overview of the game..." rows="4"><%= product.description %></textarea>
                </div>
              </div>
            </div>
          </section>
        </div>
        
        <!-- Row 2: Hybrid System Requirements Grid -->
        <section class="bg-surface-dark rounded-xl border border-border-dark p-6">
          <div class="flex items-center gap-2 mb-6 pb-4 border-b border-border-dark">
            <span class="material-icons-outlined text-accent text-sm">settings_system_daydream</span>
            <h2 class="text-lg font-semibold text-white">Hardware Requirements</h2>
          </div>
          
          <div id="requirementsTabs" class="flex flex-wrap gap-2 mb-6 border-b border-border-dark pb-2">
            <!-- Tabs generated dynamically -->
          </div>
          
          <div id="requirementsContent" class="bg-background-dark/30 p-6 rounded-lg border border-border-dark">
            <!-- Form blocks generated dynamically -->
          </div>
          
          <div id="noPlatformsMessage" class="text-text-muted text-sm text-center py-6">
            Please select at least one supported platform above to configure requirements.
          </div>
        </section>
      </div>
    </div>
    
    <!-- Footer containing action buttons -->
    <footer class="px-8 py-4 border-t border-border-dark flex items-center justify-end gap-4 bg-background-dark/50 backdrop-blur-sm flex-shrink-0 z-10 sticky bottom-0">
      <button id="cancelBtn" class="px-6 py-2.5 text-sm font-medium text-white hover:bg-surface-hover border border-border-dark rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-background-dark focus:ring-border-dark" type="button">
        Discard Changes
      </button>
      <button id="submitBtn" class="px-6 py-2.5 text-sm font-medium text-background-dark bg-accent hover:bg-accent/90 rounded-lg transition-colors flex items-center gap-2 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-background-dark focus:ring-accent" type="submit">
        <span class="material-icons-outlined text-sm">save</span>
        Save Modifications
      </button>
    </footer>
  </form>
</main>

<!-- Preset Options Datalists -->
<datalist id="architecture-presets">
  <option value="64-bit"></option>
  <option value="32-bit"></option>
</datalist>
<datalist id="os-presets">
  <option value="Windows 10"></option>
  <option value="Windows 11"></option>
  <option value="macOS"></option>
  <option value="Ubuntu"></option>
</datalist>
<datalist id="processor-presets">
  <option value="Intel Core i5"></option>
  <option value="Intel Core i7"></option>
  <option value="AMD Ryzen 5"></option>
</datalist>
<datalist id="memory-presets">
  <option value="4 GB RAM"></option>
  <option value="8 GB RAM"></option>
  <option value="16 GB RAM"></option>
  <option value="32 GB RAM"></option>
</datalist>
<datalist id="graphics-presets">
  <option value="NVIDIA GTX 1060"></option>
  <option value="NVIDIA RTX 3060"></option>
  <option value="AMD RX 580"></option>
</datalist>
<datalist id="storage-presets">
  <option value="50 GB available space"></option>
  <option value="100 GB available space"></option>
</datalist>

<!-- ── Status Confirmation Modal ──────────────────────────────── -->
<div id="status-confirm-modal"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-zinc-950/80 backdrop-blur-sm"
    role="dialog" aria-modal="true" aria-labelledby="status-modal-title">
    <div class="relative bg-[#141418] border border-[#353437] rounded-xl max-w-md w-full mx-4 p-6 shadow-2xl">
        <!-- Alert icon -->
        <div id="status-modal-icon" class="flex items-center justify-center w-12 h-12 rounded-full mx-auto mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" id="status-modal-svg">
                <!-- Icon path dynamically generated -->
            </svg>
        </div>
        <h3 id="status-modal-title" class="[font-family:'Inter-Bold',Helvetica] font-bold text-[#e6eef2] text-lg text-center mb-2">
            Confirm Status Change
        </h3>
        <p id="status-modal-desc" class="[font-family:'Inter-Regular',Helvetica] text-[#9aa6ab] text-sm text-center leading-relaxed mb-4">
            Are you sure you want to change the status of this game?
        </p>
        <div class="bg-surface-dark border border-border-dark rounded-lg p-3.5 mb-6">
            <span class="text-xs font-semibold text-pixel-yellow uppercase tracking-wider block mb-1">Disclaimer / Notice</span>
            <p id="status-modal-disclaimer" class="text-xs text-[#9aa6ab] leading-relaxed">
                Disclaimer message goes here.
            </p>
        </div>
        <div class="flex gap-3 justify-center">
            <button id="status-modal-cancel-btn" type="button"
                class="flex-1 py-2.5 px-4 rounded border border-solid border-[#ffffff1f] bg-transparent [font-family:'Inter-Medium',Helvetica] text-sm text-[#9aa6ab] hover:bg-[#2a2a2f] hover:text-[#e6eef2] transition-colors cursor-pointer">
                Cancel
            </button>
            <button id="status-modal-confirm-btn" type="button"
                class="flex-1 py-2.5 px-4 rounded border border-solid [font-family:'Inter-Medium',Helvetica] text-sm transition-colors cursor-pointer">
                Confirm
            </button>
        </div>
    </div>
</div>

<script>
  // Edition toggle syncing & Dynamic theme switching
  const toggle = document.getElementById('toggle');
  const editionInput = document.getElementById('edition_type');
  const standardLabel = document.getElementById('standardLabel');
  const legendsLabel = document.getElementById('legendsLabel');

  // Status toggle syncing
  const statusToggle = document.getElementById('statusToggle');
  const statusInput = document.getElementById('status');
  const statusLabel = document.getElementById('statusLabel');
  const unlistLabel = document.getElementById('unlistLabel');

  const statusConfirmModal = document.getElementById('status-confirm-modal');
  const statusModalTitle = document.getElementById('status-modal-title');
  const statusModalDesc = document.getElementById('status-modal-desc');
  const statusModalDisclaimer = document.getElementById('status-modal-disclaimer');
  const statusModalConfirmBtn = document.getElementById('status-modal-confirm-btn');
  const statusModalCancelBtn = document.getElementById('status-modal-cancel-btn');
  const statusModalIcon = document.getElementById('status-modal-icon');
  const statusModalSvg = document.getElementById('status-modal-svg');

  let pendingStatusChange = null;

  // Make sure status toggle is visually correctly offset on load
  if (statusToggle.checked) {
    statusToggle.classList.remove('translate-x-0');
    statusToggle.classList.add('translate-x-6');
  }

  function openStatusConfirmModal(targetState) {
    pendingStatusChange = targetState;
    
    if (targetState === 'Live') {
      // Listing the game
      statusModalTitle.textContent = 'Confirm Game Listing';
      statusModalDesc.textContent = 'Are you sure you want to list this game on the storefront?';
      statusModalDisclaimer.textContent = 'Listing this game will make it live and immediately purchasable by customers. Ensure all details, pricing, media assets, and system requirements are accurate before proceeding.';
      
      // Theme icon/buttons for Listing (Live / Success emerald style)
      statusModalIcon.className = 'flex items-center justify-center w-12 h-12 rounded-full mx-auto mb-4 bg-emerald-500/10 border border-emerald-500/20';
      statusModalSvg.className = 'w-6 h-6 text-emerald-400';
      statusModalSvg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />';
      
      statusModalConfirmBtn.className = 'flex-1 py-2.5 px-4 rounded border border-solid border-emerald-500/30 bg-emerald-500/10 [font-family:\'Inter-Medium\',Helvetica] text-sm text-emerald-400 hover:bg-emerald-500/20 hover:border-emerald-500/50 transition-colors cursor-pointer';
    } else {
      // Unlisting the game
      statusModalTitle.textContent = 'Confirm Game Unlisting';
      statusModalDesc.textContent = 'Are you sure you want to unlist this game?';
      statusModalDisclaimer.textContent = 'Unlisting this game will hide it from customer listings on the storefront. Pre-existing purchases, user downloads, and active orders remain completely unaffected.';
      
      // Theme icon/buttons for Unlisting (Hidden / Warning red style)
      statusModalIcon.className = 'flex items-center justify-center w-12 h-12 rounded-full mx-auto mb-4 bg-red-500/10 border border-red-500/20';
      statusModalSvg.className = 'w-6 h-6 text-red-400';
      statusModalSvg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />';
      
      statusModalConfirmBtn.className = 'flex-1 py-2.5 px-4 rounded border border-solid border-red-500/30 bg-red-500/10 [font-family:\'Inter-Medium\',Helvetica] text-sm text-red-400 hover:bg-red-500/20 hover:border-red-500/50 transition-colors cursor-pointer';
    }
    
    statusConfirmModal.classList.remove('hidden');
    statusConfirmModal.classList.add('flex');
    statusModalConfirmBtn.focus();
  }

  function closeStatusConfirmModal() {
    statusConfirmModal.classList.add('hidden');
    statusConfirmModal.classList.remove('flex');
    pendingStatusChange = null;
  }

  statusToggle.addEventListener('click', function(e) {
    e.preventDefault();
    const isCurrentlyHidden = statusInput.value === 'Hidden';
    const targetState = isCurrentlyHidden ? 'Live' : 'Hidden';
    openStatusConfirmModal(targetState);
  });

  statusModalCancelBtn.addEventListener('click', closeStatusConfirmModal);
  
  // Close on backdrop click
  statusConfirmModal.addEventListener('click', function(e) {
    if (e.target === statusConfirmModal) {
      closeStatusConfirmModal();
    }
  });

  // Close on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !statusConfirmModal.classList.contains('hidden')) {
      closeStatusConfirmModal();
    }
  });

  statusModalConfirmBtn.addEventListener('click', function() {
    if (pendingStatusChange) {
      if (pendingStatusChange === 'Hidden') {
        statusToggle.checked = true;
        statusToggle.classList.remove('translate-x-0');
        statusToggle.classList.add('translate-x-6');
        statusInput.value = 'Hidden';
        
        statusLabel.classList.remove('text-accent');
        statusLabel.classList.add('text-text-muted');
        unlistLabel.classList.remove('text-text-muted');
        unlistLabel.classList.add('text-accent');
      } else {
        statusToggle.checked = false;
        statusToggle.classList.remove('translate-x-6');
        statusToggle.classList.add('translate-x-0');
        statusInput.value = 'Live';
        
        statusLabel.classList.remove('text-text-muted');
