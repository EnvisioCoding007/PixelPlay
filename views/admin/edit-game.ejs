  // Render searchable dropdown options
  function renderDropdownOptions(filterText = '') {
    otherDropdown.innerHTML = '';
    const filtered = otherPlatformsList.filter(platform => 
      platform.toLowerCase().includes(filterText.toLowerCase())
    );
    
    // Render filtered list
    filtered.forEach(platform => {
      const isAlreadySelected = Array.from(document.querySelectorAll('input[name="platforms[]"]'))
        .some(cb => cb.value === platform);
      
      if (isAlreadySelected) return;

      const item = document.createElement('div');
      item.className = 'px-4 py-2 text-sm text-white hover:bg-accent hover:text-background-dark cursor-pointer transition-colors';
      item.textContent = platform;
      item.addEventListener('mousedown', function(e) {
        e.preventDefault();
        addPlatformCheckbox(platform);
      });
      otherDropdown.appendChild(item);
    });

    // Add "+ Add Custom" option if there is text
    if (filterText.trim().length > 0) {
      const isAlreadySelected = Array.from(document.querySelectorAll('input[name="platforms[]"]'))
        .some(cb => cb.value.toLowerCase() === filterText.trim().toLowerCase());
      
      if (!isAlreadySelected) {
        const customItem = document.createElement('div');
        customItem.className = 'px-4 py-2 text-sm text-accent hover:bg-accent hover:text-background-dark cursor-pointer transition-colors border-t border-border-dark font-medium';
        customItem.textContent = `+ Add Custom: "${filterText.trim()}"`;
        customItem.addEventListener('mousedown', function(e) {
          e.preventDefault();
          addPlatformCheckbox(filterText.trim());
        });
        otherDropdown.appendChild(customItem);
      }
    } else if (filtered.length === 0) {
      const noResult = document.createElement('div');
      noResult.className = 'px-4 py-2 text-xs text-text-muted';
      noResult.textContent = 'No matching platforms';
      otherDropdown.appendChild(noResult);
    }

    // Always add 'Add New' option at the very end of the dropdown options
    const addNewItem = document.createElement('div');
    addNewItem.className = 'px-4 py-2 text-sm text-accent hover:bg-accent hover:text-background-dark cursor-pointer transition-colors border-t border-border-dark font-medium flex items-center gap-1';
    addNewItem.innerHTML = `<span class="material-icons-outlined text-sm">add</span> Add New Platform`;
    addNewItem.addEventListener('mousedown', function(e) {
      e.preventDefault();
      const customName = prompt("Enter the name of the new platform:");
      if (customName && customName.trim().length > 0) {
        addPlatformCheckbox(customName.trim());
      }
    });
    otherDropdown.appendChild(addNewItem);
  }

  function addPlatformCheckbox(platform) {
    const otherLabel = document.getElementById('otherPlatformsToggle').closest('label');
    const newLabel = document.createElement('label');
    newLabel.className = 'flex items-center gap-2 cursor-pointer text-sm text-white dynamic-platform-checkbox';
    newLabel.innerHTML = `
      <input type="checkbox" name="platforms[]" value="${platform}" checked class="platform-checkbox rounded bg-background-dark border border-border-dark text-white text-accent focus:ring-accent">
      <span>${platform}</span>
    `;
    otherLabel.parentNode.insertBefore(newLabel, otherLabel);
    
    // Add event listener to remove when unchecked
    newLabel.querySelector('input').addEventListener('change', function() {
      if (!this.checked) {
        newLabel.remove();
        updateHardwareRequirementsUI();
      }
    });

    // Hide dropdown and clear search
    otherDropdown.classList.add('hidden');
    otherSearchInput.value = '';
    
    // Update hardware requirements UI
    updateHardwareRequirementsUI();
  }

