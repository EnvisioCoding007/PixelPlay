        <div class="space-y-4">
          <h3 class="text-sm font-semibold text-accent uppercase tracking-wider">Recommended Info (${platform})</h3>
          <p class="text-xs text-text-muted">Standard configuration matches specifications for this console release.</p>
          <input type="hidden" data-req="recommended.os" class="req-input" value="${recOs}">
          <input type="hidden" data-req="recommended.storage" class="req-input" value="${recStorage}">
          <input type="hidden" data-req="recommended.graphics" class="req-input" value="${recGpu}">
          <input type="hidden" data-req="recommended.additional_notes" class="req-input" value="${recNotes}">
          <input type="hidden" data-req="recommended.architecture" class="req-input" value="${recArch}">
          <input type="hidden" data-req="recommended.processor" class="req-input" value="${recProc}">
          <input type="hidden" data-req="recommended.memory" class="req-input" value="${recMem}">
          <input type="hidden" data-req="recommended.sound_card" class="req-input" value="DirectX Compatible">
        </div>
      </div>
    `;
  }

  function updateHardwareRequirementsUI() {
    // Collect all selected platforms
    const checkedBoxes = Array.from(document.querySelectorAll('.platform-checkbox:checked')).map(cb => cb.value);
    const selected = [...checkedBoxes];

    if (selected.length === 0) {
      noPlatformsMessage.classList.remove('hidden');
      requirementsTabs.classList.add('hidden');
      requirementsContent.classList.add('hidden');
      requirementsTabs.innerHTML = '';
      requirementsContent.innerHTML = '';
      activePlatformTab = '';
      return;
    }

    noPlatformsMessage.classList.add('hidden');
    requirementsTabs.classList.remove('hidden');
    requirementsContent.classList.remove('hidden');

    // Remove platforms that are no longer selected
    const renderedBlocks = Array.from(requirementsContent.querySelectorAll('.platform-req-form'));
    renderedBlocks.forEach(block => {
      const p = block.dataset.platform;
      if (!selected.includes(p)) {
        block.remove();
      }
    });

    // Render blocks for newly selected platforms
    selected.forEach(platform => {
      let block = requirementsContent.querySelector(`.platform-req-form[data-platform="${platform}"]`);
      if (!block) {
        const tempDiv = document.createElement('div');
        if (platform === 'PC') {
          tempDiv.innerHTML = getPCRequirementsHTML(platform);
        } else {
          const defaults = consoleDefaults[platform] || { os: `${platform} System OS`, storage: "50 GB", graphics: "1080p Support" };
          tempDiv.innerHTML = getConsoleRequirementsHTML(platform, defaults);
        }
        requirementsContent.appendChild(tempDiv.firstElementChild);
      }
    });

    // Ensure activePlatformTab is valid
    if (!selected.includes(activePlatformTab)) {
      activePlatformTab = selected[0];
    }

    // Render Tabs
    requirementsTabs.innerHTML = '';
    selected.forEach(platform => {
      const tabBtn = document.createElement('button');
      tabBtn.type = 'button';
      tabBtn.className = `px-4 py-2 text-xs font-semibold rounded-lg border transition-colors cursor-pointer ${
        platform === activePlatformTab 
          ? 'bg-accent text-background-dark border-accent' 
          : 'bg-transparent text-text-muted border-border-dark hover:text-white'
      }`;
      tabBtn.textContent = platform;
      tabBtn.addEventListener('click', function() {
        activePlatformTab = platform;
        showActivePlatformForm();
      });
      requirementsTabs.appendChild(tabBtn);
    });

    showActivePlatformForm();
    updatePlatformStocksUI();
  }

  const platformStocksSection = document.getElementById('platformStocksSection');
  const platformStocksContainer = document.getElementById('platformStocksContainer');

  function updatePlatformStocksUI() {
    const checkedBoxes = Array.from(document.querySelectorAll('.platform-checkbox:checked')).map(cb => cb.value);
    
    if (checkedBoxes.length === 0) {
      platformStocksSection.classList.add('hidden');
      platformStocksContainer.innerHTML = '';
      return;
    }
    
    platformStocksSection.classList.remove('hidden');
    
    // Save current values to restore them
    const currentStockValues = {};
    const currentPriceValues = {};
    platformStocksContainer.querySelectorAll('input').forEach(input => {
      if (input.dataset.field === 'stock') {
        currentStockValues[input.dataset.platform] = input.value;
      } else if (input.dataset.field === 'price') {
        currentPriceValues[input.dataset.platform] = input.value;
      }
    });

    // Check if we have pre-loaded/existing stocks/prices (useful in edit page)
    let existingStockMap = {};
    let existingPriceMap = {};
    const existingScript = document.getElementById('existingPlatformStocks');
    if (existingScript) {
      try {
        const list = JSON.parse(existingScript.textContent);
        list.forEach(item => {
          existingStockMap[item.platform] = item.stock;
          existingPriceMap[item.platform] = item.price;
        });
      } catch(e) {}
    }

    platformStocksContainer.innerHTML = '';
    checkedBoxes.forEach(platform => {
      const slug = platform.replace(/[^a-zA-Z0-9]/g, '_');
      const savedStock = currentStockValues[platform] !== undefined 
        ? currentStockValues[platform] 
        : (existingStockMap[platform] !== undefined ? existingStockMap[platform] : '0');
      const savedPrice = currentPriceValues[platform] !== undefined 
        ? currentPriceValues[platform] 
        : (existingPriceMap[platform] !== undefined ? existingPriceMap[platform] : '0.00');

      const row = document.createElement('div');
      row.className = 'flex items-center justify-between gap-4 py-2 border-b border-border-dark last:border-b-0';
      row.innerHTML = `
        <span class="text-sm font-medium text-white">${platform}</span>
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-1.5">
            <span class="text-xs text-text-muted">Stock:</span>
            <input type="number" min="0" required 
              data-platform="${platform}"
              data-field="stock"
              name="platform_stock_${platform}" 
              id="stock_${slug}" 
              value="${savedStock}" 
              class="w-20 bg-surface-dark border border-border-dark rounded px-2 py-1 text-sm text-white focus:outline-none focus:border-accent text-right" 
              placeholder="0" />
          </div>
          <div class="flex items-center gap-1.5">
            <span class="text-xs text-text-muted">Price: ₹</span>
            <input type="number" min="0" step="0.01" required 
              data-platform="${platform}"
              data-field="price"
              name="platform_price_${platform}" 
              id="price_${slug}" 
              value="${savedPrice}" 
              class="w-24 bg-surface-dark border border-border-dark rounded px-2 py-1 text-sm text-white focus:outline-none focus:border-accent text-right" 
              placeholder="0.00" />
          </div>
        </div>
      `;
      platformStocksContainer.appendChild(row);
    });
  }

  function showActivePlatformForm() {
    // Update tab styles
    const tabButtons = Array.from(requirementsTabs.querySelectorAll('button'));
    tabButtons.forEach(btn => {
      if (btn.textContent === activePlatformTab) {
        btn.className = 'px-4 py-2 text-xs font-semibold rounded-lg border bg-accent text-background-dark border-accent cursor-pointer';
      } else {
        btn.className = 'px-4 py-2 text-xs font-semibold rounded-lg border bg-transparent text-text-muted border-border-dark hover:text-white cursor-pointer';
      }
    });

    // Show only the active form block
    const blocks = Array.from(requirementsContent.querySelectorAll('.platform-req-form'));
    blocks.forEach(block => {
      if (block.dataset.platform === activePlatformTab) {
        block.classList.remove('hidden');
      } else {
        block.classList.add('hidden');
      }
    });
  }

  // Initialize requirements UI on load
  updateHardwareRequirementsUI();

  // Form submit handling via AJAX
  const editForm = document.getElementById('gameEditForm');
  editForm.addEventListener('submit', async function(e) {
    e.preventDefault();

    const formData = new FormData();

    // Append core inputs
    formData.append('title', editForm.title.value);
    formData.append('publisher', editForm.publisher.value);
    formData.append('release_year', editForm.release_year.value);
    formData.append('category', editForm.category.value);
    formData.append('edition_type', editionInput.value);
    formData.append('description', editForm.description.value);
    formData.append('status', statusInput.value);

    let totalStock = 0;
    let firstPlatformPrice = 0;
    let hasFirstPlat = false;
    // Append checked platforms
    const selectedPlatforms = Array.from(editForm.querySelectorAll('input[name="platforms[]"]:checked')).map(cb => cb.value);
    selectedPlatforms.forEach(val => {
      const slug = val.replace(/[^a-zA-Z0-9]/g, '_');
      const stockInput = document.getElementById(`stock_${slug}`);
      const priceInput = document.getElementById(`price_${slug}`);
      const stockVal = parseInt(stockInput ? stockInput.value : '0') || 0;
      const priceVal = parseFloat(priceInput ? priceInput.value : '0.00') || 0;
      totalStock += stockVal;
      if (!hasFirstPlat) {
        firstPlatformPrice = priceVal;
        hasFirstPlat = true;
      }
      formData.append(`platform_stock_${val}`, stockVal);
      formData.append(`platform_price_${val}`, priceVal);
      formData.append('platforms[]', val);
    });
    formData.append('stock', totalStock);
    formData.append('price', firstPlatformPrice);

    // Append existing gallery URLs remaining in DOM
    editForm.querySelectorAll('input[name="existing_gallery[]"]').forEach(input => {
      formData.append('existing_gallery[]', input.value);
    });

    // Append new cover image if selected
    const coverInput = document.getElementById('coverInput');
    if (coverInput.files.length > 0) {
      formData.append('cover_image', coverInput.files[0]);
    }

    // Append new gallery images if selected
    const galleryInput = document.getElementById('galleryInput');
    Array.from(galleryInput.files).forEach(file => {
      formData.append('gallery', file);
    });

    // Append dynamic system requirements from the active tab form
    const activeReqBlock = document.querySelector('.platform-req-form:not(.hidden)');
    if (activeReqBlock) {
      const getVal = (dataReq) => {
        const input = activeReqBlock.querySelector(`[data-req="${dataReq}"]`);
        return input ? input.value : '';
      };
      
      formData.append('system_requirements.minimum.architecture', getVal('minimum.architecture'));
      formData.append('system_requirements.minimum.os', getVal('minimum.os'));
      formData.append('system_requirements.minimum.processor', getVal('minimum.processor'));
      formData.append('system_requirements.minimum.memory', getVal('minimum.memory'));
      formData.append('system_requirements.minimum.graphics', getVal('minimum.graphics'));
      formData.append('system_requirements.minimum.storage', getVal('minimum.storage'));
      formData.append('system_requirements.minimum.sound_card', getVal('minimum.sound_card'));
      formData.append('system_requirements.minimum.additional_notes', getVal('minimum.additional_notes'));
      
      formData.append('system_requirements.recommended.architecture', getVal('recommended.architecture'));
      formData.append('system_requirements.recommended.os', getVal('recommended.os'));
      formData.append('system_requirements.recommended.processor', getVal('recommended.processor'));
      formData.append('system_requirements.recommended.memory', getVal('recommended.memory'));
      formData.append('system_requirements.recommended.graphics', getVal('recommended.graphics'));
      formData.append('system_requirements.recommended.storage', getVal('recommended.storage'));
      formData.append('system_requirements.recommended.sound_card', getVal('recommended.sound_card'));
      formData.append('system_requirements.recommended.additional_notes', getVal('recommended.additional_notes'));
    } else {
      // Fallbacks matching database schema requirements
      formData.append('system_requirements.minimum.architecture', '64-bit');
      formData.append('system_requirements.minimum.os', 'N/A');
      formData.append('system_requirements.minimum.processor', 'N/A');
      formData.append('system_requirements.minimum.memory', 'N/A');
      formData.append('system_requirements.minimum.graphics', 'N/A');
      formData.append('system_requirements.minimum.storage', 'N/A');
      formData.append('system_requirements.minimum.sound_card', '');
      formData.append('system_requirements.minimum.additional_notes', '');
      
      formData.append('system_requirements.recommended.architecture', '64-bit');
      formData.append('system_requirements.recommended.os', 'N/A');
      formData.append('system_requirements.recommended.processor', 'N/A');
      formData.append('system_requirements.recommended.memory', 'N/A');
      formData.append('system_requirements.recommended.graphics', 'N/A');
      formData.append('system_requirements.recommended.storage', 'N/A');
      formData.append('system_requirements.recommended.sound_card', '');
      formData.append('system_requirements.recommended.additional_notes', '');
    }

    try {
      const submitBtn = document.getElementById('submitBtn');
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="material-icons-outlined animate-spin text-sm">sync</span> Saving...';

      const response = await fetch('/admin/products/edit/<%= product._id %>', {
        method: 'POST',
        body: formData
      });

      let result = null;
      const contentType = response.headers.get('content-type');
      if (contentType && contentType.includes('application/json')) {
        result = await response.json();
      }

      if (response.ok && result && result.success) {
        alert('Game modifications saved successfully!');
        window.location.href = '/admin/products';
      } else {
        const errMsg = result && result.message 
          ? result.message 
          : `Server error ${response.status}`;
        alert('Error saving modifications: ' + errMsg);
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<span class="material-icons-outlined text-sm">save</span> Save Modifications';
      }
    } catch (err) {
      console.error('Submission error:', err);
      alert('Failed to save modifications: ' + err.message);
      const submitBtn = document.getElementById('submitBtn');
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<span class="material-icons-outlined text-sm">save</span> Save Modifications';
    }
  });
</script>

<%- include('../partials/admin/footer') %>