<%- include('../partials/admin/header') %>
<body class="bg-pixel-bg text-gray-300 min-h-screen flex text-sm">
<%- include('../partials/admin/sidebar', { activeTab: 'publishers' }) %>
<main class="content-bg flex-1 flex flex-col overflow-hidden relative">
  <!-- Top Header Bar -->
  <header class="flex items-center justify-between px-8 py-6 border-b border-border-dark bg-[#121418]/50">
    <div>
      <h1 class="text-2xl font-semibold text-gray-100">Publisher Directory</h1>
      <p class="text-gray-400 text-sm">Manage all game publishers and their linked physical title catalogs.</p>
    </div>
    <div class="flex items-center gap-4">
      <!-- Search Bar -->
      <form action="/admin/publishers" method="get" class="relative">
        <i class="fa-solid fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-500"></i>
        <input id="pubSearchInput" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>" class="bg-content-bg border border-input-dark-border text-gray-200 focus:border-pixel-blue focus:outline-none focus:ring-1 focus:ring-pixel-blue text-sm rounded-lg pl-9 pr-10 py-2.5 w-64 placeholder-gray-500" placeholder="Search Publishers..." type="text"/>
        <button type="button" id="clearPubSearchBtn" class="<%= (typeof search !== 'undefined' && search) ? '' : 'hidden' %> absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 hover:text-white">
          <i class="fa-solid fa-xmark text-sm"></i>
        </button>
      </form>
      <!-- Add Button -->
      <a href="/admin/publishers/add" class="bg-pixel-blue hover:bg-pixel-blue-hover text-white font-medium py-2.5 px-4 rounded-lg flex items-center gap-2 transition-colors">
        <i class="fa-solid fa-plus text-xs"></i> Add New Publisher
      </a>
    </div>
  </header>

  <!-- Scrollable Content Area -->
  <div class="flex-1 overflow-y-auto p-8">
    <!-- BEGIN: Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <!-- Stat Card 1 -->
      <div class="bg-card-bg rounded-xl p-6 border border-border-dark">
        <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">Total Publishers</h3>
        <div class="text-4xl font-bold text-pixel-yellow mb-2">
          <%= typeof totalCount !== 'undefined' ? totalCount : (typeof publishers !== 'undefined' ? publishers.length : 0) %>
        </div>
        <p class="text-sm text-gray-400">Active in catalog</p>
      </div>
      <!-- Stat Card 2 -->
      <div class="bg-card-bg rounded-xl p-6 border border-border-dark">
        <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">Total Games Linked</h3>
        <div class="text-4xl font-bold text-pixel-blue mb-2">
          <% 
            let totalGamesLinked = 0;
            if (typeof publishers !== 'undefined' && publishers) {
              publishers.forEach(p => {
                totalGamesLinked += (p.gameCount || p.gamesCount || p.linkedGamesCount || 0);
              });
            }
          %>
          <%= totalGamesLinked %>
        </div>
        <p class="text-sm text-gray-400">Physical disk titles</p>
      </div>
      <!-- Stat Card 3 -->
      <div class="bg-card-bg rounded-xl p-6 border border-border-dark">
        <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">New This Month</h3>
        <div class="text-4xl font-bold text-white mb-2">3</div>
        <p class="text-sm text-gray-400">Publishers onboarded</p>
      </div>
    </div>
    <!-- END: Stats Cards -->

    <!-- BEGIN: Data Table Section -->
    <div class="bg-card-bg rounded-xl border border-border-dark flex flex-col">
      <!-- Table Header Area -->
      <div class="p-6 border-b border-border-dark flex justify-between items-center bg-[#121418]/30">
        <h2 class="text-lg font-bold text-white">All Publishers</h2>
        <span class="bg-[#121418] text-pixel-blue text-xs font-semibold px-3 py-1 rounded-full border border-border-dark">
          <%= typeof totalCount !== 'undefined' ? totalCount : (typeof publishers !== 'undefined' ? publishers.length : 0) %> Records
        </span>
      </div>
      <!-- Table -->
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-border-dark text-xs font-semibold text-pixel-blue uppercase tracking-wider bg-sidebar-bg">
              <th class="px-6 py-4">Publisher</th>
              <th class="px-6 py-4">Official Website</th>
              <th class="px-6 py-4">Games Linked</th>
              <th class="px-6 py-4 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border-dark bg-sidebar-bg/30 text-gray-300">
            <% if (typeof publishers !== 'undefined' && publishers && publishers.length > 0) { %>
              <% publishers.forEach(publisher => { %>
                <tr class="hover:bg-card-bg transition-colors group">
                  <!-- Publisher -->
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      <% if (publisher.logo || publisher.logoUrl) { %>
                        <img alt="<%= publisher.name %>" class="w-10 h-10 rounded bg-content-bg object-cover" src="<%= publisher.logo || publisher.logoUrl %>"/>
                      <% } else { %>
                        <div class="w-10 h-10 rounded bg-card-bg flex items-center justify-center border border-border-dark text-pixel-blue font-bold text-sm">
                          <%= publisher.name ? publisher.name.substring(0, 2).toUpperCase() : 'PB' %>
                        </div>
                      <% } %>
                      <div>
                        <div class="font-semibold text-white"><%= publisher.name %></div>
                        <% if (publisher.description || publisher.brief_description) { %>
                          <div class="text-xs text-gray-400 max-w-xs truncate"><%= publisher.description || publisher.brief_description %></div>
                        <% } %>
                      </div>
                    </div>
                  </td>
                  <!-- Official Website -->
                  <td class="px-6 py-4">
                    <% if (publisher.website || publisher.official_website || publisher.officialWebsite) { %>
                      <% const siteUrl = publisher.website || publisher.official_website || publisher.officialWebsite; %>
                      <a class="text-pixel-blue hover:underline flex items-center gap-1.5" href="<%= siteUrl %>" target="_blank" rel="noopener noreferrer">
                        <i class="fa-solid fa-arrow-up-right-from-square text-xs"></i>
                        <%= siteUrl.replace(/https?:\/\/(www\.)?/, '') %>
                      </a>
                    <% } else { %>
                      <span class="text-gray-500">N/A</span>
                    <% } %>
                  </td>
                  <!-- Games Linked -->
                  <td class="px-6 py-4">
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium text-pixel-yellow bg-pixel-yellow/10 border border-pixel-yellow/20">
                      <i class="fa-solid fa-compact-disc"></i>
                      <%= publisher.gameCount || publisher.gamesCount || publisher.linkedGamesCount || 0 %> Games
                    </span>
                  </td>
                  <!-- Actions -->
                  <td class="px-6 py-4 text-right">
                    <div class="flex items-center justify-end gap-2">
                      <a href="/admin/publishers/edit/<%= publisher._id %>" class="px-3 py-1.5 rounded bg-card-bg border border-border-dark text-pixel-blue hover:bg-content-bg transition-colors text-xs font-medium flex items-center gap-1.5">
                        <i class="fa-solid fa-pen text-[10px]"></i> Edit
                      </a>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="4" class="text-center py-8 text-gray-500">
                  No publishers found in the database.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <div class="p-6 border-t border-border-dark flex items-center justify-between bg-sidebar-bg/50">
          <div class="text-gray-400 text-sm">
            Showing <span class="font-medium text-white"><%= (currentPage - 1) * limit + 1 %>-<%= Math.min(currentPage * limit, totalCount) %></span> of <span class="font-medium text-white"><%= totalCount %></span> publishers
          </div>
          <div class="flex items-center gap-1">
            <% if (currentPage > 1) { %>
              <a href="/admin/publishers?page=<%= currentPage - 1 %>&search=<%= encodeURIComponent(typeof search !== 'undefined' ? search : '') %>" class="px-3 py-1.5 rounded border border-border-dark bg-card-bg text-gray-400 hover:text-white transition-colors text-sm font-medium flex items-center gap-1">
                <i class="fa-solid fa-chevron-left text-xs"></i> Previous
              </a>
            <% } %>
            <% for (let p = 1; p <= totalPages; p++) { %>
              <% if (p === currentPage) { %>
                <span class="w-8 h-8 rounded bg-pixel-blue text-background-dark font-medium flex items-center justify-center text-sm"><%= p %></span>
              <% } else { %>
                <a href="/admin/publishers?page=<%= p %>&search=<%= encodeURIComponent(typeof search !== 'undefined' ? search : '') %>" class="w-8 h-8 rounded bg-transparent text-gray-400 hover:bg-card-bg hover:text-white transition-colors font-medium flex items-center justify-center text-sm"><%= p %></a>
              <% } %>
            <% } %>
            <% if (currentPage < totalPages) { %>
              <a href="/admin/publishers?page=<%= currentPage + 1 %>&search=<%= encodeURIComponent(typeof search !== 'undefined' ? search : '') %>" class="px-3 py-1.5 rounded border border-border-dark bg-card-bg text-pixel-blue hover:bg-content-bg transition-colors text-sm font-medium flex items-center gap-1 ml-2">
                Next <i class="fa-solid fa-chevron-right text-xs"></i>
              </a>
            <% } %>
          </div>
        </div>
      <% } else { %>
        <div class="p-6 border-t border-border-dark flex items-center justify-between bg-sidebar-bg/50">
          <div class="text-gray-400 text-sm font-medium">
            Showing <span class="text-white"><%= typeof publishers !== 'undefined' ? publishers.length : 0 %></span> publishers
          </div>
        </div>
      <% } %>
    </div>
    <!-- END: Data Table Section -->
  </div>
</main>

<script>
  (function () {
    const pubSearchInput = document.getElementById('pubSearchInput');
    const clearPubSearchBtn = document.getElementById('clearPubSearchBtn');

    if (pubSearchInput && clearPubSearchBtn) {
      pubSearchInput.addEventListener('input', function() {
        if (this.value.trim().length > 0) {
          clearPubSearchBtn.classList.remove('hidden');
        } else {
          clearPubSearchBtn.classList.add('hidden');
        }
      });
      clearPubSearchBtn.addEventListener('click', function() {
        pubSearchInput.value = '';
        pubSearchInput.form.submit();
      });
    }
  })();
</script>

<%- include('../partials/admin/footer') %>