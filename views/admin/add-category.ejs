<%- include('../partials/admin/header') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css">
<body class="bg-pixel-bg text-gray-300 min-h-screen flex text-sm">
<%- include('../partials/admin/sidebar', { activeTab: 'categories' }) %>
<main class="content-bg flex-1 flex flex-col overflow-hidden relative">
  <!-- Header -->
  <header class="flex items-center justify-between px-8 py-6 border-b border-border-dark">
    <h1 class="text-2xl font-bold text-white">Category Management</h1>
  </header>

  <!-- Content Area -->
  <div class="flex-1 overflow-y-auto p-8">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Create Category Form Column -->
      <div class="lg:col-span-4 bg-card-bg rounded-xl border border-border-dark p-6 shadow-2xl h-fit">
        <div class="mb-6">
          <h2 class="text-lg font-semibold text-white">Create Category</h2>
          <p class="text-xs text-gray-500 mt-1">Add a new taxonomy to your library.</p>
        </div>
        <form id="createCategoryForm" action="/admin/categories" method="POST" enctype="multipart/form-data" class="space-y-5">
          <div>
            <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">Category Name</label>
            <input name="name" type="text" class="w-full bg-content-bg border border-input-dark-border rounded-lg px-3 py-2.5 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-pixel-blue focus:ring-1 focus:ring-pixel-blue" placeholder="e.g. RPG, Shooter" required />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">Category Description</label>
            <textarea name="description" class="w-full bg-content-bg border border-input-dark-border rounded-lg px-3 py-2.5 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-pixel-blue focus:ring-1 focus:ring-pixel-blue resize-none" placeholder="Brief description of this category..." rows="4"></textarea>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">Default Offer / Discount</label>
            <input name="defaultOffer" type="text" class="w-full bg-content-bg border border-input-dark-border rounded-lg px-3 py-2.5 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-pixel-blue focus:ring-1 focus:ring-pixel-blue" placeholder="e.g. 10 or 10%" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">Category Icon</label>
            <div id="dropzone" class="border-2 border-dashed border-input-dark-border hover:border-pixel-blue/50 rounded-lg p-6 flex flex-col items-center justify-center text-center bg-content-bg/50 cursor-pointer transition-colors relative">
              <input type="file" id="categoryIcon" class="hidden" accept="image/*" />
              
              <!-- Upload Instructions (hidden when preview is shown) -->
              <div id="uploadInstructions" class="flex flex-col items-center justify-center">
                <div class="w-12 h-12 rounded-full bg-pixel-blue/10 flex items-center justify-center mb-3 text-pixel-blue">
                  <i class="fa-solid fa-cloud-arrow-up text-lg"></i>
                </div>
                <h3 class="text-sm font-semibold text-white mb-1">Drop Category Icon Here</h3>
                <p class="text-xs text-gray-500 mb-2">Drag &amp; drop your image, or <button id="browseBtn" class="text-pixel-blue hover:underline font-medium" type="button">browse files</button></p>
                <p class="text-[11px] text-gray-500">Supports PNG, JPG · Max file size: 2MB ·<br/>Recommended: 300x300px</p>
              </div>

              <!-- Preview container (shown when cropped blob exists) -->
              <div id="iconPreviewContainer" class="hidden flex flex-col items-center justify-center w-full">
                <img id="categoryIconPreview" class="w-20 h-20 rounded-lg object-cover border border-border-dark mb-3 mx-auto" />
                <div class="flex gap-2 justify-center">
                  <button type="button" id="removeIconBtn" class="px-3 py-1.5 text-xs bg-[#f92a40]/10 hover:bg-[#f92a40]/20 text-pixel-red rounded-lg transition-colors flex items-center gap-1.5">
                    <i class="fa-solid fa-trash text-[10px]"></i> Remove Icon
                  </button>
                </div>
              </div>
              
              <p id="fileNameDisplay" class="text-xs text-pixel-yellow font-medium mt-3 hidden"></p>
            </div>
          </div>
          <button class="w-full bg-pixel-blue hover:bg-pixel-blue-hover text-background-dark font-semibold py-2.5 px-4 rounded-lg flex items-center justify-center gap-2 transition-colors" type="submit">
            Add Category
          </button>
        </form>
      </div>
      <!-- Category List Column -->
      <div class="lg:col-span-8 space-y-4">
        <!-- Search Bar -->
        <form action="/admin/categories" method="GET" class="flex items-center gap-3 bg-card-bg p-4 rounded-xl border border-border-dark w-full shadow-2xl">
          <div class="relative flex-1">
            <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-500"></i>
            <input type="text" id="categorySearchInput" name="search" placeholder="Search categories by name or description..." class="w-full bg-content-bg border border-input-dark-border rounded-lg pl-10 pr-10 py-2.5 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-pixel-blue focus:ring-1 focus:ring-pixel-blue transition-colors" value="<%= typeof search !== 'undefined' ? search : '' %>">
            <button type="button" id="clearSearchBtn" class="<%= (typeof search !== 'undefined' && search) ? '' : 'hidden' %> absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 hover:text-white bg-transparent border-0 cursor-pointer">
              <i class="fa-solid fa-xmark text-sm"></i>
            </button>
          </div>
          <button type="submit" class="bg-pixel-blue hover:bg-pixel-blue-hover text-background-dark font-semibold px-5 py-2.5 rounded-lg hover:opacity-90 transition-opacity text-sm whitespace-nowrap">
            Search
          </button>
        </form>

        <div class="grid grid-cols-12 gap-4 px-4 py-3 text-xs font-semibold tracking-wider text-gray-500 uppercase">
          <div class="col-span-4">Category Name</div>
          <div class="col-span-2 text-center">Total Games</div>
          <div class="col-span-3">Default Offer</div>
          <div class="col-span-2 text-center">Visibility</div>
          <div class="col-span-1 text-right">Actions</div>
        </div>
        <div class="space-y-3">
          <% if (categories && categories.length > 0) { %>
            <% categories.forEach(cat => { %>
              <div class="bg-card-bg border border-border-dark rounded-xl p-4 grid grid-cols-12 gap-4 items-center shadow-md">
                <div class="col-span-4 font-semibold text-gray-200 text-sm">
                  <%= cat.name %>
                </div>
                <div class="col-span-2 flex justify-center">
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-[#1a2432] text-pixel-blue border border-pixel-blue/20">
                    <%= cat.gameCount || 0 %> Titles
                  </span>
                </div>
                <div class="col-span-3 text-sm text-gray-400">
                  <%= (cat.defaultOffer && cat.defaultOffer > 0) ? cat.defaultOffer : 'None' %>
                </div>
                <div class="col-span-2 flex justify-center">
                  <button aria-checked="<%= cat.status !== 'Hidden' %>" 
                          data-id="<%= cat._id %>"
                          data-games-count="<%= cat.gameCount || 0 %>"
                          class="category-status-toggle relative inline-flex h-5 w-9 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none <%= cat.status !== 'Hidden' ? 'bg-pixel-blue' : 'bg-slate-700' %>" 
                          role="switch" type="button">
                    <span aria-hidden="true" 
                          class="pointer-events-none inline-block h-4 w-4 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out <%= cat.status !== 'Hidden' ? 'translate-x-4' : 'translate-x-0' %>"></span>
                  </button>
                </div>
                <div class="col-span-1 flex justify-end gap-2 text-gray-500">
                  <button data-id="<%= cat._id %>" class="category-edit-btn hover:text-white transition-colors">
                    <i class="fa-solid fa-pen text-sm"></i>
                  </button>
                  <button data-id="<%= cat._id %>" class="category-delete-btn hover:text-pixel-red transition-colors">
                    <i class="fa-solid fa-trash text-sm"></i>
                  </button>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="bg-card-bg border border-border-dark rounded-xl p-8 text-center text-gray-500 text-sm">
              No active categories found in the database.
            </div>
          <% } %>
        </div>

        <!-- Pagination -->
        <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
          <div class="p-4 border border-border-dark rounded-xl bg-card-bg flex items-center justify-between shadow-2xl">
            <div class="text-gray-400 text-sm">
              Showing <span class="font-medium text-white"><%= (currentPage - 1) * limit + 1 %>-<%= Math.min(currentPage * limit, totalCount) %></span> of <span class="font-medium text-white"><%= totalCount %></span> categories
            </div>
            <div class="flex items-center gap-1">
              <% if (currentPage > 1) { %>
                <a href="/admin/categories?page=<%= currentPage - 1 %>&search=<%= encodeURIComponent(typeof search !== 'undefined' ? search : '') %>" class="px-3 py-1.5 rounded border border-border-dark bg-card-bg text-gray-400 hover:text-white transition-colors text-sm font-medium flex items-center gap-1">
                  <i class="fa-solid fa-chevron-left text-xs"></i> Previous
                </a>
              <% } %>
              <% for (let p = 1; p <= totalPages; p++) { %>
                <% if (p === currentPage) { %>
                  <span class="w-8 h-8 rounded bg-pixel-blue text-background-dark font-medium flex items-center justify-center text-sm"><%= p %></span>
                <% } else { %>
                  <a href="/admin/categories?page=<%= p %>&search=<%= encodeURIComponent(typeof search !== 'undefined' ? search : '') %>" class="w-8 h-8 rounded bg-transparent text-gray-400 hover:bg-card-bg hover:text-white transition-colors font-medium flex items-center justify-center text-sm"><%= p %></a>
                <% } %>
              <% } %>
              <% if (currentPage < totalPages) { %>
                <a href="/admin/categories?page=<%= currentPage + 1 %>&search=<%= encodeURIComponent(typeof search !== 'undefined' ? search : '') %>" class="px-3 py-1.5 rounded border border-border-dark bg-card-bg text-pixel-blue hover:bg-content-bg transition-colors text-sm font-medium flex items-center gap-1 ml-2">
                  Next <i class="fa-solid fa-chevron-right text-xs"></i>
                </a>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<!-- Cropper.js Workspace Modal overlay -->
<div id="cropperWorkspace" class="hidden fixed inset-0 z-55 flex items-center justify-center bg-black/80 backdrop-blur-sm p-4">
  <div class="bg-card-bg border border-border-dark rounded-xl max-w-2xl w-full p-6 flex flex-col gap-4 shadow-2xl">
    <div class="flex items-center justify-between border-b border-border-dark pb-3">
      <h3 class="text-lg font-semibold text-white" id="cropperTitle">Crop Category Icon</h3>
      <button type="button" id="closeCropperBtn" class="text-gray-400 hover:text-white transition-colors">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <div class="relative w-full max-h-[50vh] bg-content-bg flex items-center justify-center overflow-hidden rounded-lg border border-border-dark">
      <img id="cropperImage" class="max-w-full max-h-[45vh] object-contain" />
    </div>
    <div class="flex gap-3 justify-end border-t border-border-dark pt-3">
      <button type="button" id="cancelCropBtn" class="px-5 py-2 text-sm text-gray-300 hover:text-white bg-content-bg border border-border-dark rounded-lg transition-colors">
        Cancel
      </button>
      <button type="button" id="saveCropBtn" class="px-5 py-2 text-sm text-background-dark bg-pixel-blue hover:bg-pixel-blue-hover font-medium rounded-lg transition-colors">
        Apply Crop
      </button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
<script>
  let cropper = null;
  let croppedIconBlob = null;

  const dropzone = document.getElementById('dropzone');
  const fileInput = document.getElementById('categoryIcon');
  const browseBtn = document.getElementById('browseBtn');
  const fileNameDisplay = document.getElementById('fileNameDisplay');
  const previewImg = document.getElementById('categoryIconPreview');
  const previewContainer = document.getElementById('iconPreviewContainer');
  const uploadInstructions = document.getElementById('uploadInstructions');
  const removeIconBtn = document.getElementById('removeIconBtn');

  const cropperWorkspace = document.getElementById('cropperWorkspace');
  const cropperImage = document.getElementById('cropperImage');
  const closeCropperBtn = document.getElementById('closeCropperBtn');
  const cancelCropBtn = document.getElementById('cancelCropBtn');
  const saveCropBtn = document.getElementById('saveCropBtn');

  function startCropper(imageSrc) {
    cropperImage.src = imageSrc;
    cropperWorkspace.classList.remove('hidden');
    cropperWorkspace.classList.add('flex');
    
    if (cropper) {
      cropper.destroy();
    }
    
    cropper = new Cropper(cropperImage, {
      aspectRatio: 1, // 1:1 ratio
      viewMode: 1,
      dragMode: 'move',
      autoCropArea: 0.9,
      responsive: true,
      restore: false,
      guides: true,
      center: true,
      highlight: false,
      cropBoxMovable: true,
      cropBoxResizable: true,
      toggleDragModeOnDblclick: false
    });
  }

  function closeCropper() {
    cropperWorkspace.classList.add('hidden');
    cropperWorkspace.classList.remove('flex');
    if (cropper) {
      cropper.destroy();
      cropper = null;
    }
  }

  cancelCropBtn.addEventListener('click', () => {
    closeCropper();
    fileInput.value = '';
  });

  closeCropperBtn.addEventListener('click', () => {
    closeCropper();
    fileInput.value = '';
  });

  saveCropBtn.addEventListener('click', () => {
    if (!cropper) return;
    const canvas = cropper.getCroppedCanvas({
      width: 300,
      height: 300
    });
    canvas.toBlob((blob) => {
      croppedIconBlob = blob;
      if (previewImg && previewContainer && uploadInstructions) {
        previewImg.src = URL.createObjectURL(blob);
        previewContainer.classList.remove('hidden');
        uploadInstructions.classList.add('hidden');
      }
      fileNameDisplay.textContent = 'Selected: cropped_icon.png';
      fileNameDisplay.classList.remove('hidden');
      closeCropper();
    }, 'image/png');
  });

  if (dropzone && fileInput) {
    dropzone.addEventListener('click', (e) => {
      if (e.target !== browseBtn && !e.target.closest('#removeIconBtn')) {
        fileInput.click();
      }
    });

    fileInput.addEventListener('click', (e) => {
      e.stopPropagation();
    });

    if (browseBtn) {
      browseBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        fileInput.click();
      });
    }

    function handleIconFile(file) {
      if (file && file.type.startsWith('image/')) {
        const reader = new FileReader();
        reader.onload = (e) => {
          startCropper(e.target.result);
        };
        reader.readAsDataURL(file);
      }
    }

    fileInput.addEventListener('change', () => {
      if (fileInput.files && fileInput.files.length > 0) {
        handleIconFile(fileInput.files[0]);
      }
    });

    // Drag and drop handlers
    dropzone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropzone.classList.add('border-pixel-blue');
    });

    dropzone.addEventListener('dragleave', () => {
      dropzone.classList.remove('border-pixel-blue');
    });

    dropzone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.classList.remove('border-pixel-blue');
      if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
        const file = e.dataTransfer.files[0];
        fileInput.files = e.dataTransfer.files;
        handleIconFile(file);
      }
    });

    if (removeIconBtn) {
      removeIconBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        croppedIconBlob = null;
        fileInput.value = '';
        if (previewContainer && uploadInstructions) {
          previewContainer.classList.add('hidden');
          uploadInstructions.classList.remove('hidden');
        }
        fileNameDisplay.textContent = '';
        fileNameDisplay.classList.add('hidden');
      });
    }
  }

  // Intercept category creation form submit
  const createCategoryForm = document.getElementById('createCategoryForm');
  if (createCategoryForm) {
    createCategoryForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      if (!croppedIconBlob) {
        Swal.fire({
          title: 'Validation Error',
          text: 'Please select and crop a Category Icon.',
          icon: 'error',
          confirmButtonColor: '#2cb5e8'
        });
        return;
      }
      
      const formData = new FormData();
      formData.append('name', this.name.value);
      formData.append('description', this.description.value);
      formData.append('defaultOffer', this.defaultOffer.value);
      formData.append('icon', croppedIconBlob, 'icon.png');
      
      try {
        const submitBtn = this.querySelector('button[type="submit"]');
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<i class="fa-solid fa-spinner animate-spin"></i> Adding...';
        }
        
        const response = await fetch('/admin/categories', {
          method: 'POST',
          body: formData
        });
        
        window.location.href = response.url || '/admin/categories';
      } catch (err) {
        console.error('Category creation error:', err);
        Swal.fire({
          title: 'Error',
          text: 'Failed to create category: ' + err.message,
          icon: 'error',
          confirmButtonColor: '#2cb5e8'
        });
        const submitBtn = this.querySelector('button[type="submit"]');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = 'Add Category';
        }
      }
    });
  }

  // Handle Category Status Toggle
  document.querySelectorAll('.category-status-toggle').forEach(button => {
    button.addEventListener('click', async function() {
      const catId = this.getAttribute('data-id');
      const isCurrentlyActive = this.getAttribute('aria-checked') === 'true';
      const gamesCount = parseInt(this.getAttribute('data-games-count') || '0', 10);
      
      if (isCurrentlyActive) {
        let warningText = "Disclaimer: Unlisting this category will hide all associated games from storefront filter options. Are you sure you want to proceed?";
        if (gamesCount > 0) {
          warningText = `Warning: This category currently has ${gamesCount} linked game(s). Unlisting it will automatically unlist all linked games on the storefront. Are you sure you want to proceed?`;
        }
        const confirmUnlist = await Swal.fire({
          title: 'Unlist Category?',
          text: warningText,
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#f92a40',
          cancelButtonColor: '#1f232b',
          confirmButtonText: 'Yes, unlist it!',
          cancelButtonText: 'Cancel'
        });
        if (!confirmUnlist.isConfirmed) return;
      } else {
        const confirmList = await Swal.fire({
          title: 'List Category?',
          text: "Disclaimer: Listing this category will make it visible to customers on the storefront. Are you sure you want to proceed?",
          icon: 'question',
          showCancelButton: true,
          confirmButtonColor: '#2cb5e8',
          cancelButtonColor: '#1f232b',
          confirmButtonText: 'Yes, list it!',
          cancelButtonText: 'Cancel'
        });
        if (!confirmList.isConfirmed) return;
      }
      
      try {
        const response = await fetch(`/admin/categories/toggle-status/${catId}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          }
        });
        
        const result = await response.json();
        if (response.ok && result.success) {
          window.location.reload();
        } else {
          Swal.fire({
            title: 'Error',
            text: result.message || 'Failed to toggle category status.',
            icon: 'error',
            confirmButtonColor: '#2cb5e8'
          });
        }
      } catch (err) {
        console.error('Error toggling status:', err);
        Swal.fire({
          title: 'Error',
          text: 'An error occurred. Please try again.',
          icon: 'error',
          confirmButtonColor: '#2cb5e8'
        });
      }
    });
  });

  // Handle Category Edit button click
  document.querySelectorAll('.category-edit-btn').forEach(button => {
    button.addEventListener('click', function() {
      const catId = this.getAttribute('data-id');
      window.location.href = `/admin/categories/edit/${catId}`;
    });
  });

  // Handle Category Delete button click
  document.querySelectorAll('.category-delete-btn').forEach(button => {
    button.addEventListener('click', async function() {
      const catId = this.getAttribute('data-id');
      const confirmDelete = await Swal.fire({
        title: 'Delete Category?',
        text: "Are you sure you want to delete this category?",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#f92a40',
        cancelButtonColor: '#1f232b',
        confirmButtonText: 'Yes, delete it!',
        cancelButtonText: 'Cancel'
      });
      if (!confirmDelete.isConfirmed) return;

      try {
        const response = await fetch(`/admin/categories/delete/${catId}`, {
          method: 'POST'
        });
        const result = await response.json();
        if (response.ok && result.success) {
          window.location.reload();
        } else {
          Swal.fire({
            title: 'Error',
            text: result.message || 'Failed to delete category.',
            icon: 'error',
            confirmButtonColor: '#2cb5e8'
          });
        }
      } catch (err) {
        console.error('Error deleting category:', err);
        Swal.fire({
          title: 'Error',
          text: 'An error occurred. Please try again.',
          icon: 'error',
          confirmButtonColor: '#2cb5e8'
        });
      }
    });
  });

  // Handle Category Search input & clear button
  const categorySearchInput = document.getElementById('categorySearchInput');
  const clearSearchBtn = document.getElementById('clearSearchBtn');
  if (categorySearchInput && clearSearchBtn) {
    categorySearchInput.addEventListener('input', function() {
      if (this.value.trim().length > 0) {
        clearSearchBtn.classList.remove('hidden');
      } else {
        clearSearchBtn.classList.add('hidden');
      }
    });

    clearSearchBtn.addEventListener('click', function() {
      categorySearchInput.value = '';
      clearSearchBtn.classList.add('hidden');
      categorySearchInput.form.submit();
    });
  }
</script>

  <% if (typeof error !== 'undefined' && error) { %>
    <script>
      Swal.fire({
        title: 'Error',
        text: '<%= error %>',
        icon: 'error',
        confirmButtonColor: '#2cb5e8'
      });
    </script>
  <% } %>

  <% if (typeof success !== 'undefined' && success) { %>
    <script>
      Swal.fire({
        title: 'Success',
        text: '<%= success %>',
        icon: 'success',
        confirmButtonColor: '#2cb5e8'
      });
    </script>
  <% } %>

  <%- include('../partials/admin/footer') %>
</body>
</html>