<!DOCTYPE html>
<html lang="en">

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta charset="utf-8" />
    <title>PixelPlay Admin Verification</title>
    <meta name="description" content="Secure admin access portal for PixelPlay command center." />
    <link rel="stylesheet" href="/globals.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        /** @type {import('tailwindcss').Config} */
        tailwind.config = {
            theme: {
                extend: {},
            },
            plugins: [],
        }
    </script>
</head>

<body>
    <main
        class="flex min-h-[1024px] items-center justify-center px-0 py-[181px] relative [background:radial-gradient(50%_50%_at_50%_50%,rgba(26,26,26,1)_0%,rgba(0,0,0,1)_100%),linear-gradient(0deg,rgba(255,255,255,1)_0%,rgba(255,255,255,1)_100%)] w-full min-w-[1440px]">
        <div class="flex items-start justify-center p-4 relative flex-1 grow">
            <section
                class="max-w-[1000px] w-[1000px] h-[628px] items-start justify-center bg-[#141414] rounded-lg overflow-hidden border border-solid border-[#ffffff0d] shadow-[0px_25px_50px_-12px_#000000b2] flex relative"
                aria-label="Admin login panel">
                <div class="flex flex-col w-[554.5px] items-start justify-center p-14 relative self-stretch">
                    <header
                        class="pt-0 pb-8 px-0 flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                        <div class="gap-2 flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                            <div class="flex items-center gap-2 relative self-stretch w-full flex-[0_0_auto]">
                                <div class="relative w-1.5 h-1.5 bg-[#d9a34a] rounded-full" aria-hidden="true"></div>
                                <div class="inline-flex flex-col items-start relative flex-[0_0_auto]">
                                    <p
                                        class="relative flex items-center w-fit mt-[-1.00px] [font-family:'Nimbus_Sans-Bold',Helvetica] font-bold text-[#d9a34a] text-[10px] tracking-[2.00px] leading-[15px] whitespace-nowrap">
                                        SECURE PORTAL</p>
                                </div>
                            </div>
                            <div
                                class="flex items-center gap-2 pt-2 pb-0 px-0 relative self-stretch w-full flex-[0_0_auto]">
                                <div class="relative w-6 h-6" aria-hidden="true">
                                    <img class="absolute w-[87.50%] h-[91.67%] top-[8.33%] left-[12.50%]"
                                        src="img/vector.svg" alt="" />
                                </div>
                                <div
                                    class="text-white text-xl tracking-[0.50px] leading-7 relative flex items-center w-fit mt-[-1.00px] [font-family:'Nimbus_Sans-Bold',Helvetica] font-bold whitespace-nowrap">
                                    Codex Arc</div>
                            </div>
                            <div
                                class="flex flex-col items-start pt-8 pb-0 px-0 relative self-stretch w-full flex-[0_0_auto]">
                                <h1
                                    class="text-white text-3xl tracking-[-0.75px] leading-9 relative flex items-center self-stretch mt-[-1.00px] [font-family:'Nimbus_Sans-Bold',Helvetica] font-bold">
                                    Admin Verification</h1>
                            </div>
                            <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                <p
                                    class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'Cal_Sans-Regular',Helvetica] font-normal text-gray-500 text-sm tracking-[0] leading-5">
                                    Enter your credentials to access the command center.</p>
                            </div>
                        </div>
                    </header>
                    <form id="admin-login-form"
                        class="flex-col items-start pt-0 pb-4 px-0 self-stretch w-full flex-[0_0_auto] flex relative"
                        action="/admin/login" method="post" aria-label="Admin verification form" novalidate>
                        <div class="flex-col items-start gap-5 self-stretch w-full flex-[0_0_auto] flex relative">
                            <div class="flex flex-col items-start gap-2 relative self-stretch w-full flex-[0_0_auto]">
                                <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                    <label
                                        class="text-gray-500 text-xs tracking-[0.30px] leading-4 relative flex items-center self-stretch mt-[-1.00px] [font-family:'Nimbus_Sans-Bold',Helvetica] font-bold"
                                        for="input-1">ADMIN EMAIL</label>
                                </div>
                                <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                    <div
                                        class="flex flex-col items-start pl-10 pr-3 py-3 relative self-stretch w-full flex-[0_0_auto] bg-[#111111] rounded-md overflow-hidden border border-solid border-zinc-800">
                                        <input
                                            class="relative self-stretch w-full border-[none] [background:none] [font-family:'Cal_Sans-Regular',Helvetica] font-normal text-gray-300 text-sm tracking-[0] leading-5 p-0 outline-none"
                                            placeholder="system@codexarc.com" type="email" id="input-1" name="email"
                                            autocomplete="email" inputmode="email" aria-required="true" />
                                    </div>
                                    <div class="inline-flex h-full items-center pl-3 pr-0 py-0 absolute top-0 left-0 pointer-events-none"
                                        aria-hidden="true">
                                        <div class="relative w-4 h-4">
                                            <img class="absolute w-[91.67%] h-[83.33%] top-[16.67%] left-[8.33%]"
                                                src="img/vector-3.svg" alt="" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="flex flex-col items-start gap-2 relative self-stretch w-full flex-[0_0_auto]">
                                <div
                                    class="flex items-center justify-between pr-[5.68e-14px] pl-0 py-0 relative self-stretch w-full flex-[0_0_auto]">
                                    <div class="inline-flex flex-col items-start relative flex-[0_0_auto]">
                                        <label
                                            class="text-gray-500 text-xs tracking-[0.30px] leading-4 relative flex items-center w-fit mt-[-1.00px] [font-family:'Nimbus_Sans-Bold',Helvetica] font-bold whitespace-nowrap"
                                            for="input-2">PASSWORD</label>
                                    </div>
                                </div>
                                <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                    <div
                                        class="flex flex-col items-start pl-10 pr-3 py-3 relative self-stretch w-full flex-[0_0_auto] bg-[#111111] rounded-md overflow-hidden border border-solid border-[#1fb2e9] shadow-[0px_0px_15px_#1fb2e966]">
                                        <input
                                            class="relative flex items-center self-stretch [font-family:'Cal_Sans-Regular',Helvetica] font-normal text-white text-sm tracking-[0] leading-5 p-0 border-[none] [background:none] outline-none"
                                            type="password" id="input-2" name="password" placeholder="••••••••"
                                            aria-required="true" />
                                    </div>
                                    <div class="inline-flex h-full items-center pl-3 pr-0 py-0 absolute top-0 left-0 pointer-events-none"
                                        aria-hidden="true">
                                        <div class="relative w-4 h-4">
                                            <img class="absolute w-[87.50%] h-[91.67%] top-[8.33%] left-[12.50%]"
                                                src="img/image.svg" alt="" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <button type="submit"
                                class="items-center justify-center gap-2 px-0 py-4 self-stretch w-full flex-[0_0_auto] bg-[#1fb2e9] rounded-md shadow-[0px_0px_20px_#1fb2e94c] flex relative">
                                <span
                                    class="justify-center text-[#0f0f0f] text-sm text-center tracking-[1.40px] leading-5 relative flex items-center w-fit mt-[-1.00px] [font-family:'Nimbus_Sans-Bold',Helvetica] font-bold whitespace-nowrap">SECURE
                                    LOGIN</span>
                                <span class="relative w-4 h-4" aria-hidden="true">
                                    <img class="absolute w-[91.67%] h-[83.33%] top-[16.67%] left-[8.33%]"
                                        src="img/vector-2.svg" alt="" />
                                </span>
                            </button>
                        </div>
                        <% if (typeof error !== 'undefined' && error) { %>
                        <p id="admin-alert" class="mt-4 text-red-400 text-sm text-center [font-family:'Cal_Sans-Regular',Helvetica]" role="alert">
                            <%= error %>
                        </p>
                        <% } else { %>
                        <p id="admin-alert" class="hidden mt-4 text-red-400 text-sm text-center [font-family:'Cal_Sans-Regular',Helvetica]" role="alert"></p>
                        <% } %>
                    </form>
                    <footer
                        class="flex flex-col items-start pt-[39.12px] pb-0 px-0 relative self-stretch w-full flex-[0_0_auto]">
                        <div class="flex flex-col items-center relative self-stretch w-full flex-[0_0_auto]">
                            <p
                                class="relative flex items-center justify-center w-fit mt-[-1.00px] [font-family:'Averia_Serif_Libre-Regular',Helvetica] font-normal text-gray-600 text-[10px] text-center tracking-[0.50px] leading-[16.2px] whitespace-nowrap">
                                UNAUTHORIZED ACCESS ATTEMPTS ARE LOGGED.</p>
                        </div>
                    </footer>
                </div>
                <aside class="relative flex-1 grow h-[994px] mb-[-367.00px] bg-[#0a0a0d] overflow-hidden"
                    aria-label="Brand showcase">
                    <div class="absolute top-[calc(50.00%_-_293px)] left-[calc(50.00%_-_247px)] w-[494px] h-[355px]">
                        <div class="inline-flex items-center justify-center absolute top-0 left-[calc(50.00%_-_108px)]">
                            <div
                                class="relative w-[217px] h-[145px] aspect-[1.5] bg-[url(legacy:image:md5:376:3757-no-children)] bg-cover bg-[50%_50%]">
                            </div>
                        </div>
                        <div
                            class="flex flex-col w-[213px] h-px items-center px-[86.41px] py-0 absolute top-[84px] left-[calc(50.00%_-_106px)]">
                            <div
                                class="relative w-10 h-px [background:linear-gradient(90deg,rgba(14,165,233,0)_0%,rgba(14,165,233,0.4)_50%,rgba(14,165,233,0)_100%)]">
                            </div>
                        </div>
                        <div
                            class="inline-flex flex-col items-start gap-[6.59px] absolute top-28 left-[calc(50.00%_-_106px)]">
                            <div
                                class="relative flex items-center justify-center w-fit mt-[-1.00px] [font-family:'Inter-ExtraBold',Helvetica] font-extrabold text-zinc-100 text-[28px] text-center tracking-[1.68px] leading-[33.6px] whitespace-nowrap">
                                THE LEGENDS</div>
                            <div
                                class="inline-flex flex-col items-center pl-[63.16px] pr-[63.17px] py-0 relative flex-[0_0_auto]">
                                <div
                                    class="relative flex items-center justify-center w-fit mt-[-1.00px] [font-family:'Inter-SemiBold',Helvetica] font-semibold text-[#d4af37] text-lg text-center tracking-[3.24px] leading-[21.6px] whitespace-nowrap">
                                    LEGION</div>
                            </div>
                        </div>
                        <div
                            class="flex flex-col w-[213px] h-px items-center px-[86.41px] py-0 absolute top-[202px] left-[calc(50.00%_-_106px)]">
                            <div
                                class="relative w-10 h-px [background:linear-gradient(90deg,rgba(14,165,233,0)_0%,rgba(14,165,233,0.4)_50%,rgba(14,165,233,0)_100%)]">
                            </div>
                        </div>
                    </div>
                    <div class="absolute w-full h-full top-0 left-0 [background:linear-gradient(180deg,rgba(14,165,233,0.04)_3%,rgba(14,165,233,0)_3%),linear-gradient(90deg,rgba(14,165,233,0.04)_3%,rgba(14,165,233,0)_3%)]"
                        aria-hidden="true"></div>
                    <div class="absolute top-[calc(50.00%_-_160px)] left-[calc(50.00%_-_160px)] w-80 h-80 [background:radial-gradient(50%_50%_at_50%_50%,rgba(14,165,233,0.07)_0%,rgba(14,165,233,0)_70%)]"
                        aria-hidden="true"></div>
                    <div class="absolute h-full top-0 right-0 w-px [background:linear-gradient(180deg,rgba(14,165,233,0)_0%,rgba(14,165,233,0.2)_50%,rgba(14,165,233,0)_100%)]"
                        aria-hidden="true"></div>
                </aside>
            </section>
        </div>
    </main>
    <script>
        (function () {
            const form    = document.getElementById('admin-login-form');
            const alertEl = document.getElementById('admin-alert');

            function showAlert(msg) {
                alertEl.textContent = msg;
                alertEl.classList.remove('hidden');
            }

            // Clear alert on any input activity
            document.querySelectorAll('#admin-login-form input').forEach(function (inp) {
                inp.addEventListener('input', function () {
                    alertEl.classList.add('hidden');
                });
            });

            form.addEventListener('submit', function (e) {
                const email    = document.getElementById('input-1').value.trim();
                const password = document.getElementById('input-2').value;

                if (!email) {
                    e.preventDefault();
                    showAlert('Admin email is required.');
                    return;
                }

                const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                if (!emailRe.test(email)) {
                    e.preventDefault();
                    showAlert('Please enter a valid email address.');
                    return;
                }

                if (!password) {
                    e.preventDefault();
                    showAlert('Password is required.');
                    return;
                }

                if (password.length < 6) {
                    e.preventDefault();
                    showAlert('Password must be at least 6 characters.');
                    return;
                }
            });
        })();
    </script>
</body>

</html>