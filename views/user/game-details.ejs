<%- include('../partials/user/header') %>

<%
  // Compute theme colors based on product.edition_type
  const isLegendary = (product.edition_type === 'LEGENDARY');
  
  const themeText = isLegendary ? 'text-pixel-gold' : 'text-pixel-cyan';
  const themeBorder = isLegendary ? 'border-pixel-gold' : 'border-pixel-cyan';
  const themeBg = isLegendary ? 'bg-pixel-gold' : 'bg-pixel-cyan';
  const themeBgHover = isLegendary ? 'hover:bg-pixel-gold/20' : 'hover:bg-pixel-cyan/20';
  const themeShadow = isLegendary ? 'shadow-pixel-gold' : 'shadow-pixel-cyan';
  const themeBtnBg = isLegendary ? 'bg-pixel-gold bg-pixel-gold-hover' : 'bg-pixel-cyan bg-pixel-cyan-hover';

  // Video helper check
  const isVideo = (url) => {
    if (!url) return false;
    const cleanUrl = url.split('?')[0].toLowerCase();
    return cleanUrl.endsWith('.mp4') || cleanUrl.endsWith('.webm') || cleanUrl.endsWith('.ogg') || url.includes('/video/');
  };

  // Gallery fallback
  const fallbackCover = product.cover_image || product.coverImage || product.coverImageUrl || '/images/default-game.jpg';
  const gallery = (product.gallery && product.gallery.length > 0) 
    ? product.gallery 
    : [fallbackCover];
  const firstMedia = gallery[0];

  // Reviews calculation
  const productReviews = (typeof reviews !== 'undefined' && reviews) ? reviews : [];
  let avgRating = 0;
  let totalReviews = productReviews.length;
  if (totalReviews > 0) {
    const sum = productReviews.reduce((acc, rev) => acc + (rev.rating || 0), 0);
    avgRating = (sum / totalReviews).toFixed(1);
  } else {
    avgRating = '0.0';
  }

  // Star rendering helper
  const renderStars = (rating, sizeClass = 'w-4 h-4') => {
    let starsHtml = '';
    const roundedRating = Math.round(parseFloat(rating) || 0);
    for (let i = 1; i <= 5; i++) {
      if (i <= roundedRating) {
        starsHtml += `<svg class="${sizeClass} ${themeText}" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>`;
      } else {
        starsHtml += `<svg class="${sizeClass} text-gray-600" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>`;
      }
    }
    return starsHtml;
  };

  // Similar games dynamic mock fallback list
  const mockSimilarGames = [
    { title: 'Neon Override 2077', categoryName: 'Action RPG', platforms: ['PS5'], price: 59.99, coverImageUrl: 'https://lh3.googleusercontent.com/aida-public/AB6AXuDzScuMskdeHwISgiKZni6Bys9tpCgt3qQWL1XpI5leVfzy3xd2OXe_jjBfvKRsE6nA4ybe58aoD3858tWVdsXa4DBZjKEI_5IH88TdQFPjU66XIGqexO8rbnIrAem_WpePpp7ne9x0Ty-twdpVIX8ccC7-PM-cnsklO04QvxmkFK7te2TwPy1ZHHiHNbQ4MynOfHkjEbAeMsHn4phqSexVbjOKFsLNZobw7acge1yppFQFR4IiV303vdbwTAb6ps-GFthh13YkP0ze', edition_type: 'STANDARD' },
    { title: 'Void Breach: Signa', categoryName: 'Shooter', platforms: ['Xbox Series X'], price: 49.99, coverImageUrl: 'https://lh3.googleusercontent.com/aida-public/AB6AXuDp8m9QPJAc4rCfHv_8FbGfjugPXa0OXA1ghpQCwCjPWIYfpzoJKocnaCcEZed48bxu65DI07Vp4_TCYzGoRLPBRvl9we7rwdPYUnQigWDj9b_axhUPws4cbdZiLLutSfanaCpaFE4HjjCojw1qa_b12KOK4ytEKhWa0QkOiZz-ZJ40joRLVHbOIkQym4Cxf97s9oOEnjzCsFHH-SfhMiKG7zkY1KPhDdB4EG-EWC2A5Y54UsDJkJbSqaxmgufirGVBZrHALRo92bYa', edition_type: 'STANDARD' },
    { title: 'Chronicles of Aethelgard', categoryName: 'Legends Vault', platforms: ['PS5'], price: 119.99, coverImageUrl: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCigZK8yN1e5ru98LTuD63NsU6b-4ckp-CGypvoDgTyGILKZFN3SFTxBWS2eqzUm7VEd7xgz6Ct05ubK21wU_WUvND__T6gCEywkhw28JdfNovBxKptkU4da91JDNZoSaGfMBzzxrvKTerW-cqQ2XZ61VDLn3hR-QiC0MqqX_pg4fS_J--3cAEm9Ka9fh-pVPz1QImdshOMWM-GhBPbt78AHl9acEJLbqirwCAhRXnCqxMwhuAl-Ug03OsST1iUh1RBHr3bpsClxd9f', edition_type: 'LEGENDARY' },
    { title: 'Aether Chronicles', categoryName: 'Adventure', platforms: ['Nintendo Switch'], price: 44.99, coverImageUrl: 'https://lh3.googleusercontent.com/aida-public/AB6AXuAtKd3MlNGyLm-mx6Rv0q9x5em_SMRJLLJqB2ZSH_u-0XD7DuZZJEUb8j4iei5Hv4cXxqM7F3DfNWmz3eO4qfSWk4xv_nsKEw5aq2h2vc-lE4OAfBmeaWi3fXdUqW4QIZb133S0uS6-sZAmFT_xSLg9ex3R2dg-JRsW9syXIUS8hXhQ7y_9lqXTYBpVM_DZYcpDlW3fad7W6TecyFxx-hu8sCdJZ5p_uLXjdfBiLC2eyAKVHv3nDHJl39zVBP4lXwDGyRjBCOB4-a4t', edition_type: 'STANDARD' },
    { title: "Hollow Knight's Oath", categoryName: 'Horror RPG', platforms: ['Xbox Series X'], price: 39.99, coverImageUrl: 'https://lh3.googleusercontent.com/aida-public/AB6AXuBTWSpv07GHjoWX_guqMgCaecXP4DISyOFyP8ax0RsUPeoawgH6G-vmQWVOMtoPuEGtwcI0oNenXvyzGKUNbtNh-FSSCQPihYH8SVmpwtS44to3ctWY65KLoC7dK_A1NomWcOGwjww58KFr2fttJH0b54x2StLDEcuecBfc92MhXM3kmuAovi6j4ReaTkAUNrrQ1N4K12aYTDC_lglSZQrgUtUi1BmL4gMiyJ7lF_7fPtu0ItXOP2WzKmWovkwNB529SjrfDt9eKl4d', edition_type: 'STANDARD' }
  ];
  const similarGamesList = (typeof similarGames !== 'undefined' && similarGames) ? similarGames : [];

  // Helper to get platform stock
  const getPlatformStock = (platName) => {
    if (product.platform_stock && product.platform_stock.length > 0) {
      const ps = product.platform_stock.find(item => item.platform.toLowerCase() === platName.toLowerCase());
      return ps ? ps.stock : 0;
    }
    return product.stock || 0;
  };

  // Find first platform that is in stock
  let defaultPlat = '';
  if (product.platforms && product.platforms.length > 0) {
    const inStockPlat = product.platforms.find(plat => getPlatformStock(plat) > 0);
    defaultPlat = inStockPlat || product.platforms[0];
  } else {
    defaultPlat = 'PC';
  }

  // Price & Offer handling
  let initialBasePrice = product.price || 0;
  if (product.platform_stock && product.platform_stock.length > 0) {
    const defaultPlatStock = product.platform_stock.find(ps => ps.platform === defaultPlat);
    if (defaultPlatStock && typeof defaultPlatStock.price === 'number') {
      initialBasePrice = defaultPlatStock.price;
    } else {
      const firstPlat = product.platform_stock[0];
      if (firstPlat && typeof firstPlat.price === 'number') {
        initialBasePrice = firstPlat.price;
      }
    }
  }
  const discount = typeof product.categoryDiscount !== 'undefined' ? product.categoryDiscount : 0;
  const displayPrice = discount > 0 ? Math.max(0, initialBasePrice - (initialBasePrice * (discount / 100))) : initialBasePrice;
  const hasDiscount = discount > 0;
%>

<style>
  .text-pixel-gold { color: #F2B94A !important; }
  .text-pixel-cyan { color: #00D1FF !important; }
  .border-pixel-gold { border-color: #F2B94A !important; }
  .border-pixel-cyan { border-color: #00D1FF !important; }
  .bg-pixel-gold { background-color: #F2B94A !important; }
  .bg-pixel-cyan { background-color: #00D1FF !important; }
  .shadow-pixel-gold { box-shadow: 0 0 15px rgba(242, 185, 74, 0.3) !important; }
  .shadow-pixel-cyan { box-shadow: 0 0 15px rgba(0, 209, 255, 0.3) !important; }
  .bg-pixel-cyan-hover:hover { background-color: #00B8E6 !important; }
  .bg-pixel-gold-hover:hover { background-color: #d9a336 !important; }
  
  .magnifier-lens {
    position: absolute;
    border: 2px solid <%= isLegendary ? '#F2B94A' : '#00D1FF' %>;
    border-radius: 50%;
    cursor: none;
    width: 160px;
    height: 160px;
    pointer-events: none;
    box-shadow: 0 0 15px rgba(0, 180, 255, 0.4), inset 0 0 10px rgba(0,0,0,0.5);
    background-repeat: no-repeat;
    display: none;
    z-index: 30;
  }
</style>

<body class="antialiased min-h-screen flex flex-col bg-pixel-dark text-pixel-text">

<%- include('../partials/user/navbar', { activeTab: 'browse', user: typeof user !== 'undefined' ? user : null }) %>

<!-- Main Content Area -->
<main class="max-w-[95%] mx-auto px-4 sm:px-6 lg:px-8 py-6 flex-grow w-full">
  <!-- Breadcrumbs -->
  <nav aria-label="Breadcrumb" class="flex text-xs text-gray-500 mb-6">
    <ol class="inline-flex items-center space-x-1 md:space-x-2">
      <li class="inline-flex items-center">
        <svg class="w-3 h-3 mr-1.5" fill="currentColor" viewbox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path></svg>
        <a class="hover:text-pixel-white" href="/">Home</a>
      </li>
      <li>
        <div class="flex items-center">
          <span class="mx-1">/</span>
          <a class="hover:text-pixel-white ml-1 md:ml-2" href="/browse">Browse</a>
        </div>
      </li>
      <% if (product.categoryName && product.categoryName !== 'N/A') { %>
        <li>
          <div class="flex items-center">
            <span class="mx-1">/</span>
            <a class="hover:text-pixel-white ml-1 md:ml-2" href="/browse?genre=<%= encodeURIComponent(product.categoryName) %>"><%= product.categoryName %></a>
          </div>
        </li>
      <% } %>
      <li aria-current="page">
        <div class="flex items-center">
          <span class="mx-1">/</span>
          <span class="text-pixel-white ml-1 md:ml-2"><%= product.title %></span>
        </div>
      </li>
    </ol>
  </nav>

  <!-- Product Hero Section -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-12">
    <!-- Left: Media Gallery -->
    <div class="lg:col-span-8 space-y-4">
      <!-- Main Media Player -->
      <div id="mainMediaPlayer" class="relative bg-black rounded-lg overflow-hidden aspect-video group cursor-pointer border border-gray-800">
        <video id="mainMediaVideo" src="<%= isVideo(firstMedia) ? firstMedia : '' %>" controls controlslist="nodownload" oncontextmenu="return false;" class="w-full h-full object-cover <%= isVideo(firstMedia) ? '' : 'hidden' %>"></video>
        <img id="mainMediaImage" alt="<%= product.title %> screenshot" class="w-full h-full object-cover transition-opacity duration-300 <%= isVideo(firstMedia) ? 'hidden' : '' %>" src="<%= isVideo(firstMedia) ? '' : firstMedia %>"/>
        <!-- Top Left Tag -->
        <div class="absolute top-4 left-4 bg-pixel-panel/80 backdrop-blur-sm border <%= themeBorder %> <%= themeText %> text-[10px] font-bold px-2 py-1 rounded uppercase tracking-wider">
          <%= isLegendary ? 'Legends Rarity' : 'Standard Rarity' %>
        </div>
        <!-- Controls overlay (Zoom & Fullscreen) -->
        <div class="absolute top-4 right-4 flex items-center gap-2 z-20">
          <button type="button" id="zoomBtn" class="bg-pixel-panel/80 hover:bg-pixel-panel border border-zinc-700 text-white rounded-lg p-2 flex items-center justify-center transition-colors cursor-pointer hover:text-sky-400 <%= isVideo(firstMedia) ? 'hidden' : '' %>" aria-label="Toggle Magnifier Zoom" title="Toggle Magnifier Zoom">
            <i class="fa-solid fa-magnifying-glass-plus text-sm"></i>
          </button>
          <button type="button" id="fullscreenBtn" class="bg-pixel-panel/80 hover:bg-pixel-panel border border-zinc-700 text-white rounded-lg p-2 flex items-center justify-center transition-colors cursor-pointer hover:text-sky-400 <%= isVideo(firstMedia) ? 'hidden' : '' %>" aria-label="Toggle Fullscreen" title="Toggle Fullscreen">
            <i class="fa-solid fa-expand text-sm"></i>
          </button>
        </div>
        <!-- Magnifier Lens -->
        <div id="magnifierLens" class="magnifier-lens"></div>
      </div>
      <!-- Thumbnail Gallery -->
      <div class="flex space-x-2 overflow-x-auto pb-2 scrollbar-hide">
        <% gallery.forEach((mediaUrl, index) => { %>
          <% const mediaIsVideo = isVideo(mediaUrl); %>
          <div 
            onclick="changeActiveMedia('<%= mediaUrl %>', '<%= mediaIsVideo ? 'video' : 'image' %>', this)"
            class="flex-none w-32 aspect-video bg-pixel-panel rounded border-2 <%= index === 0 ? themeBorder : 'border-gray-800' %> cursor-pointer relative overflow-hidden hover:border-gray-500 transition-colors thumbnail-item"
          >
            <img alt="Thumbnail <%= index + 1 %>" class="w-full h-full object-cover <%= index === 0 ? '' : 'opacity-60' %> hover:opacity-100 transition-opacity" src="<%= mediaIsVideo ? fallbackCover : mediaUrl %>"/>
            <% if (mediaIsVideo) { %>
              <div class="absolute inset-0 flex items-center justify-center bg-black/30">
                <svg class="h-6 w-6 <%= themeText %> opacity-80" fill="currentColor" viewbox="0 0 20 20">
                  <path clip-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" fill-rule="evenodd"></path>
                </svg>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>

    <!-- Right: Product Info & Purchase -->
    <div class="lg:col-span-4 flex flex-col">
      <!-- Title & Meta -->
      <div class="mb-6">
        <div class="flex items-center space-x-2 <%= themeText %> text-xs font-bold tracking-wider uppercase mb-2">
          <svg class="w-4 h-4" fill="currentColor" viewbox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path clip-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" fill-rule="evenodd"></path></svg>
          <span><%= isLegendary ? 'Legends Collection' : 'Standard Edition' %> • <%= product.release_year || 2026 %></span>
        </div>
        <div class="mb-4 w-32 aspect-[3/4] rounded-md overflow-hidden border border-gray-800 bg-gray-900 shadow-lg">
          <img src="<%= fallbackCover %>" class="w-full h-full object-cover" alt="<%= product.title %> Cover" />
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-pixel-white leading-tight mb-2 uppercase"><%= product.title %></h1>
        <div class="text-xs text-gray-400 mb-4 flex flex-wrap gap-x-4 gap-y-1">
          <p>Publisher: <span class="text-gray-300"><%= product.publisher || 'PixelPlay Interactive' %></span></p>
        </div>
        <!-- Rating -->
        <div class="flex items-center space-x-2 text-sm">
          <div class="flex space-x-0.5">
            <%- renderStars(avgRating, 'w-4 h-4') %>
          </div>
          <span class="text-pixel-white font-medium"><%= avgRating %></span>
          <span class="text-xs text-gray-500">(<%= totalReviews %> active <%= totalReviews === 1 ? 'transmission/review' : 'transmissions/reviews' %>)</span>
        </div>
      </div>

      <!-- Platform Selection -->
      <div class="mb-6">
        <p class="text-[10px] text-gray-500 font-bold uppercase tracking-wider mb-2">Select Target Platform</p>
        <div class="grid grid-cols-3 gap-2">
          <% if (product.platforms && product.platforms.length > 0) { %>
            <% product.platforms.forEach((plat) => { %>
              <% 
                const platStock = getPlatformStock(plat);
                const isOutOfStock = (platStock === 0);
                const isSelected = (plat === defaultPlat);
              %>
              <button 
                type="button" 
                class="platform-btn bg-pixel-panel border <%= isSelected ? themeBorder : 'border-gray-700' %> <%= isSelected ? 'text-pixel-white font-bold' : 'text-gray-400' %> <%= isOutOfStock ? 'opacity-40 cursor-not-allowed pointer-events-none border-gray-800/50' : 'hover:bg-gray-800 cursor-pointer' %> text-xs font-semibold py-2 px-1 rounded flex items-center justify-center space-x-1"
                data-platform="<%= plat %>"
                <%= isOutOfStock ? 'disabled' : '' %>
              >
                <svg class="check-icon w-3 h-3 <%= themeText %> <%= isSelected && !isOutOfStock ? '' : 'hidden' %>" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                </svg>
                <span><%= plat.toUpperCase() %></span>
              </button>
            <% }) %>
          <% } else { %>
            <% 
              const platStock = getPlatformStock('PC');
              const isOutOfStock = (platStock === 0);
            %>
            <button 
              type="button" 
              class="platform-btn bg-pixel-panel border <%= themeBorder %> text-pixel-white font-bold text-xs font-semibold py-2 px-1 rounded flex items-center justify-center space-x-1 <%= isOutOfStock ? 'opacity-40 cursor-not-allowed pointer-events-none border-gray-800/50' : 'hover:bg-gray-800 cursor-pointer' %>"
              data-platform="PC"
              <%= isOutOfStock ? 'disabled' : '' %>
            >
              <svg class="check-icon w-3 h-3 <%= themeText %> <%= isOutOfStock ? 'hidden' : '' %>" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
              </svg>
              <span>PC</span>
            </button>
          <% } %>
        </div>
      </div>

      <!-- Price & Stock -->
      <%
        let initialStock = getPlatformStock(defaultPlat);
      %>
      <div class="bg-pixel-panel border border-gray-800 rounded-lg p-4 mb-6">
        <div class="flex justify-between items-center mb-3 border-b border-gray-800 pb-3">
          <div class="flex items-center space-x-2">
            <div class="w-2 h-2 rounded-full <%= themeBg %> animate-pulse"></div>
            <p class="text-xs text-gray-300">In Stock: <span id="selectedPlatformStock" class="<%= themeText %> font-bold"><%= initialStock %> <%= initialStock === 1 ? 'Physical Unit' : 'Physical Units' %></span> left in operational facility</p>
          </div>
          <% if (typeof user !== 'undefined' && user && user.addresses && user.addresses.some(addr => addr.postal_code)) { %>
            <p class="text-[10px] text-gray-500 flex items-center"><svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>Est. 2-3 Days</p>
          <% } %>
        </div>
        <div id="platformPriceContainer" class="flex items-end justify-between mb-4">
          <% if (hasDiscount) { %>
            <div class="flex flex-col">
              <span class="text-xs text-gray-500 line-through">₹<%= Number(initialBasePrice / 100).toFixed(2) %></span>
              <span class="text-3xl font-bold text-pixel-white">₹<%= Number(displayPrice / 100).toFixed(2) %></span>
            </div>
            <span class="bg-red-500 text-white text-xs font-bold px-2 py-1 rounded">
              <%= product.categoryDiscount %>% OFF
            </span>
          <% } else { %>
            <span class="text-3xl font-bold text-pixel-white">₹<%= Number(initialBasePrice / 100).toFixed(2) %></span>
          <% } %>
        </div>
        <!-- Action Buttons -->
        <div class="space-y-3">
          <button id="buyNowBtn" class="w-full <%= themeBtnBg %> text-black font-bold py-3 px-4 rounded transition-colors flex items-center justify-center space-x-2 <%= themeShadow %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
            <span>BUY NOW</span>
          </button>
          <button id="addToCartBtn" class="w-full bg-transparent border border-gray-600 hover:border-pixel-white text-pixel-white font-bold py-3 px-4 rounded transition-colors flex items-center justify-center space-x-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
            <span>ADD TO CART</span>
          </button>
        </div>
      </div>

      <!-- Utility Links -->
      <div class="flex justify-between items-center text-xs text-gray-400 px-2 pb-4 border-b border-gray-800">
        <button type="button" onclick="toggleWishlist(this, '<%= product._id %>', '<%= product.title.replace(/'/g, "\\'") %>')" class="flex items-center space-x-1 hover:text-pixel-white transition-colors">
