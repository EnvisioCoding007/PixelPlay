</main>

<script id="gameDetailsData" type="application/json">
  {
    "platforms": <%- JSON.stringify(product.platforms || []) %>,
    "platformStock": <%- JSON.stringify(product.platform_stock || []) %>,
    "globalStock": <%= product.stock || 0 %>,
    "systemRequirements": <%- JSON.stringify(product.system_requirements || {}) %>
  }
</script>

<script>
  const wishlistPlatforms = <%- JSON.stringify(typeof wishlistPlatforms !== 'undefined' ? wishlistPlatforms : []) %>;
  async function checkLiveStatus() {
    try {
      const response = await fetch('/products/status/<%= product._id %>');
      const data = await response.json();
      if (data.status === 'Hidden' || data.redirectUrl) {
        window.location.href = data.redirectUrl || '/browse';
        return false;
      }
      return true;
    } catch (err) {
      console.error(err);
      return true;
    }
  }
  function changeActiveMedia(url, type, element) {
    const mainPlayer = document.getElementById('mainMediaPlayer');
    if (!mainPlayer) return;
    
    const video = document.getElementById('mainMediaVideo');
    const img = document.getElementById('mainMediaImage');
    const zoomBtn = document.getElementById('zoomBtn');
    
    // Stop magnifier lens
    const lens = document.getElementById('magnifierLens');
    if (lens) {
      lens.style.display = 'none';
    }

    if (type === 'video') {
      if (img) img.classList.add('hidden');
      if (video) {
        video.src = url;
        video.classList.remove('hidden');
        video.play().catch(err => {});
      }
      if (zoomBtn) {
        zoomBtn.classList.add('hidden');
      }
      const fullscreenBtn = document.getElementById('fullscreenBtn');
      if (fullscreenBtn) {
        fullscreenBtn.classList.add('hidden');
      }
    } else {
      if (video) {
        video.pause();
        video.classList.add('hidden');
        video.src = '';
      }
      if (img) {
        img.src = url;
        img.classList.remove('hidden');
      }
      if (zoomBtn) {
        zoomBtn.classList.remove('hidden');
      }
      const fullscreenBtn = document.getElementById('fullscreenBtn');
      if (fullscreenBtn) {
        fullscreenBtn.classList.remove('hidden');
      }
    }
    
    // Update active border on thumbnails
    const thumbnails = document.querySelectorAll('.thumbnail-item');
    const themeBorderClass = '<%= isLegendary ? "border-pixel-gold" : "border-pixel-cyan" %>';
    
    thumbnails.forEach(thumb => {
      thumb.classList.remove('border-pixel-gold', 'border-pixel-cyan', 'border-2');
      thumb.classList.add('border-gray-800', 'border');
      
      const img = thumb.querySelector('img');
      if (img) img.classList.add('opacity-60');
    });
    
    element.classList.remove('border-gray-800', 'border');
    element.classList.add(themeBorderClass, 'border-2');
    
    const clickedImg = element.querySelector('img');
    if (clickedImg) clickedImg.classList.remove('opacity-60');
  }

  // Interactive platform-specific updates
  (function() {
    const dataEl = document.getElementById('gameDetailsData');
    let gameData = { platforms: [], platformStock: [], globalStock: 0, systemRequirements: {} };
    if (dataEl) {
      try {
        gameData = JSON.parse(dataEl.textContent);
      } catch (e) {
        console.error("Error parsing game details data:", e);
      }
    }

    const consoleDefaults = {
      "PlayStation 5": { os: "PS5 System Software", storage: "100 GB SSD", graphics: "4K 60FPS Support", processor: "AMD Zen 2 (8-core)", memory: "16 GB GDDR6" },
      "Xbox Series X|S": { os: "Xbox System Software", storage: "100 GB SSD", graphics: "4K 60FPS Support", processor: "AMD Zen 2 (8-core)", memory: "16 GB GDDR6" },
      "Nintendo Switch": { os: "Horizon OS", storage: "32 GB", graphics: "720p/1080p Support", processor: "Nvidia Tegra X1", memory: "4 GB LPDDR4" },
      "PlayStation 4": { os: "Orbis OS", storage: "500 GB / 1 TB", graphics: "1080p Support", processor: "AMD Jaguar (8-core)", memory: "8 GB GDDR5" },
      "Xbox One": { os: "Xbox OS", storage: "500 GB / 1 TB", graphics: "1080p Support", processor: "AMD Jaguar (8-core)", memory: "8 GB DDR3" },
      "PlayStation 3": { os: "Cell OS", storage: "80 GB / 160 GB", graphics: "720p/1080p Support", processor: "Cell Broadband (3.2 GHz)", memory: "256 MB XDR RAM" },
      "PlayStation 2": { os: "PS2 System OS", storage: "8 MB Memory Card", graphics: "480p Support", processor: "Emotion Engine (294 MHz)", memory: "32 MB RDRAM" },
      "PlayStation 1": { os: "PlayStation OS", storage: "1 MB Memory Card", graphics: "240p/480i Support", processor: "MIPS R3000A (33.86 MHz)", memory: "2 MB" },
      "Xbox 360": { os: "Xbox 360 Dashboard", storage: "120 GB / 250 GB", graphics: "720p Support", processor: "Xenon (3.2 GHz)", memory: "512 MB GDDR3" },
      "Nintendo Wii U": { os: "Wii U System Software", storage: "32 GB", graphics: "1080p Support", processor: "Espresso (1.24 GHz)", memory: "2 GB DDR3" },
      "Nintendo Wii": { os: "Wii Menu Software", storage: "512 MB Flash", graphics: "480p Support", processor: "Broadway (729 MHz)", memory: "88 MB 1T-SRAM" },
      "Nintendo 3DS": { os: "3DS System Software", storage: "4 GB SD Card", graphics: "240p 3D Support", processor: "ARM11 (268 MHz)", memory: "128 MB FCRAM" },
      "Nintendo DS": { os: "NDS Firmware", storage: "Game Card", graphics: "192p Support", processor: "ARM9 (67 MHz) & ARM7 (33 MHz)", memory: "4 MB" },
      "PlayStation Portable": { os: "PSP System Software", storage: "Memory Stick PRO Duo", graphics: "272p Support", processor: "MIPS R4000 (333 MHz)", memory: "32 MB" },
      "PlayStation Vita": { os: "PS Vita System Software", storage: "Vita Memory Card", graphics: "544p Support", processor: "ARM Cortex-A9 (4-core)", memory: "512 MB" },
      "Sega Genesis": { os: "Genesis Hardware", storage: "ROM Cartridge", graphics: "224p Support", processor: "Motorola 68000 (7.67 MHz)", memory: "64 KB" },
      "NES": { os: "NES Hardware", storage: "ROM Cartridge", graphics: "240p Support", processor: "Ricoh 2A03 (1.79 MHz)", memory: "2 KB" },
      "SNES": { os: "SNES Hardware", storage: "ROM Cartridge", graphics: "224p/240p Support", processor: "Ricoh 5A22 (3.58 MHz)", memory: "128 KB" }
    };

    const themeText = '<%= isLegendary ? "text-pixel-gold" : "text-pixel-cyan" %>';
    const themeBorderClass = '<%= isLegendary ? "border-pixel-gold" : "border-pixel-cyan" %>';

    const buyNowBtn = document.getElementById('buyNowBtn');
    const addToCartBtn = document.getElementById('addToCartBtn');
    const originalBuyNowHtml = buyNowBtn ? buyNowBtn.innerHTML : '';
    const originalAddToCartHtml = addToCartBtn ? addToCartBtn.innerHTML : '';

    function updatePlatformSelection(selectedPlatform) {
      document.querySelectorAll('.platform-btn').forEach(btn => {
        const isSelected = btn.dataset.platform === selectedPlatform;
        const checkIcon = btn.querySelector('.check-icon');
        
        if (isSelected) {
          btn.classList.remove('border-gray-700', 'text-gray-400');
          btn.classList.add(themeBorderClass, 'text-pixel-white', 'font-bold');
          if (checkIcon) checkIcon.classList.remove('hidden');
        } else {
          btn.classList.remove(themeBorderClass, 'text-pixel-white', 'font-bold');
          btn.classList.add('border-gray-700', 'text-gray-400');
          if (checkIcon) checkIcon.classList.add('hidden');
        }
      });

      const heartIcon = document.querySelector('button[onclick*="toggleWishlist"] svg');
      if (heartIcon) {
        if (wishlistPlatforms.includes(selectedPlatform.toLowerCase())) {
          heartIcon.setAttribute('fill', 'currentColor');
          heartIcon.classList.remove('text-gray-400');
          heartIcon.classList.add('fill-red-500', 'text-red-500');
        } else {
          heartIcon.setAttribute('fill', 'none');
          heartIcon.classList.remove('fill-red-500', 'text-red-500');
          heartIcon.classList.add('text-gray-400');
        }
      }

      let stock = 0;
      if (gameData.platformStock && gameData.platformStock.length > 0) {
        const found = gameData.platformStock.find(ps => ps.platform === selectedPlatform);
        if (found) stock = found.stock;
      } else {
        stock = gameData.globalStock;
      }

      const stockEl = document.getElementById('selectedPlatformStock');
      if (stockEl) {
        stockEl.textContent = `${stock} ${stock === 1 ? 'Physical Unit' : 'Physical Units'}`;
      }

      // Update platform price display dynamically
      const categoryDiscount = <%= product.categoryDiscount || 0 %>;
      let basePrice = 0;
      if (gameData.platformStock && gameData.platformStock.length > 0) {
        const found = gameData.platformStock.find(ps => ps.platform === selectedPlatform);
        if (found) {
          basePrice = found.price || 0;
        } else {
          // Fallback to first available platform
          basePrice = gameData.platformStock[0].price || 0;
        }
      } else {
        basePrice = <%= product.price || 0 %>;
      }

      const discountedPrice = categoryDiscount > 0 ? Math.max(0, basePrice - (basePrice * (categoryDiscount / 100))) : basePrice;
      const priceContainer = document.getElementById('platformPriceContainer');
      if (priceContainer) {
        if (categoryDiscount > 0) {
          priceContainer.innerHTML = `
            <div class="flex flex-col">
              <span class="text-xs text-gray-500 line-through">₹${Number(basePrice / 100).toFixed(2)}</span>
              <span class="text-3xl font-bold text-pixel-white">₹${Number(discountedPrice / 100).toFixed(2)}</span>
            </div>
            <span class="bg-red-500 text-white text-xs font-bold px-2 py-1 rounded">
              ${categoryDiscount}% OFF
            </span>
          `;
        } else {
          priceContainer.innerHTML = `
            <span class="text-3xl font-bold text-pixel-white">₹${Number(basePrice / 100).toFixed(2)}</span>
          `;
        }
      }

      if (stock === 0) {
        if (buyNowBtn) {
          buyNowBtn.disabled = true;
          buyNowBtn.classList.add('opacity-50', 'cursor-not-allowed', 'pointer-events-none');
          buyNowBtn.innerHTML = `<span>OUT OF STOCK</span>`;
        }
        if (addToCartBtn) {
          addToCartBtn.disabled = true;
          addToCartBtn.classList.add('opacity-50', 'cursor-not-allowed', 'pointer-events-none');
          addToCartBtn.innerHTML = `<span>OUT OF STOCK</span>`;
        }
      } else {
        if (buyNowBtn) {
          buyNowBtn.disabled = false;
          buyNowBtn.classList.remove('opacity-50', 'cursor-not-allowed', 'pointer-events-none');
          buyNowBtn.innerHTML = originalBuyNowHtml;
        }
        if (addToCartBtn) {
          addToCartBtn.disabled = false;
          addToCartBtn.classList.remove('opacity-50', 'cursor-not-allowed', 'pointer-events-none');
          addToCartBtn.innerHTML = originalAddToCartHtml;
        }
      }

      const specsContainer = document.getElementById('specsContainer');
      if (specsContainer) {
        if (selectedPlatform === 'PC' && gameData.systemRequirements && gameData.systemRequirements.minimum && gameData.systemRequirements.minimum.os && gameData.systemRequirements.recommended && gameData.systemRequirements.recommended.os) {
          specsContainer.innerHTML = `
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="space-y-3">
                <h3 class="text-xs font-bold ${themeText} uppercase tracking-wider mb-2">Minimum Requirements</h3>
                <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
                  <span class="text-gray-500 uppercase text-[10px] tracking-wider">OS</span>
                  <span class="text-pixel-white text-right">${gameData.systemRequirements.minimum.os}</span>
                </div>
                <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
                  <span class="text-gray-500 uppercase text-[10px] tracking-wider">Processor</span>
                  <span class="text-pixel-white text-right">${gameData.systemRequirements.minimum.processor}</span>
                </div>
                <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
                  <span class="text-gray-500 uppercase text-[10px] tracking-wider">Memory</span>
                  <span class="text-pixel-white text-right">${gameData.systemRequirements.minimum.memory}</span>
                </div>
                <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
                  <span class="text-gray-500 uppercase text-[10px] tracking-wider">Graphics</span>
                  <span class="text-pixel-white text-right">${gameData.systemRequirements.minimum.graphics}</span>
                </div>
                <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
                  <span class="text-gray-500 uppercase text-[10px] tracking-wider">Storage</span>
                  <span class="text-pixel-white text-right">${gameData.systemRequirements.minimum.storage}</span>
                </div>
                ${gameData.systemRequirements.minimum.sound_card ? `
                <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
                  <span class="text-gray-500 uppercase text-[10px] tracking-wider">Sound Card</span>
                  <span class="text-pixel-white text-right">${gameData.systemRequirements.minimum.sound_card}</span>
                </div>` : ''}
              </div>
              <div class="space-y-3">
                <h3 class="text-xs font-bold ${themeText} uppercase tracking-wider mb-2">Recommended Requirements</h3>
                <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
                  <span class="text-gray-500 uppercase text-[10px] tracking-wider">OS</span>
                  <span class="text-pixel-white text-right">${gameData.systemRequirements.recommended.os}</span>
                </div>
                <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
                  <span class="text-gray-500 uppercase text-[10px] tracking-wider">Processor</span>
                  <span class="text-pixel-white text-right">${gameData.systemRequirements.recommended.processor}</span>
                </div>
                <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
                  <span class="text-gray-500 uppercase text-[10px] tracking-wider">Memory</span>
                  <span class="text-pixel-white text-right">${gameData.systemRequirements.recommended.memory}</span>
                </div>
                <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
                  <span class="text-gray-500 uppercase text-[10px] tracking-wider">Graphics</span>
                  <span class="text-pixel-white text-right">${gameData.systemRequirements.recommended.graphics}</span>
                </div>
                <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
                  <span class="text-gray-500 uppercase text-[10px] tracking-wider">Storage</span>
                  <span class="text-pixel-white text-right">${gameData.systemRequirements.recommended.storage}</span>
                </div>
                ${gameData.systemRequirements.recommended.sound_card ? `
                <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
                  <span class="text-gray-500 uppercase text-[10px] tracking-wider">Sound Card</span>
                  <span class="text-pixel-white text-right">${gameData.systemRequirements.recommended.sound_card}</span>
                </div>` : ''}
              </div>
            </div>
          `;
        } else {
          const defaults = consoleDefaults[selectedPlatform] || { 
            os: `${selectedPlatform} System OS`, 
            storage: "50 GB Required", 
            graphics: "1080p Support", 
            processor: "Custom CPU", 
            memory: "8 GB" 
          };
          specsContainer.innerHTML = `
            <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
              <span class="text-gray-500 uppercase text-xs tracking-wider">OS</span>
              <span class="text-pixel-white text-right">${defaults.os}</span>
            </div>
            <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
              <span class="text-gray-500 uppercase text-xs tracking-wider">Processor</span>
              <span class="text-pixel-white text-right">${defaults.processor}</span>
            </div>
            <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
              <span class="text-gray-500 uppercase text-xs tracking-wider">Memory</span>
              <span class="text-pixel-white text-right">${defaults.memory}</span>
            </div>
            <div class="flex justify-between items-center text-sm border-b border-gray-800/50 pb-2">
              <span class="text-gray-500 uppercase text-xs tracking-wider">Graphics</span>
              <span class="text-pixel-white text-right">${defaults.graphics}</span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-gray-500 uppercase text-xs tracking-wider">Storage</span>
              <span class="text-pixel-white text-right">${defaults.storage}</span>
            </div>
          `;
        }
      }
    }

    document.querySelectorAll('.platform-btn').forEach(btn => {
      btn.addEventListener('click', async function() {
        const isLive = await checkLiveStatus();
        if (!isLive) return;
        const plat = this.dataset.platform;
        updatePlatformSelection(plat);
      });
    });

    const initialPlat = '<%= defaultPlat %>';
    updatePlatformSelection(initialPlat);
  })();

  const isLoggedIn = <%= typeof user !== 'undefined' && user ? 'true' : 'false' %>;

  (function() {
    const buyNowBtn = document.getElementById('buyNowBtn');
    const addToCartBtn = document.getElementById('addToCartBtn');
    if (buyNowBtn) {
      buyNowBtn.addEventListener('click', async function(e) {
        e.preventDefault();
        e.stopPropagation();
        if (!isLoggedIn) {
          showToast("You must sign-in to continue with the process.", "info");
          return;
        }
        const isLive = await checkLiveStatus();
        if (!isLive) return;

        const activeBtn = document.querySelector('.platform-btn.text-pixel-white');
        const selectedPlatform = activeBtn ? activeBtn.dataset.platform : 'PC';
        const productId = '<%= product._id %>';
        const productTitle = '<%= product.title.replace(/'/g, "\\'") %>';

        try {
          const response = await fetch('/auth/cart/add', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ productId, platform: selectedPlatform, quantity: 1 })
          });

          const data = await response.json();
          if (data.success) {
            showToast(`${productTitle} (${selectedPlatform}) added to cart!`, "success");
            setTimeout(() => {
              window.location.href = '/auth/cart';
            }, 800);
          } else {
            showToast(data.message || "Failed to add item to cart.", "error");
          }
        } catch (err) {
          console.error("Error adding to cart:", err);
          showToast("Network error adding to cart.", "error");
        }
      });
    }
    if (addToCartBtn) {
      addToCartBtn.addEventListener('click', async function(e) {
        e.preventDefault();
        e.stopPropagation();
        if (!isLoggedIn) {
          showToast("You must sign-in to continue with the process.", "info");
          return;
        }

        const activeBtn = document.querySelector('.platform-btn.text-pixel-white');
        const selectedPlatform = activeBtn ? activeBtn.dataset.platform : 'PC';
        const productId = '<%= product._id %>';
        const productTitle = '<%= product.title.replace(/'/g, "\\'") %>';

        try {
          const response = await fetch('/auth/cart/add', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ productId, platform: selectedPlatform, quantity: 1 })
          });

          const data = await response.json();
          if (data.success) {
            showToast(`${productTitle} (${selectedPlatform}) added to cart!`, "success");
            setTimeout(() => {
              window.location.href = '/auth/cart';
            }, 800);
          } else {
            showToast(data.message || "Failed to add item to cart.", "error");
          }
        } catch (err) {
          console.error("Error adding to cart:", err);
          showToast("Network error adding to cart.", "error");
        }
      });
    }
  })();

  async function toggleWishlist(btn, productId, productTitle) {
    if (!isLoggedIn) {
      showToast("You must sign-in to continue with the process.", "info");
      return;
    }

    const isLive = await checkLiveStatus();
    if (!isLive) return;

    const activeBtn = document.querySelector('.platform-btn.text-pixel-white');
    const selectedPlatform = activeBtn ? activeBtn.dataset.platform : 'PC';

    try {
      const response = await fetch('/auth/wishlist/toggle', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ productId, platform: selectedPlatform })
      });
      
      if (response.status === 401) {
        window.location.href = '/auth/login';
        return;
      }

      const data = await response.json();
      if (data.success) {
        const svg = btn.querySelector('svg');
        if (svg) {
          if (data.added) {
            svg.setAttribute('fill', 'currentColor');
            svg.classList.remove('text-gray-400');
            svg.classList.add('fill-red-500', 'text-red-500');
            showToast(`${productTitle} (${selectedPlatform}) added to wishlist!`, "success");
            if (!wishlistPlatforms.includes(selectedPlatform.toLowerCase())) {
              wishlistPlatforms.push(selectedPlatform.toLowerCase());
            }
          } else {
            svg.setAttribute('fill', 'none');
            svg.classList.remove('fill-red-500', 'text-red-500');
            svg.classList.add('text-gray-400');
            showToast(`${productTitle} (${selectedPlatform}) removed from wishlist.`, "success");
            const idx = wishlistPlatforms.indexOf(selectedPlatform.toLowerCase());
            if (idx > -1) {
              wishlistPlatforms.splice(idx, 1);
            }
          }
        }
      } else {
        console.error('Error toggling wishlist:', data.message);
      }
    } catch (err) {
      console.error('Network error toggling wishlist:', err);
    }
  }

  // Magnifier Hover Zoom and Fullscreen Logic
  (function() {
    const mainPlayer = document.getElementById('mainMediaPlayer');
    const zoomBtn = document.getElementById('zoomBtn');
    const fullscreenBtn = document.getElementById('fullscreenBtn');
    const lens = document.getElementById('magnifierLens');

    if (!mainPlayer || !zoomBtn || !fullscreenBtn || !lens) return;

    let zoomActive = false;

    // Toggle zoom magnifier
    zoomBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (document.fullscreenElement) {
        // Not available in fullscreen
        return;
      }
      zoomActive = !zoomActive;
      updateZoomState();
    });

    function updateZoomState() {
      const icon = zoomBtn.querySelector('i');
      if (zoomActive) {
        zoomBtn.classList.remove('text-white');
        zoomBtn.classList.add('text-sky-400', 'border-sky-500');
        if (icon) {
          icon.classList.remove('fa-magnifying-glass-plus');
          icon.classList.add('fa-magnifying-glass-minus');
        }
      } else {
        zoomBtn.classList.remove('text-sky-400', 'border-sky-500');
        zoomBtn.classList.add('text-white');
        if (icon) {
          icon.classList.remove('fa-magnifying-glass-minus');
          icon.classList.add('fa-magnifying-glass-plus');
        }
        lens.style.display = 'none';
      }
    }

    // Fullscreen toggling
    fullscreenBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleFullscreen();
    });

    // Double-click to toggle fullscreen
    mainPlayer.addEventListener('dblclick', (e) => {
      // Don't trigger if clicked on buttons
      if (e.target.closest('#zoomBtn') || e.target.closest('#fullscreenBtn')) return;
      toggleFullscreen();
    });

    function toggleFullscreen() {
      if (!document.fullscreenElement) {
        mainPlayer.requestFullscreen().catch(err => {
          console.error('[Fullscreen error]', err);
        });
      } else {
        document.exitFullscreen();
      }
    }

    // Monitor fullscreen state
    document.addEventListener('fullscreenchange', () => {
      const icon = fullscreenBtn.querySelector('i');
      if (document.fullscreenElement === mainPlayer) {
        // Enforce zoom disabled in fullscreen
        zoomActive = false;
        updateZoomState();
        if (icon) {
          icon.classList.remove('fa-expand');
          icon.classList.add('fa-compress');
        }
      } else {
        if (icon) {
          icon.classList.remove('fa-compress');
          icon.classList.add('fa-expand');
        }
      }
    });

    // Magnifier calculation and movement
    function moveMagnifier(e) {
      const img = document.getElementById('mainMediaImage');
      if (!img || img.classList.contains('hidden')) {
        lens.style.display = 'none';
        return;
      }

      const rect = img.getBoundingClientRect();
      const playerRect = mainPlayer.getBoundingClientRect();

      // Relative coordinates inside the image
      let x = e.clientX - rect.left;
      let y = e.clientY - rect.top;

      // Prevent coordinates out of image bounds
      if (x < 0 || x > rect.width || y < 0 || y > rect.height) {
        lens.style.display = 'none';
        return;
      }

      lens.style.display = 'block';
      lens.style.backgroundImage = `url('${img.src}')`;

      const zoomFactor = 2.5;
      lens.style.backgroundSize = `${rect.width * zoomFactor}px ${rect.height * zoomFactor}px`;

      // Positioning the lens centered on mouse relative to mainMediaPlayer
      const lensX = (e.clientX - playerRect.left) - (lens.offsetWidth / 2);
      const lensY = (e.clientY - playerRect.top) - (lens.offsetHeight / 2);

      lens.style.left = `${lensX}px`;
      lens.style.top = `${lensY}px`;

      // Setting background positioning of magnified view
      const bgX = (x * zoomFactor) - (lens.offsetWidth / 2);
      const bgY = (y * zoomFactor) - (lens.offsetHeight / 2);

      lens.style.backgroundPosition = `-${bgX}px -${bgY}px`;
    }

    mainPlayer.addEventListener('mousemove', (e) => {
      if (!zoomActive || document.fullscreenElement) {
        lens.style.display = 'none';
        return;
      }
      moveMagnifier(e);
    });

    mainPlayer.addEventListener('mouseleave', () => {
      lens.style.display = 'none';
    });
  })();
</script>

