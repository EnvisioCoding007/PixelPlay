                <header class="flex flex-col items-start gap-2 relative self-stretch w-full flex-[0_0_auto]">
                    <div class="flex items-center justify-between gap-4 relative self-stretch w-full flex-[0_0_auto]">
                        <div class="inline-flex flex-col items-start relative flex-[0_0_auto]">
                            <h1 id="terminal-form-title"
                                class="mt-[-1.00px] [font-family:'Inter-Bold',Helvetica] font-bold text-[#e6f7fb] text-2xl relative flex items-center w-fit tracking-[0] leading-[normal]">
                                Update Terminal: Home</h1>
                        </div>
                        <div class="inline-flex gap-1.5 px-3 py-1.5 flex-[0_0_auto] bg-[#0ea5e926] rounded-full border-[#0ea5e94c] shadow-[0px_0px_12px_#0ea5e933] items-center relative border border-solid"
                            aria-label="Current Default">
                            <img class="relative w-3.5 h-3.5" src="img/container-2.svg" alt="" aria-hidden="true" />
                            <span
                                class="[font-family:'Inter-SemiBold',Helvetica] font-semibold text-sky-500 text-xs relative flex items-center w-fit tracking-[0] leading-[normal]">Current
                                Default</span>
                        </div>
                    </div>
                    <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                        <p
                            class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'Inter-Regular',Helvetica] font-normal text-[#9aa6ab] text-sm tracking-[0] leading-[normal]">
                            Review and modify the parameters for your physical delivery address.</p>
                    </div>
                </header>
                <fieldset
