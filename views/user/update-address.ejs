                            <img class="absolute top-[13px] left-3.5 w-[18px] h-[18px] pointer-events-none"
                                src="img/container.svg" alt="" aria-hidden="true" />
                        </div>
                    </div>
                    <div class="relative md:row-[4_/_5] md:col-[1_/_3] w-full h-fit flex flex-col items-start gap-2">
                        <label for="secondary-coordinates"
