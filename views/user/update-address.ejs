</head>

<body>
    <main class="flex flex-col min-h-[812px] items-start relative bg-zinc-950">
        <section class="flex items-center justify-center px-10 py-12 relative self-stretch w-full flex-[0_0_auto]">
            <form
                class="flex flex-col max-w-[680px] w-full items-start gap-5 p-10 relative bg-[#18181b80] rounded-xl border border-solid border-[#0ea5e933] shadow-[0px_0px_32px_#0ea5e90d] backdrop-blur-[6px] backdrop-brightness-[100%] [-webkit-backdrop-filter:blur(6px)_brightness(100%)]"
