                            <input class="sr-only" type="radio" name="terminal-type" value="home" checked />
                            <div class="absolute w-full top-0 left-0 h-[42px] bg-[#ffffff01] rounded-md shadow-[0px_0px_18px_#0ea5e91f,inset_0px_0px_0px_2px_#0ea5e91a]"
                                aria-hidden="true"></div>
                            <div class="inline-flex flex-col items-start relative flex-[0_0_auto]">
                                <div class="relative w-4 h-4">
                                    <div class="relative w-[75.00%] h-[79.17%] top-[8.33%] left-[12.50%]">
