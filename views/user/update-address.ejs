                            <span
                                class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'Inter-SemiBold',Helvetica] font-semibold text-[#9aa6ab] text-[13px] tracking-[0] leading-[normal]">Secure
                                Comm Link</span>
                        </label>
                        <div class="flex items-center justify-center relative self-stretch w-full flex-[0_0_auto]">
                            <input id="secure-comm-link" name="secure-comm-link" type="tel" value="+1 (555) 019-2834"
                                class="h-11 items-center px-10 py-0 flex-1 grow bg-[#0f1113] rounded-md overflow-hidden border border-solid border-[#00000014] flex relative [font-family:'Inter-Regular',Helvetica] font-normal text-[#e6f7fb] text-sm tracking-[0] leading-[normal] outline-none" />
                            <div
                                class="inline-flex items-center justify-center absolute top-[13px] left-3.5 pointer-events-none">
                                <div class="inline-flex flex-col items-start relative flex-[0_0_auto]">
