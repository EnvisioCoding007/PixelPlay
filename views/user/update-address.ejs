                                class="relative flex items-center justify-center w-fit [font-family:'Inter-Medium',Helvetica] font-medium text-[#9aa6ab] text-sm text-center tracking-[0] leading-[normal]">Office</span>
                        </label>
                        <label
                            class="relative row-[1_/_2] col-[3_/_4] w-full h-[42px] flex items-center justify-center gap-2 rounded-md cursor-pointer">
                            <input class="sr-only" type="radio" name="terminal-type" value="other" />
                            <img class="relative flex-[0_0_auto]" src="img/iconify-icon-2.svg" alt=""
