<!DOCTYPE html>
<html lang="en">

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta charset="utf-8" />
    <title>PixelPlay - Game Store Showcase</title>
    <link rel="stylesheet" href="globals.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        /** @type {import('tailwindcss').Config} */
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            DEFAULT: '#00A3FF',
                            dark: '#0082CC',
                            light: '#33B5FF',
                        },
                        legend: {
                            DEFAULT: '#FFB800',
                            dark: '#CC9300',
                            light: '#FFC633',
                        }
                    }
                },
            },
            plugins: [],
        }
    </script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
    <style>
        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }
        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>

<body class="bg-zinc-950 text-white min-h-screen flex flex-col">
    <% 
      const showDelivery = (typeof user !== 'undefined' && user && user.addresses && user.addresses.some(addr => addr.postal_code));
    %>
    <%- include('../partials/user/navbar', { activeTab: 'home' , user: user }) %>

        <main class="flex flex-col w-full items-center gap-12 pt-8 pb-16 relative">
            <!-- Segment 1: Latest Release, Categories, and Latest & Popular Games -->
            <div class="max-w-[95%] mx-auto px-4 sm:px-6 lg:px-8 w-full">
                <section class="flex h-[480px] items-end relative self-stretch w-full rounded-xl overflow-hidden"
                    aria-labelledby="featured-release-title">
                    <% if (typeof latestRelease !== 'undefined' && latestRelease) { %>
                        <div class="absolute w-full h-full top-0 left-0 bg-cover bg-[50%_50%]"
                            style="background-image: url('<%= latestRelease.coverImageUrl || latestRelease.cover_image %>');"
                            aria-hidden="true"></div>
                    <% } else { %>
                        <div class="absolute w-full h-full top-0 left-0 bg-[url('/img/games/neon_override_hero.png')] bg-cover bg-[50%_50%]"
                            aria-hidden="true"></div>
                    <% } %>
                    <div class="absolute w-full h-full top-0 left-0 [background:linear-gradient(90deg,rgba(9,9,11,0.95)_0%,rgba(9,9,11,0.4)_50%,rgba(9,9,11,0)_100%),linear-gradient(0deg,rgba(9,9,11,0.95)_0%,rgba(9,9,11,0)_40%)]"
                        aria-hidden="true"></div>
                    <div
                        class="inline-flex flex-col max-w-[600px] items-start gap-[15.1px] p-12 relative flex-[0_0_auto] z-[1]">
                        <div
                            class="inline-flex items-center gap-1.5 px-3 py-1.5 relative flex-[0_0_auto] bg-sky-500 rounded-full">
                            <div class="flex w-3.5 h-3.5 items-center justify-center relative" aria-hidden="true">
                                <div class="inline-flex flex-col items-start relative flex-[0_0_auto]">
                                    <div class="relative w-3.5 h-3.5">
                                        <img class="absolute w-[91.68%] h-[95.85%] top-[4.15%] left-[8.32%]"
                                            src="img/vector-4.svg" alt="" />
                                    </div>
                                </div>
                            </div>
                            <p
                                class="flex items-center mt-[-1.00px] [font-family:'Inter-Bold',Helvetica] font-bold text-[#061323] text-xs tracking-[0.50px] leading-[normal] relative w-fit">
                                LATEST RELEASE</p>
                        </div>
                        <div
                            class="pt-[3.9px] pb-[0.8px] px-0 self-stretch w-full flex-[0_0_auto] flex flex-col items-start relative">
                            <h1 id="featured-release-title"
                                class="flex items-center mt-[-1.00px] [text-shadow:0px_2px_12px_#00000080] [font-family:'Inter-ExtraBold',Helvetica] font-extrabold text-white text-5xl tracking-[0] leading-[52.8px] whitespace-nowrap relative w-fit">
                                <%= typeof latestRelease !== 'undefined' && latestRelease ? latestRelease.title : 'Neon Override 2077' %></h1>
                        </div>
                        <div
                            class="flex flex-col items-start pt-0 pb-[0.69px] px-0 relative self-stretch w-full flex-[0_0_auto]">
                            <p
                                class="mt-[-1.00px] [font-family:'Inter-Regular',Helvetica] font-normal text-[#9aa6b3] text-base tracking-[0] leading-[25.6px] relative w-fit">
                                <%= typeof latestRelease !== 'undefined' && latestRelease ? latestRelease.description : 'Dive into a relentless, neon-drenched metropolis where corporate syndicates rule and rogue AI dictate the streets. Reclaim the override key before the system purges.' %></p>
                        </div>
                        <div
                            class="flex items-center gap-4 pt-[16.9px] pb-0 px-0 relative self-stretch w-full flex-[0_0_auto]">
                            <% if (typeof latestRelease !== 'undefined' && latestRelease) { %>
                                <% if (typeof user !=='undefined' && user) { %>
                                    <button type="button"
                                        onclick="window.location.href='/products/<%= latestRelease._id %>'"
                                        class="all-[unset] box-border px-8 py-0 bg-sky-500 shadow-[0px_0px_24px_#0ea5e94c] inline-flex h-12 items-center justify-center gap-2 relative flex-[0_0_auto] rounded-md cursor-pointer"
                                        aria-label="Buy <%= latestRelease.title %> now">
                                        <div class="inline-flex flex-col items-start relative flex-[0_0_auto]"
                                            aria-hidden="true">
                                            <!-- <div class="relative w-[18px] h-[18px]">
                                                <img class="absolute w-[83.33%] h-[91.67%] top-[8.33%] left-[16.67%]"
                                                    src="icons/bag-icon.svg" alt="" />
                                            </div> -->
                                        </div>
                                        <span
                                            class="relative flex items-center justify-center w-fit [font-family:'Alegreya_Sans-Bold',Helvetica] font-bold text-[#061323] text-base text-center tracking-[0] leading-[normal] whitespace-nowrap">Buy
                                            Now</span>
                                    </button>
                                <% } else { %>
                                    <a href="/auth/login"
                                        class="all-[unset] box-border px-8 py-0 bg-sky-500 shadow-[0px_0px_24px_#0ea5e94c] inline-flex h-12 items-center justify-center gap-2 relative flex-[0_0_auto] rounded-md cursor-pointer"
                                        aria-label="Sign in to purchase <%= latestRelease.title %>">
                                        <div class="inline-flex flex-col items-start relative flex-[0_0_auto]"
                                            aria-hidden="true">
                                            <!-- <div class="relative w-[18px] h-[18px]">
                                                <img class="absolute w-[83.33%] h-[91.67%] top-[8.33%] left-[16.67%]"
                                                    src="img/vector-2.svg" alt="" />
                                            </div> -->
                                        </div>
                                        <span
                                            class="relative flex items-center justify-center w-fit [font-family:'Alegreya_Sans-Bold',Helvetica] font-bold text-[#061323] text-base text-center tracking-[0] leading-[normal] whitespace-nowrap">Sign
                                            In to Purchase</span>
                                    </a>
                                <% } %>
                                <button type="button"
                                    onclick="window.location.href='/products/<%= latestRelease._id %>'"
                                    class="all-[unset] box-border px-6 py-0 bg-[#ffffff1a] border border-solid border-[#ffffff33] backdrop-blur-sm backdrop-brightness-[100%] [-webkit-backdrop-filter:blur(4px)_brightness(100%)] inline-flex h-12 items-center justify-center gap-2 relative flex-[0_0_auto] rounded-md cursor-pointer"
                                    aria-label="View details for <%= latestRelease.title %>">
                                    <div class="inline-flex flex-col items-start relative flex-[0_0_auto]"
                                        aria-hidden="true">
                                        <!-- <div class="relative w-[18px] h-[18px]">
                                            <div
                                                class="relative w-[83.33%] h-[83.33%] top-[8.33%] left-[8.33%]">
                                                <img class="absolute w-[105.00%] h-[105.00%] top-[-5.00%] left-[-5.00%]"
                                                    src="icons/information-icon.svg" alt="" />
                                                <img class="absolute w-[55.00%] h-[75.00%] top-[25.00%] left-[45.00%]"
                                                    src="icons/information-icon.svg" alt="" />
                                            </div>
                                        </div> -->
                                    </div>
                                    <span
                                        class="relative flex items-center justify-center w-fit [font-family:'Alegreya_Sans-Bold',Helvetica] font-bold text-white text-base text-center tracking-[0] leading-[normal] whitespace-nowrap">View
                                        Details</span>
                                </button>
                            <% } else { %>
                                <% if (typeof user !=='undefined' && user) { %>
                                    <button type="button"
                                        class="all-[unset] box-border px-8 py-0 bg-sky-500 shadow-[0px_0px_24px_#0ea5e94c] inline-flex h-12 items-center justify-center gap-2 relative flex-[0_0_auto] rounded-md cursor-pointer"
                                        aria-label="Buy Neon Override 2077 now">
                                        <div class="inline-flex flex-col items-start relative flex-[0_0_auto]"
                                            aria-hidden="true">
                                            <div class="relative w-[18px] h-[18px]">
                                                <img class="absolute w-[83.33%] h-[91.67%] top-[8.33%] left-[16.67%]"
                                                    src="icons/bag-icon.svg" alt="" />
                                            </div>
                                        </div>
                                        <span
                                            class="relative flex items-center justify-center w-fit [font-family:'Alegreya_Sans-Bold',Helvetica] font-bold text-[#061323] text-base text-center tracking-[0] leading-[normal] whitespace-nowrap">Buy
                                            Now</span>
                                    </button>
                                <% } else { %>
                                    <a href="/auth/login"
                                        class="all-[unset] box-border px-8 py-0 bg-sky-500 shadow-[0px_0px_24px_#0ea5e94c] inline-flex h-12 items-center justify-center gap-2 relative flex-[0_0_auto] rounded-md cursor-pointer"
                                        aria-label="Sign in to purchase Neon Override 2077">
                                        <div class="inline-flex flex-col items-start relative flex-[0_0_auto]"
                                            aria-hidden="true">
                                            <div class="relative w-[18px] h-[18px]">
                                                <img class="absolute w-[83.33%] h-[91.67%] top-[8.33%] left-[16.67%]"
                                                    src="img/vector-2.svg" alt="" />
                                            </div>
                                        </div>
                                        <span
                                            class="relative flex items-center justify-center w-fit [font-family:'Alegreya_Sans-Bold',Helvetica] font-bold text-[#061323] text-base text-center tracking-[0] leading-[normal] whitespace-nowrap">Sign
                                            In to Purchase</span>
                                    </a>
                                <% } %>
                                <button type="button"
                                    class="all-[unset] box-border px-6 py-0 bg-[#ffffff1a] border border-solid border-[#ffffff33] backdrop-blur-sm backdrop-brightness-[100%] [-webkit-backdrop-filter:blur(4px)_brightness(100%)] inline-flex h-12 items-center justify-center gap-2 relative flex-[0_0_auto] rounded-md cursor-pointer"
                                    aria-label="View details for Neon Override 2077">
                                    <div class="inline-flex flex-col items-start relative flex-[0_0_auto]"
                                        aria-hidden="true">
                                        <div class="relative w-[18px] h-[18px]">
                                            <div
                                                class="relative w-[83.33%] h-[83.33%] top-[8.33%] left-[8.33%]">
                                                <img class="absolute w-[105.00%] h-[105.00%] top-[-5.00%] left-[-5.00%]"
                                                    src="icons/information-icon.svg" alt="" />
                                                <img class="absolute w-[55.00%] h-[75.00%] top-[25.00%] left-[45.00%]"
                                                    src="icons/information-icon.svg" alt="" />
                                            </div>
                                        </div>
                                    </div>
                                    <span
                                        class="relative flex items-center justify-center w-fit [font-family:'Alegreya_Sans-Bold',Helvetica] font-bold text-white text-base text-center tracking-[0] leading-[normal] whitespace-nowrap">View
                                        Details</span>
                                </button>
                            <% } %>
                        </div>
                    </div>
                    <div class="inline-flex items-start gap-2 absolute right-12 bottom-6 z-[1]" role="tablist"
                        aria-label="Featured release slides">
                        <button type="button"
                            class="relative w-8 h-1 bg-sky-500 rounded-sm shadow-[0px_0px_8px_#0ea5e980] cursor-pointer"
                            role="tab" aria-selected="true" aria-label="Go to slide 1"></button>
                        <button type="button" class="relative w-8 h-1 bg-[#ffffff33] rounded-sm cursor-pointer"
                            role="tab" aria-selected="false" aria-label="Go to slide 2"></button>
                        <button type="button" class="relative w-8 h-1 bg-[#ffffff33] rounded-sm cursor-pointer"
                            role="tab" aria-selected="false" aria-label="Go to slide 3"></button>
                        <button type="button" class="relative w-8 h-1 bg-[#ffffff33] rounded-sm cursor-pointer"
                            role="tab" aria-selected="false" aria-label="Go to slide 4"></button>
                    </div>
                </section>
                <section
                    class="flex flex-col items-start gap-6 pt-8 pb-0 px-0 relative self-stretch w-full flex-[0_0_auto]"
                    aria-labelledby="browse-categories-title">
                    <div class="flex items-end relative self-stretch w-full flex-[0_0_auto]">
                        <div class="flex-1 grow flex flex-col items-start relative">
                            <h2 id="browse-categories-title"
                                class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'Inter-Bold',Helvetica] font-bold text-[#e6eef6] text-2xl tracking-[0] leading-[normal]">
                                Browse by Category</h2>
                        </div>
                    </div>
                    
                    <div class="relative w-full group">
                        <!-- Left button -->
                        <button type="button" id="cat-prev-btn" class="absolute left-[-20px] top-1/2 -translate-y-1/2 z-10 bg-[#0f1113]/90 hover:bg-[#121214] border border-solid border-[#ffffff20] text-sky-500 rounded-full w-10 h-10 flex items-center justify-center shadow-lg transition-all opacity-0 group-hover:opacity-100 focus:opacity-100 cursor-pointer">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
                        </button>

                        <!-- Carousel scroll container -->
                        <div id="cat-carousel" class="flex gap-4 overflow-x-auto scroll-smooth scrollbar-hide py-2 px-1">
                            <% if (typeof categories !== 'undefined' && categories && categories.length > 0) { %>
                                <% categories.forEach(cat => { %>
                                    <div onclick="window.location.href='/browse?genre=<%= encodeURIComponent(cat.name) %>'" class="flex flex-col min-w-[150px] max-w-[180px] items-center gap-3 px-4 py-6 bg-[#0f1113] rounded-lg border border-solid border-[#ffffff10] hover:border-sky-500/50 hover:bg-[#121214] transition-all flex-shrink-0 cursor-pointer">
                                        <div class="flex w-12 h-12 items-center justify-center relative bg-[#121214] rounded-3xl overflow-hidden border border-solid border-[#ffffff05]">
                                            <% if (cat.icon) { %>
                                                <img class="w-8 h-8 object-cover" src="<%= cat.icon %>" alt="<%= cat.name %> Icon" />
                                            <% } else { %>
                                                <img class="w-6 h-6 object-contain" src="icons/game-controller-icon.svg" alt="Default Icon" />
                                            <% } %>
                                        </div>
                                        <p class="font-semibold text-[#e6eef6] text-sm text-center truncate w-full">
                                            <%= cat.name %>
                                        </p>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <p class="text-zinc-500 text-sm py-4">No active categories found.</p>
                            <% } %>
                        </div>

                        <!-- Right button -->
                        <button type="button" id="cat-next-btn" class="absolute right-[-20px] top-1/2 -translate-y-1/2 z-10 bg-[#0f1113]/90 hover:bg-[#121214] border border-solid border-[#ffffff20] text-sky-500 rounded-full w-10 h-10 flex items-center justify-center shadow-lg transition-all opacity-0 group-hover:opacity-100 focus:opacity-100 cursor-pointer">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                        </button>
                    </div>
                </section>
                <section class="flex flex-col items-start gap-5 relative self-stretch w-full"
                    aria-labelledby="latest-popular-games-title">
                    <div class="flex items-center justify-between relative self-stretch w-full flex-[0_0_auto]">
                        <div class="inline-flex items-center gap-2.5 relative flex-[0_0_auto]">
                            <div class="relative w-1 h-[18px] bg-sky-500 rounded" aria-hidden="true"></div>
                            <h2 id="latest-popular-games-title"
                                class="flex items-center mt-[-1.00px] [font-family:'Inter-Bold',Helvetica] font-bold text-zinc-100 text-lg tracking-[0.90px] leading-[normal] whitespace-nowrap relative w-fit">
                                LATEST &amp; POPULAR GAMES</h2>
                        </div>
                        <a href="/browse?vault=standard" class="inline-flex items-center gap-1 relative flex-[0_0_auto]"
                            aria-label="View all latest and popular games">
                            <span
                                class="flex items-center mt-[-1.00px] [font-family:'Inter-Bold',Helvetica] font-bold text-sky-500 text-xs tracking-[0.60px] leading-[normal] relative w-fit">VIEW
                                ALL</span>
                            <span class="inline-flex flex-col items-start relative flex-[0_0_auto]" aria-hidden="true">
                                <span class="relative w-3 h-3">
                                    <img class="absolute w-[83.33%] h-[83.33%] top-[16.67%] left-[16.67%]"
                                        src="img/vector-8.svg" alt="" />
                                </span>
                            </span>
                        </a>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6 self-stretch h-fit">
                        <% if (typeof standardGames !== 'undefined' && standardGames && standardGames.length > 0) { %>
                            <% standardGames.slice(0, 4).forEach(game => { %>
                                <article onclick="window.location.href='/products/<%= game._id %>'" class="relative w-full h-[380px] flex flex-col items-start bg-[#121215] rounded-lg overflow-hidden border border-solid border-[#0ea5e94c] shadow-[0px_4px_20px_#0ea5e90d] cursor-pointer hover:border-sky-500 transition-colors">
                                    <div class="flex flex-col h-[180px] items-start justify-center relative self-stretch w-full z-[1] bg-[#1a1a1f]">
                                        <div class="relative flex-1 self-stretch w-full grow bg-cover bg-[50%_50%]"
                                             style="background-image: url('<%= game.coverImageUrl || game.cover_image %>');"
                                             role="img" aria-label="<%= game.title %> cover art"></div>
                                    </div>
                                    <div class="flex flex-col items-start justify-between p-4 relative flex-1 self-stretch w-full grow z-0">
                                        <div class="flex flex-col items-start pt-0 pb-1.5 px-0 self-stretch w-full relative flex-[0_0_auto]">
                                            <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                                <h2 class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'Inter-Bold',Helvetica] font-bold text-white text-[15px] tracking-[0] leading-[19.5px] truncate">
                                                    <%= game.title %>
                                                </h2>
                                            </div>
                                        </div>
                                        <div class="flex flex-col items-start pt-0 pb-3 px-0 relative self-stretch w-full flex-[0_0_auto]">
                                            <div class="flex flex-col gap-0.5 text-zinc-400 text-[11px] leading-[normal] w-full">
                                                <div><span class="text-zinc-500">Category:</span> <%= game.categoryName %></div>
                                                <div><span class="text-zinc-500">Publisher:</span> <%= game.publisher %></div>
                                                <div class="truncate"><span class="text-zinc-500">Platforms:</span> <%= (game.platforms && game.platforms.length > 0) ? game.platforms.join(', ') : 'PC' %></div>
                                            </div>
                                        </div>
                                        <div class="flex flex-col min-h-[45px] items-start justify-end pt-[69.5px] pb-0 px-0 relative flex-1 self-stretch w-full grow">
                                            <div class="flex items-center justify-between pt-3 pb-0 px-0 relative self-stretch w-full flex-[0_0_auto] mt-[-0.50px] border-t [border-top-style:solid] border-[#00000014]">
                                                <div class="inline-flex flex-col items-start relative flex-[0_0_auto]">
                                                    <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                                        <p class="mt-[-1.00px] [font-family:'Inter-Regular',Helvetica] font-normal text-zinc-400 text-[10px] tracking-[0] whitespace-nowrap relative flex items-center w-fit leading-[normal]">
                                                            <% if (game.categoryDiscount > 0) { %>
                                                                <span class="line-through">₹<%= Number(game.price).toFixed(2) %></span>
                                                            <% } else { %>
                                                                &nbsp;
                                                            <% } %>
                                                        </p>
                                                    </div>
                                                    <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                                        <p class="mt-[-1.00px] [font-family:'Inter-ExtraBold',Helvetica] font-extrabold text-sky-500 text-base tracking-[0] leading-[normal] relative flex items-center w-fit leading-[normal]">
                                                            ₹<%= Number(game.discountedPrice).toFixed(2) %>
                                                        </p>
                                                    </div>
                                                </div>
                                                
                                                <div class="flex gap-2 items-center" onclick="event.stopPropagation();">
                                                    <% if (game.edition_type === 'LEGENDARY') { %>
                                                      <button type="button" onclick="handleCartClick(this, '<%= game._id %>', '<%= game.title.replace(/'/g, "\\'") %>', '<%= (game.platforms && game.platforms.length > 0) ? game.platforms[0] : 'PC' %>')" class="bg-legend hover:bg-legend-light text-[#151515] p-2 rounded transition-colors shadow-[0_0_10px_rgba(255,184,0,0.3)] cursor-pointer">
                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                                                      </button>
                                                    <% } else { %>
                                                      <button type="button" onclick="handleCartClick(this, '<%= game._id %>', '<%= game.title.replace(/'/g, "\\'") %>', '<%= (game.platforms && game.platforms.length > 0) ? game.platforms[0] : 'PC' %>')" class="bg-brand hover:bg-brand-light text-white p-2 rounded transition-colors shadow-[0_0_10px_rgba(0,163,255,0.2)] cursor-pointer">
                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                                                      </button>
                                                    <% } %>
                                                    <button type="button" onclick="toggleWishlist(this, '<%= game._id %>', '<%= game.title.replace(/'/g, "\\'") %>')" class="bg-[#222222] hover:bg-[#333333] border border-[#333] p-2 rounded transition-colors cursor-pointer">
                                                      <svg class="w-4 h-4 <%= (typeof userWishlist !== 'undefined' && userWishlist.includes(game._id.toString())) ? 'fill-red-500 text-red-500' : 'text-gray-400' %>" fill="<%= (typeof userWishlist !== 'undefined' && userWishlist.includes(game._id.toString())) ? 'currentColor' : 'none' %>" stroke="currentColor" viewbox="0 0 24 24"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            <% }) %>
                        <% } else { %>
                            <div class="col-span-full py-16 text-center text-zinc-500">
