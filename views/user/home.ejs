        <script>
            // Authentication state
            const isLoggedIn = <%= typeof user !== 'undefined' && user ? 'true' : 'false' %>;

            // Toast notifications
            function showToast(message, type = 'info') {
              let container = document.getElementById('toast-container');
              if (!container) {
                container = document.createElement('div');
                container.id = 'toast-container';
                container.className = 'fixed top-6 right-6 z-[9999] flex flex-col gap-3 pointer-events-none';
                document.body.appendChild(container);
              }
              
              const toast = document.createElement('div');
              toast.className = `flex items-center gap-3 px-5 py-3 rounded-lg shadow-2xl text-sm font-semibold border transition-all duration-500 ease-out transform translate-x-full opacity-0 pointer-events-auto max-w-sm bg-[#13161b] text-white ${
                type === 'success' 
                  ? 'border-emerald-500 text-emerald-400' 
                  : type === 'error' 
                    ? 'border-red-500 text-red-400' 
                    : 'border-[#00D1FF] text-[#00D1FF]'
              }`;
              
              let icon = '<i class="fa-solid fa-circle-info"></i>';
              if (type === 'success') icon = '<i class="fa-solid fa-circle-check"></i>';
              if (type === 'error') icon = '<i class="fa-solid fa-circle-exclamation"></i>';
              
              toast.innerHTML = `${icon} <span>${message}</span>`;
              container.appendChild(toast);
              
              setTimeout(() => {
                toast.classList.remove('translate-x-full', 'opacity-0');
              }, 10);
              
              setTimeout(() => {
                toast.classList.add('translate-x-full', 'opacity-0');
                setTimeout(() => {
                  toast.remove();
                }, 500);
              }, 3000);
            }

            // Cart Actions
            async function handleCartClick(btn, productId, productTitle, defaultPlatform) {
              if (!isLoggedIn) {
                showToast("You must sign-in to continue with the process.", "info");
                return;
              }
              try {
                const response = await fetch('/auth/cart/add', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json'
                  },
                  body: JSON.stringify({ productId, platform: defaultPlatform, quantity: 1 })
                });
                const data = await response.json();
                if (data.success) {
                  showToast(`${productTitle} (${defaultPlatform}) added to cart!`, "success");
                  setTimeout(() => {
                    window.location.href = '/auth/cart';
                  }, 800);
                } else {
                  showToast(data.message || "Failed to add item to cart.", "error");
                }
              } catch (err) {
                console.error("Error adding to cart:", err);
                showToast("Network error adding to cart.", "error");
              }
            }

            // Wishlist Actions
            async function toggleWishlist(btn, productId, productTitle) {
              if (!isLoggedIn) {
                showToast("You must sign-in to continue with the process.", "info");
                return;
              }

              try {
                const response = await fetch('/auth/wishlist/toggle', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json'
                  },
                  body: JSON.stringify({ productId })
                });
                
                if (response.status === 401) {
                  window.location.href = '/auth/login';
                  return;
                }

                const data = await response.json();
                if (data.success) {
                  const svg = btn.querySelector('svg');
                  if (svg) {
                    if (data.added) {
                      svg.setAttribute('fill', 'currentColor');
                      svg.classList.remove('text-gray-400');
                      svg.classList.add('fill-red-500', 'text-red-500');
                      showToast(`${productTitle} added to wishlist!`, "success");
                    } else {
                      svg.setAttribute('fill', 'none');
                      svg.classList.remove('fill-red-500', 'text-red-500');
                      svg.classList.add('text-gray-400');
                      showToast(`${productTitle} removed from wishlist.`, "success");
                    }
                  }
                } else {
                  console.error('Error toggling wishlist:', data.message);
                }
              } catch (err) {
                console.error('Network error toggling wishlist:', err);
              }
            }

            // Category Carousel Navigation
            const catCarousel = document.getElementById('cat-carousel');
            const catPrevBtn = document.getElementById('cat-prev-btn');
            const catNextBtn = document.getElementById('cat-next-btn');
            if (catCarousel && catPrevBtn && catNextBtn) {
                catPrevBtn.addEventListener('click', () => {
                    catCarousel.scrollLeft -= 250;
                });
                catNextBtn.addEventListener('click', () => {
                    catCarousel.scrollLeft += 250;
                });
            }

            // Inline publishers Spotlight expand logic
            const viewAllPublishersBtn = document.getElementById('viewAllPublishersBtn');
            if (viewAllPublishersBtn) {
                viewAllPublishersBtn.addEventListener('click', () => {
                    const extraCards = document.querySelectorAll('.publisher-extra-card');
                    extraCards.forEach(card => card.classList.remove('hidden'));
                    viewAllPublishersBtn.classList.add('hidden');
                });
            }
        </script>
</body>

</html>