<!DOCTYPE html>
<html lang="en">

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta charset="utf-8" />
    <title>Forgot Password - CODEX ARC</title>
    <link rel="stylesheet" href="/globals.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        /** @type {import('tailwindcss').Config} */
        tailwind.config = {
            theme: {
                extend: {
                },
            },
            plugins: [],
        }
    </script>
</head>

<body>
    <main
        class="flex flex-col min-h-[1024px] items-start relative [background:linear-gradient(0deg,rgba(19,19,21,1)_0%,rgba(19,19,21,1)_100%),linear-gradient(0deg,rgba(255,255,255,1)_0%,rgba(255,255,255,1)_100%)]">
        <div class="flex flex-col w-full h-full items-start justify-center absolute top-0 left-0" aria-hidden="true">
            <img class="relative flex-1 self-stretch w-full grow object-cover" src="/img/image.png" alt="" />
            <div
                class="absolute w-full h-full top-0 left-0 bg-[#131315b2] backdrop-blur-[6px] backdrop-brightness-[100%] [-webkit-backdrop-filter:blur(6px)_brightness(100%)]">
            </div>
        </div>
        <div
            class="flex max-w-[1440px] w-full mx-auto items-center justify-center pt-[266.7px] pb-[266.72px] px-10 relative flex-[0_0_auto]">
            <section
                class="flex flex-col max-w-[480px] w-full items-start gap-8 p-8 relative bg-[#201f22cc] rounded-lg overflow-hidden border border-solid border-[#3b494b] shadow-[0px_10px_40px_#000000cc] backdrop-blur-[6px] backdrop-brightness-[100%] [-webkit-backdrop-filter:blur(6px)_brightness(100%)]"
                aria-labelledby="forgot-password-title">
                <header class="flex flex-col items-start pt-2 pb-0 px-0 relative self-stretch w-full flex-[0_0_auto]">
                    <div class="flex flex-col items-start gap-4 relative self-stretch w-full flex-[0_0_auto]">
                        <div
                            class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto] shadow-[0px_0px_8px_#00f0ff80]">
                            <div
                                class="relative flex items-center w-[155.47px] h-[39px] mt-[-1.00px] [font-family:'Space_Grotesk-Bold',Helvetica] font-bold text-[#00f0ff] text-[32px] tracking-[-1.60px] leading-[38.4px] whitespace-nowrap">
                                PixelPlay</div>
                        </div>
                        <div class="flex flex-col items-start gap-2 relative self-stretch w-full flex-[0_0_auto]">
                            <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                <h1 id="forgot-password-title"
                                    class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'Space_Grotesk-Medium',Helvetica] font-medium text-[#e5e1e4] text-2xl tracking-[0] leading-[31.2px]">
                                    Forgot Password</h1>
                            </div>
                            <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                <p
                                    class="relative self-stretch mt-[-1.00px] [font-family:'Inter-Regular',Helvetica] font-normal text-[#b9cacb] text-base tracking-[0] leading-6">
                                    Enter your email address and we will send you a link to<br />reset your password.
                                </p>
                            </div>
                        </div>
                    </div>
                </header>
                <div class="pt-0 pb-4 px-0 flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                    <div id="alert-message"
                        class="hidden w-full mb-4 px-4 py-3 rounded relative text-center text-sm font-medium"></div>

                    <form id="forgot-password-form"
                        class="gap-6 flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]" action="#"
                        method="post">
                        <div
                            class="flex flex-col items-start gap-2 relative self-stretch w-full flex-[0_0_auto] rounded-sm">
                            <div class="flex items-center gap-2 relative self-stretch w-full flex-[0_0_auto]">
                                <div class="inline-flex flex-col items-start relative flex-[0_0_auto]"
                                    aria-hidden="true">
                                    <img class="relative w-[11.67px] h-[11.67px]" src="/img/image.svg" alt="" />
                                </div>
                                <label
                                    class="w-[104.73px] mt-[-1.00px] text-[#c8c5ca] tracking-[1.20px] relative flex items-center h-3 [font-family:'Space_Grotesk-Bold',Helvetica] font-bold text-xs leading-3 whitespace-nowrap"
                                    for="input-1">EMAIL ADDRESS</label>
                            </div>
                            <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                <div
                                    class="flex items-start justify-center pl-10 pr-4 pt-3.5 pb-[13px] relative self-stretch w-full flex-[0_0_auto] bg-[#131315] rounded-sm overflow-hidden border border-solid border-[#3b494b]">
                                    <input
                                        class="relative grow border-[none] [background:none] self-stretch mt-[-1.00px] [font-family:'Space_Grotesk-Regular',Helvetica] font-normal text-[#c8c5ca] text-base tracking-[1.60px] leading-[normal] p-0 outline-none"
                                        placeholder="operator@codex.arc" type="email" id="input-1" name="email"
                                        autocomplete="email" inputmode="email" required aria-required="true" />
                                </div>
                                <div class="inline-flex h-full items-center pl-3 pr-0 py-0 absolute top-0 left-0 pointer-events-none"
                                    aria-hidden="true">
                                    <div class="inline-flex flex-col items-start relative flex-[0_0_auto]">
                                        <img class="relative w-5 h-4" src="/img/icon-2.svg" alt="" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <button type="submit" id="submit-btn"
                            class="flex items-center justify-center gap-2 px-0 py-4 relative self-stretch w-full flex-[0_0_auto] bg-[#00f0ff] hover:bg-[#00c8d4] transition-colors rounded-sm overflow-hidden">
                            <span class="inline-flex flex-col items-center relative flex-[0_0_auto]" aria-hidden="true">
                                <img class="relative w-[12.98px] h-[13.5px]" src="/img/icon.svg" alt="" />
                            </span>
                            <span
                                class="justify-center w-[132.13px] mt-[-0.25px] text-[#006970] text-center tracking-[2.40px] relative flex items-center h-3 [font-family:'Space_Grotesk-Bold',Helvetica] font-bold text-xs leading-3 whitespace-nowrap">SEND
                                RESET LINK</span>
                        </button>
                    </form>
                </div>
                <footer class="flex flex-col items-start pt-2 pb-0 px-0 relative self-stretch w-full flex-[0_0_auto]">
                    <div
                        class="flex items-center justify-center pt-6 pb-0 px-0 relative self-stretch w-full flex-[0_0_auto] border-t [border-top-style:solid] border-[#3b494b4c]">
                        <a href="/auth/login"
                            class="inline-flex items-center gap-2 relative flex-[0_0_auto] hover:opacity-80 transition-opacity">
                            <span class="inline-flex flex-col items-start relative flex-[0_0_auto]" aria-hidden="true">
                                <img class="relative w-3 h-2" src="/img/icon-3.svg" alt="" />
                            </span>
                            <span
                                class="w-[99.14px] mt-[-1.00px] text-[#c8c5ca] tracking-[1.20px] relative flex items-center h-3 [font-family:'Space_Grotesk-Bold',Helvetica] font-bold text-xs leading-3 whitespace-nowrap">Back
                                to Log In</span>
                        </a>
                    </div>
                </footer>
            </section>
        </div>
    </main>
    <script>
        document.getElementById('forgot-password-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('input-1').value;
            const alertMsg = document.getElementById('alert-message');
            const submitBtn = document.getElementById('submit-btn');

            alertMsg.className = 'hidden w-full mb-4 px-4 py-3 rounded relative text-center text-sm font-medium';
            alertMsg.textContent = '';

            submitBtn.disabled = true;
            submitBtn.style.opacity = '0.7';

            try {
                const response = await fetch('/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });

                const data = await response.json();

                if (response.ok) {
                    alertMsg.textContent = data.message || 'An OTP has been sent to your email address.';
                    alertMsg.classList.add('bg-green-100', 'border', 'border-green-400', 'text-green-700');
                    alertMsg.classList.remove('hidden');

                    if (data.redirectUrl) {
                        setTimeout(() => window.location.href = data.redirectUrl, 2000);
                    }
                } else {
                    alertMsg.textContent = data.message || 'An error occurred. Please try again.';
                    alertMsg.classList.add('bg-red-100', 'border', 'border-red-400', 'text-red-700');
                    alertMsg.classList.remove('hidden');
                    submitBtn.disabled = false;
                    submitBtn.style.opacity = '1';
                }
            } catch (error) {
                alertMsg.textContent = 'Network error. Please try again later.';
                alertMsg.classList.add('bg-red-100', 'border', 'border-red-400', 'text-red-700');
                alertMsg.classList.remove('hidden');
                submitBtn.disabled = false;
                submitBtn.style.opacity = '1';
            }
        });
    </script>
</body>

</html>