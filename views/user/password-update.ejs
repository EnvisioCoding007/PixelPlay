<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= user.username %> — Update Password · PixelPlay</title>
    <link rel="stylesheet" href="globals.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        /** @type {import('tailwindcss').Config} */
        tailwind.config = {
            theme: {
                extend: {
                },
            },
            plugins: [],
        }
    </script>
</head>

<body>
    <main
        class="flex flex-col min-h-[812px] items-start relative [background:linear-gradient(180deg,rgba(14,165,233,0.03)_2%,rgba(14,165,233,0)_2%),linear-gradient(90deg,rgba(14,165,233,0.03)_2%,rgba(14,165,233,0)_2%),linear-gradient(0deg,rgba(9,9,11,1)_0%,rgba(9,9,11,1)_100%)]">
        <section
            class="flex items-center justify-center px-6 py-[43.5px] relative self-stretch w-full flex-[0_0_auto] min-h-[812px]">
            <div aria-hidden="true"
                class="absolute top-[calc(50.00%_-_300px)] left-[calc(50.00%_-_300px)] w-[600px] h-[600px] [background:radial-gradient(50%_50%_at_50%_50%,rgba(14,165,233,0.1)_0%,rgba(14,165,233,0)_70%)]">
            </div>
            <div
                class="flex flex-col max-w-[480px] w-full items-start gap-8 px-10 py-12 relative bg-[#121215bf] rounded-2xl border border-solid border-zinc-800 shadow-[0px_0px_20px_#0ea5e91a,0px_16px_40px_#00000099] backdrop-blur-[10px] backdrop-brightness-[100%] [-webkit-backdrop-filter:blur(10px)_brightness(100%)]">
                <div aria-hidden="true"
                    class="absolute w-full h-full top-0 left-0 rounded-2xl [background:linear-gradient(140deg,rgba(14,165,233,0.35)_0%,rgba(14,165,233,0)_40%,rgba(14,165,233,0)_60%,rgba(14,165,233,0.35)_100%)]">
                </div>
                <header class="flex items-center justify-center gap-3 relative self-stretch w-full flex-[0_0_auto]">
                    <img class="relative w-10 h-10" src="img/background.svg" alt="PixelPlay logo" />
                    <div class="inline-flex flex-col items-start relative flex-[0_0_auto]">
                        <div
                            class="flex items-center mt-[-1.00px] [font-family:'JetBrains_Mono-Bold',Helvetica] font-bold text-zinc-100 text-2xl tracking-[-0.50px] leading-[normal] relative w-fit">
                            PIXELPLAY</div>
                    </div>
                </header>
                <section class="flex flex-col items-start gap-[11.25px] relative self-stretch w-full flex-[0_0_auto]">
                    <div class="flex flex-col items-center relative self-stretch w-full flex-[0_0_auto]">
                        <h1
                            class="flex items-center justify-center mt-[-1.00px] [font-family:'Inter-Bold',Helvetica] font-bold text-zinc-100 text-2xl text-center tracking-[-0.50px] leading-[normal] relative w-fit">
                            Establish New Security Credentials</h1>
                    </div>
                    <div
                        class="flex flex-col items-center pt-0 pb-[0.75px] px-0 relative self-stretch w-full flex-[0_0_auto]">
                        <p
                            class="mt-[-1.00px] [font-family:'Inter-Regular',Helvetica] font-normal text-zinc-400 text-[15px] text-center tracking-[0] leading-[22.5px] relative w-fit">
                            Enter your new access key below to regain entry to the<br />platform.</p>
                    </div>
                </section>
                <form
                    class="flex flex-col items-start gap-6 pt-2 pb-0 px-0 relative self-stretch w-full flex-[0_0_auto]"
                    id="password-update-form"
                    action="/auth/profile/password" method="post" novalidate>
                    <div class="flex flex-col items-start gap-6 relative self-stretch w-full flex-[0_0_auto]">
                        <div class="flex flex-col items-start gap-2 relative self-stretch w-full flex-[0_0_auto]">
                            <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                <label for="current-password"
                                    class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'JetBrains_Mono-Bold',Helvetica] font-bold text-zinc-300 text-xs tracking-[1.00px] leading-[normal]">CURRENT
                                    PASSWORD</label>
                            </div>
                            <div
                                class="flex items-center justify-center relative self-stretch w-full flex-[0_0_auto] bg-zinc-950 rounded-lg overflow-hidden border border-solid border-sky-500 shadow-[inset_0px_0px_10px_1px_#0ea5e91a,0px_0px_0px_1px_#0ea5e9]">
                                <img class="absolute top-3.5 left-[17px] w-5 h-5 z-10 pointer-events-none"
                                    src="img/container-6.svg" alt="" aria-hidden="true" />
                                <input id="current-password" name="current-password" type="password"
                                    value="" placeholder="Enter current password" aria-label="Current password"
                                    class="flex flex-col items-start pt-[15px] pb-[13px] px-11 relative flex-1 grow bg-transparent [font-family:'JetBrains_Mono-Regular',Helvetica] font-normal text-zinc-100 text-sm tracking-[2.00px] leading-[normal] border-0 outline-none" />
                                <button type="button" aria-label="Show current password"
                                    class="absolute top-3.5 right-[17px] w-5 h-5 p-0 border-0 bg-transparent">
                                    <img class="w-5 h-5" src="img/container-3.svg" alt="" aria-hidden="true" />
                                </button>
                            </div>
                        </div>
                        <div class="flex flex-col items-start gap-2 relative self-stretch w-full flex-[0_0_auto]">
                            <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                <label for="new-password"
                                    class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'JetBrains_Mono-Bold',Helvetica] font-bold text-zinc-300 text-xs tracking-[1.00px] leading-[normal]">NEW
                                    PASSWORD</label>
                            </div>
                            <div
                                class="bg-zinc-950 overflow-hidden border border-solid border-zinc-800 flex items-center justify-center relative self-stretch w-full flex-[0_0_auto] rounded-lg">
                                <img class="absolute top-3.5 left-[17px] w-5 h-5 z-10 pointer-events-none"
                                    src="img/container-4.svg" alt="" aria-hidden="true" />
                                <input id="new-password" name="new-password" type="password" value="" placeholder="Enter new password"
                                    aria-label="New password"
                                    class="flex flex-col items-start pt-[15px] pb-[13px] px-11 relative flex-1 grow bg-transparent [font-family:'JetBrains_Mono-Regular',Helvetica] font-normal text-zinc-100 text-sm tracking-[2.00px] leading-[normal] border-0 outline-none" />
                                <button type="button" aria-label="Show new password"
                                    class="absolute top-3.5 right-[17px] w-5 h-5 p-0 border-0 bg-transparent">
                                    <img class="w-5 h-5" src="img/container-2.svg" alt="" aria-hidden="true" />
                                </button>
                            </div>
                        </div>
                        <div class="flex flex-col items-start gap-2 relative self-stretch w-full flex-[0_0_auto]">
                            <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                <label for="confirm-new-password"
                                    class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'JetBrains_Mono-Bold',Helvetica] font-bold text-zinc-300 text-xs tracking-[1.00px] leading-[normal]">CONFIRM
                                    NEW PASSWORD</label>
                            </div>
                            <div
                                class="bg-zinc-950 overflow-hidden border border-solid border-zinc-800 flex items-center justify-center relative self-stretch w-full flex-[0_0_auto] rounded-lg">
                                <img class="absolute top-3.5 left-[17px] w-5 h-5 z-10 pointer-events-none"
                                    src="img/container-7.svg" alt="" aria-hidden="true" />
                                <input id="confirm-new-password" name="confirm-new-password" type="password"
                                    value="" placeholder="Confirm new password" aria-label="Confirm new password"
                                    class="flex flex-col items-start pt-[15px] pb-[13px] px-11 relative flex-1 grow bg-transparent [font-family:'JetBrains_Mono-Regular',Helvetica] font-normal text-zinc-100 text-sm tracking-[2.00px] leading-[normal] border-0 outline-none" />
                                <button type="button" aria-label="Show confirm new password"
                                    class="absolute top-3.5 right-[17px] w-5 h-5 p-0 border-0 bg-transparent">
                                    <img class="w-5 h-5" src="img/image.svg" alt="" aria-hidden="true" />
                                </button>
                            </div>
                        </div>
                    </div>
                    <section aria-label="Password requirements"
                        class="flex flex-col items-start gap-3 pt-4 pb-6 px-4 relative self-stretch w-full flex-[0_0_auto] bg-[#0ea5e908] rounded-lg border border-solid border-zinc-800">
                        <div class="flex items-center gap-2.5 relative self-stretch w-full flex-[0_0_auto]">
                            <img class="relative flex-[0_0_auto]" src="img/container.svg" alt="" aria-hidden="true" />
                            <div
                                class="flex items-center mt-[-0.50px] [font-family:'Inter-Medium',Helvetica] font-medium text-zinc-300 text-sm tracking-[0] leading-[normal] relative w-fit">
                                At least 8 characters</div>
                        </div>
                        <div class="flex items-center gap-2.5 relative self-stretch w-full flex-[0_0_auto]">
                            <img class="relative flex-[0_0_auto]" src="img/container-8.svg" alt="" aria-hidden="true" />
                            <div
                                class="flex items-center mt-[-0.50px] [font-family:'Inter-Medium',Helvetica] font-medium text-zinc-300 text-sm tracking-[0] leading-[normal] relative w-fit">
                                Includes a symbol</div>
                        </div>
                        <div class="flex items-center gap-2.5 relative self-stretch w-full flex-[0_0_auto]">
                            <img class="relative flex-[0_0_auto]" src="img/container-5.svg" alt="" aria-hidden="true" />
                            <p
                                class="flex items-center mt-[-0.50px] [font-family:'Inter-Medium',Helvetica] font-medium text-zinc-300 text-sm tracking-[0] leading-[normal] relative w-fit">
                                Includes uppercase and lowercase letters</p>
                        </div>
                    </section>

                    <div id="pw-alert"
                        class="hidden w-full px-4 py-3 rounded-lg text-sm font-medium text-center [font-family:'Inter-Medium',Helvetica] bg-red-950/60 border border-red-500/30 text-red-400">
                    </div>

                    <button type="submit" id="pw-submit-btn"
                        class="gap-2.5 p-4 bg-sky-500 shadow-[0px_0px_20px_#0ea5e959] flex items-center justify-center relative self-stretch w-full flex-[0_0_auto] rounded-lg">
                        <span class="inline-flex flex-col items-start relative flex-[0_0_auto]">
                            <span class="relative w-5 h-5">
                                <img class="absolute w-[87.50%] h-[95.84%] top-[4.16%] left-[12.50%]"
                                    src="img/vector.svg" alt="" aria-hidden="true" />
                            </span>
                        </span>
                        <span
                            class="flex items-center justify-center mt-[-1.00px] [font-family:'Inter-Bold',Helvetica] font-bold text-zinc-950 text-base text-center tracking-[0.50px] leading-[normal] relative w-fit">UPDATE
                            CREDENTIALS</span>
                    </button>
                    <div class="flex flex-col items-center relative self-stretch w-full flex-[0_0_auto]">
                        <a href="/auth/profile"
                            class="relative flex items-center justify-center w-fit mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium text-zinc-400 text-sm text-center tracking-[0] leading-[normal] bg-transparent border-0 p-0">Cancel
                            &amp; Return</a>
                    </div>
                </form>
            </div>
        </section>
    </main>
    <script>
        (function () {
            const form      = document.getElementById('password-update-form');
            const alertDiv  = document.getElementById('pw-alert');
            const submitBtn = document.getElementById('pw-submit-btn');

            function showAlert(msg) {
                alertDiv.textContent = msg;
                alertDiv.classList.remove('hidden');
            }

            form.addEventListener('submit', async function (e) {
                e.preventDefault();
                alertDiv.classList.add('hidden');

                const currentPassword    = document.getElementById('current-password').value;
                const newPassword        = document.getElementById('new-password').value;
                const confirmNewPassword = document.getElementById('confirm-new-password').value;

                // Basic client-side checks before hitting the server
                if (!currentPassword || !newPassword || !confirmNewPassword) {
                    showAlert('All password fields are required.');
                    return;
                }
                if (newPassword !== confirmNewPassword) {
                    showAlert('New passwords do not match.');
                    return;
                }
                if (newPassword.length < 8) {
                    showAlert('New password must be at least 8 characters.');
                    return;
                }

                submitBtn.disabled = true;
                submitBtn.style.opacity = '0.7';

                try {
                    const response = await fetch('/auth/profile/password', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            'current-password': currentPassword,
                            'new-password': newPassword,
                            'confirm-new-password': confirmNewPassword
                        })
                    });

                    const data = await response.json();

                    if (response.ok && data.success) {
                        window.location.href = data.redirectUrl || '/auth/profile';
                    } else {
                        showAlert(data.message || 'Failed to update password. Please try again.');
                        submitBtn.disabled = false;
                        submitBtn.style.opacity = '1';
                    }
                } catch (err) {
                    showAlert('Network error. Please try again.');
                    submitBtn.disabled = false;
                    submitBtn.style.opacity = '1';
                }
            });

            // Clear alert on any input interaction
            form.querySelectorAll('input[type="password"]').forEach(function (input) {
                input.addEventListener('input', function () {
                    alertDiv.classList.add('hidden');
                });
            });
        })();
    </script>
</body>

</html>