<!DOCTYPE html>
<html lang="en">

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta charset="utf-8" />
    <title><%= user.username %> — Edit Profile · PixelPlay</title>
    <link rel="stylesheet" href="globals.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        /** @type {import('tailwindcss').Config} */
        tailwind.config = {
            theme: {
                extend: {},
            },
            plugins: [],
        }
    </script>
</head>

<body>
    <div class="flex flex-col min-h-screen items-start relative bg-zinc-950">
        <header
            class="flex h-[72px] items-center justify-between px-10 py-0 relative self-stretch w-full z-[1] bg-[#09090be6] border-b [border-bottom-style:solid] border-[#00000014] backdrop-blur backdrop-brightness-[100%] [-webkit-backdrop-filter:blur(8px)_brightness(100%)]">
            <nav class="flex items-center justify-between w-full gap-6" aria-label="Primary">
                <div class="inline-flex items-center gap-10 relative flex-[0_0_auto]">
                    <a href="#"
                        class="relative w-[129px] h-12 aspect-[2.68] bg-[url(legacy:image:md5:I144:2444;273:1230-no-children)] bg-cover bg-[50%_50%] block"
                        aria-label="PixelPlay home"></a>
                    <ul class="inline-flex items-center gap-[7.6px] relative flex-[0_0_auto]">
                        <li><a href="#"
                                class="inline-flex flex-col items-start px-4 py-2 relative flex-[0_0_auto] rounded-md"><span
                                    class="relative flex items-center w-fit mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium text-[#9aa6b3] text-sm tracking-[0] leading-[normal]">Home</span></a>
                        </li>
                        <li><a href="#"
                                class="inline-flex flex-col items-start px-4 py-2 relative flex-[0_0_auto] rounded-md"><span
                                    class="mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium text-[#9aa6b3] text-sm tracking-[0] relative flex items-center w-fit leading-[normal]">Browse</span></a>
                        </li>
                        <li><a href="#"
                                class="inline-flex flex-col items-start px-4 py-2 relative flex-[0_0_auto] rounded-md"><span
                                    class="mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium text-[#9aa6b3] text-sm tracking-[0] relative flex items-center w-fit leading-[normal]">Wishlist</span></a>
                        </li>
                        <li><a href="#"
                                class="inline-flex flex-col items-start px-4 py-2 relative flex-[0_0_auto] rounded-md"><span
                                    class="mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium text-[#9aa6b3] text-sm tracking-[0] relative flex items-center w-fit leading-[normal]">Offers</span></a>
                        </li>

                        <li><a href="#"
                                class="inline-flex flex-col items-start px-4 py-2 relative flex-[0_0_auto] rounded-md"><span
                                    class="relative flex items-center w-fit mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium text-[#9aa6b3] text-sm tracking-[0] leading-[normal]">Wallet</span></a>
                        </li>
                        <li><a href="#"
                                class="inline-flex flex-col items-start px-4 py-2 relative flex-[0_0_auto] rounded-md"><span
                                    class="mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium text-[#9aa6b3] text-sm tracking-[0] relative flex items-center w-fit leading-[normal]">Support</span></a>
                        </li>
                    </ul>
                </div>
                <div class="inline-flex items-center gap-5 relative flex-[0_0_auto]">
                    <form
                        class="flex w-60 items-center gap-3 px-4 py-2 relative bg-[#0f1113] rounded-full border border-solid border-[#00000014]"
                        role="search">
                        <label for="store-search" class="sr-only">Search store</label>
                        <img class="relative w-4 h-4" src="img/container.svg" alt="" />
                        <div class="flex flex-col items-start relative flex-1 grow">
                            <input id="store-search"
                                class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'Inter-Regular',Helvetica] font-normal text-[#9aa6b3] text-sm tracking-[0] leading-[normal] bg-transparent border-0 p-0 outline-none placeholder:text-[#9aa6b3]"
                                placeholder="Search store..." type="search" />
                        </div>
                    </form>
                    <button type="button" class="flex w-10 h-10 items-center justify-center relative rounded-[20px]"
                        aria-label="Cart">
                        <img class="relative flex-[0_0_auto]" src="img/iconify-icon.svg" alt="" />
                    </button>
                    <button type="button" class="flex w-10 h-10 items-center justify-center relative rounded-[20px]"
                        aria-label="Notifications">
                        <div class="inline-flex flex-col items-start relative flex-[0_0_auto]">
                            <div class="relative w-5 h-5">
                                <img class="absolute w-[91.66%] h-[95.83%] top-[4.17%] left-[8.34%]"
                                    src="img/vector-2.svg" alt="" />
                            </div>
                        </div>
                    </button>
                    <a href="#"
                        class="relative w-9 h-9 rounded-[18px] border-2 border-solid border-[#00000014] bg-[url(legacy:image:md5:I144:2444;10:45-no-children)] bg-cover bg-[50%_50%] block"
                        aria-label="Profile"></a>
                </div>
            </nav>
        </header>
        <main class="flex items-start justify-center px-8 py-16 relative self-stretch w-full flex-[0_0_auto] z-0">
            <div class="flex flex-col max-w-[860px] w-full items-start gap-10 relative self-stretch">
                <section class="flex flex-col items-start gap-2 relative self-stretch w-full flex-[0_0_auto]">
                    <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                        <h1
                            class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'Inter-Bold',Helvetica] font-bold text-zinc-100 text-[32px] tracking-[0] leading-[normal]">
                            Profile Settings</h1>
                    </div>
                    <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                        <p
                            class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'Inter-Regular',Helvetica] font-normal text-zinc-400 text-base tracking-[0] leading-[normal]">
                            Manage your identity, personal details, and account security.</p>
                    </div>
                </section>
                <form id="profile-edit-form"
                    method="post" action="/user/profile?_method=PATCH" enctype="multipart/form-data"
                    class="flex flex-col items-start gap-14 p-12 relative self-stretch w-full flex-[0_0_auto] bg-[#121215bf] rounded-xl border border-solid border-zinc-700 shadow-[inset_0px_1px_0px_1px_#ffffff0d,0px_8px_32px_#00000066] backdrop-blur backdrop-brightness-[100%] [-webkit-backdrop-filter:blur(8px)_brightness(100%)]">
                    <section class="flex items-center gap-8 relative self-stretch w-full flex-[0_0_auto]">
                        <div class="relative mt-[-20px] mb-[-20px] ml-[-20px] shrink-0" style="width:152px;height:152px">
                            <!-- Clickable avatar -->
                            <button type="button" id="avatar-upload-btn"
                                class="relative w-full h-full rounded-full overflow-hidden border-2 border-zinc-700 hover:border-sky-500 focus:border-sky-500 transition-colors group cursor-pointer focus:outline-none flex items-center justify-center bg-[#1a2a3a]"
                                aria-label="Change profile picture">
                                <!-- Avatar image -->
                                <img id="avatar-preview"
                                    src="<%= user.profile_image || '' %>"
                                    alt="<%= user.username %> avatar"
                                    class="w-full h-full object-cover <%= !user.profile_image ? 'hidden' : '' %>" />
                                <!-- Initials fallback -->
                                <div id="avatar-fallback" class="w-full h-full flex items-center justify-center [font-family:'Inter-Bold',Helvetica] font-bold text-sky-400 text-5xl select-none <%= user.profile_image ? 'hidden' : '' %>">
                                    <%= user.username.charAt(0).toUpperCase() %>
                                </div>
                                <!-- Camera overlay on hover -->
                                <div class="absolute inset-0 bg-zinc-900/70 flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                    <svg class="w-7 h-7 text-sky-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z" />
                                    </svg>
                                    <span class="text-xs text-sky-400 font-semibold mt-1 [font-family:'Inter-SemiBold',Helvetica]">Change Photo</span>
                                </div>
                            </button>
                            <!-- Hidden file input -->
                            <input type="file" id="avatar-file-input" name="profile_image" accept="image/*" class="sr-only" aria-label="Upload profile picture" />
                            <!-- Hidden form field carries the base64 data URL -->
                            <input type="hidden" id="profile-image-data" value="" />
                        </div>
                        <div class="inline-flex flex-col items-start gap-3 relative flex-[0_0_auto]">
                            <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                <h2
                                    class="mt-[-1.00px] [font-family:'Inter-Bold',Helvetica] font-bold text-zinc-100 text-2xl tracking-[0] relative flex items-center w-fit leading-[normal]">
                                    <%= user.username %></h2>
                            </div>
                            <p class="text-xs text-zinc-500 [font-family:'Inter-Regular',Helvetica]">Click the avatar to upload a new photo (JPEG, PNG, WebP — max 2 MB).</p>
                            <p id="avatar-error" class="hidden text-xs text-red-400 [font-family:'Inter-Regular',Helvetica]"></p>
                        </div>
                    </section>
                    <section class="flex flex-col items-start gap-6 relative self-stretch w-full flex-[0_0_auto]">
                        <div class="flex items-center gap-4 relative self-stretch w-full flex-[0_0_auto]">
                            <h3
                                class="relative flex items-center w-fit mt-[-1.00px] [font-family:'Inter-Bold',Helvetica] font-bold text-zinc-400 text-[13px] tracking-[1.50px] leading-[normal]">
                                PERSONAL INFORMATION</h3>
                            <div class="relative flex-1 grow h-px bg-zinc-800"></div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6 pt-2 w-full">
                            <!-- Full Name -->
                            <div class="relative w-full h-fit flex flex-col items-start gap-3">
                                <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                    <label
                                        class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium text-[#c0c0c8] text-sm tracking-[0] leading-[normal]"
                                        for="full-name">Full Name</label>
                                </div>
                                <div
                                    class="flex flex-col items-start px-5 py-4 relative self-stretch w-full flex-[0_0_auto] bg-[#121215] rounded-lg overflow-hidden border border-solid border-zinc-700">
                                    <input id="full-name"
                                        class="relative self-stretch w-full border-[none] [background:none] [font-family:'Inter-Regular',Helvetica] font-normal text-zinc-100 text-[15px] tracking-[0] leading-[normal] p-0 outline-none"
                                        type="text" name="username" value="<%= user.username %>" />
                                </div>
                            </div>
                            <!-- Email Address (click pencil to edit) -->
                            <div class="relative w-full h-fit flex flex-col items-start gap-3">
                                <div class="flex items-center justify-between self-stretch">
                                    <label
                                        class="[font-family:'Inter-Medium',Helvetica] font-medium text-[#c0c0c8] text-sm tracking-[0] leading-[normal]"
                                        for="email-address">Email Address</label>
                                    <% if (!user.google_id && user.password_hash) { %>
                                    <button type="button" id="email-edit-btn"
                                        title="Edit email address"
                                        class="flex items-center gap-1 text-zinc-500 hover:text-sky-400 transition-colors text-xs [font-family:'Inter-Medium',Helvetica]">
                                        <!-- Pencil icon -->
                                        <svg id="email-pen-icon" xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M9 13l6.586-6.586a2 2 0 112.828 2.828L11.828 15.828A2 2 0 019.5 16.5H8v-1.5a2 2 0 01.586-1.414z" />
                                        </svg>
                                        <span id="email-edit-label">Change</span>
                                    </button>
                                    <% } %>
                                </div>
                                <div id="email-input-wrapper"
                                    class="flex items-center px-5 py-4 relative self-stretch w-full flex-[0_0_auto] bg-[#121215] rounded-lg overflow-hidden border border-solid border-zinc-700 opacity-60 transition-all duration-200">
                                    <input id="email-address"
                                        class="relative flex-1 border-[none] [background:none] [font-family:'Inter-Regular',Helvetica] font-normal text-zinc-400 text-[15px] tracking-[0] leading-[normal] p-0 outline-none cursor-not-allowed transition-colors duration-200"
                                        type="email" name="email" value="<%= user.email %>" readonly />
                                    <!-- Lock icon shown when field is locked -->
                                    <svg id="email-lock-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-600 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <rect x="3" y="11" width="18" height="11" rx="2"/>
                                        <path d="M7 11V7a5 5 0 0110 0v4"/>
                                    </svg>
                                </div>
                                <p id="email-edit-hint" class="hidden text-xs text-sky-400 [font-family:'Inter-Regular',Helvetica]">
                                    A verification code will be sent to your new address when you save.
                                </p>
                            </div>
                            <!-- Phone Number -->
                            <div class="relative w-full h-fit flex flex-col items-start gap-3 md:col-span-2">
                                <div class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                                    <label
                                        class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium text-[#c0c0c8] text-sm tracking-[0] leading-[normal]"
                                        for="phone-number">Phone Number</label>
                                </div>
                                <div
                                    class="flex flex-col items-start px-5 py-4 relative self-stretch w-full flex-[0_0_auto] bg-[#121215] rounded-lg overflow-hidden border border-solid border-zinc-700">
                                    <input id="phone-number"
                                        class="relative self-stretch w-full border-[none] [background:none] [font-family:'Inter-Regular',Helvetica] font-normal text-zinc-100 text-[15px] tracking-[0] leading-[normal] p-0 outline-none"
                                        type="tel" name="phone" value="<%= user.phone || '' %>" placeholder="Add a phone number" />
                                </div>
                            </div>
                        </div>
                    </section>
                    <% if (user.password_hash) { %>
                    <section class="flex flex-col items-start gap-8 relative self-stretch w-full flex-[0_0_auto]">
                        <div class="flex items-center gap-4 relative self-stretch w-full flex-[0_0_auto]">
                            <h3
                                class="relative flex items-center w-fit mt-[-1.00px] [font-family:'Inter-Bold',Helvetica] font-bold text-zinc-400 text-[13px] tracking-[1.50px] leading-[normal]">
                                SECURITY QUICK-ACTIONS</h3>
                            <div class="relative flex-1 grow h-px bg-zinc-800"></div>
                        </div>
                        <div class="flex items-start gap-6 relative self-stretch w-full flex-[0_0_auto]">
                            <a href="/user/profile/password"
                                class="all-[unset] box-border inline-flex items-center justify-center gap-2.5 px-8 py-3.5 relative flex-[0_0_auto] bg-[#121215] rounded-lg border border-solid border-zinc-700 cursor-pointer hover:bg-zinc-800 transition-colors">
                                <div class="inline-flex flex-col items-start relative flex-[0_0_auto]">
                                    <div class="relative w-[18px] h-[18px]">
                                        <div class="relative w-[81.61%] h-[79.17%] top-[8.33%] left-[8.33%]">
                                            <img class="absolute w-[57.11%] h-[105.26%] top-[-5.26%] left-[42.89%]"
                                                src="img/vector-3.svg" alt="" />
                                            <img class="absolute w-[105.11%] h-[63.16%] top-[36.84%] left-[-5.11%]"
                                                src="img/vector.svg" alt="" />
                                        </div>
                                    </div>
                                </div>
                                <div
                                    class="justify-center [font-family:'Inter-SemiBold',Helvetica] font-semibold text-zinc-100 text-[15px] text-center tracking-[0] relative flex items-center w-fit leading-[normal]">
                                    Change Password</div>
                            </a>
                        </div>
                    </section>
                    <% } %>
                    <div
                        class="flex items-center justify-between pt-8 pb-0 px-0 relative self-stretch w-full flex-[0_0_auto] border-t [border-top-style:solid] border-zinc-800">
                        <a href="/user/profile"
                            class="all-[unset] box-border border border-solid border-zinc-400 inline-flex items-center justify-center px-8 py-3.5 relative flex-[0_0_auto] rounded-lg shadow-[0px_0px_15px_#0ea5e940] cursor-pointer">
                            <div
                                class="relative flex items-center justify-center w-fit mt-[-1.00px] [font-family:'Inter-SemiBold',Helvetica] font-semibold text-zinc-400 text-[15px] text-center tracking-[0] leading-[normal] whitespace-nowrap">
                                Cancel &amp; Return</div>
                        </a>
                        <button type="submit"
                            class="all-[unset] box-border bg-sky-500 inline-flex items-center justify-center px-8 py-3.5 relative flex-[0_0_auto] rounded-lg shadow-[0px_0px_15px_#0ea5e940] cursor-pointer">
                            <div
                                class="justify-center mt-[-1.00px] [font-family:'Inter-SemiBold',Helvetica] font-semibold text-zinc-950 text-[15px] text-center tracking-[0] relative flex items-center w-fit leading-[normal]">
                                Update Profile</div>
                        </button>
                    </div>
                </form>
            </div>
        </main>
    </div>

    <!-- Cropper.js Workspace Modal overlay -->
    <div id="cropperWorkspace" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/90 backdrop-blur-sm p-4">
      <div class="bg-zinc-900 border border-zinc-800 rounded-xl max-w-lg w-full p-6 flex flex-col gap-4 shadow-2xl">
        <div class="flex items-center justify-between border-b border-zinc-800 pb-3">
          <h3 class="text-lg font-semibold text-zinc-100">Crop Profile Picture</h3>
          <button type="button" id="closeCropperBtn" class="text-zinc-400 hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div class="relative w-full max-h-[50vh] bg-zinc-950 flex items-center justify-center overflow-hidden rounded-lg border border-zinc-800">
          <img id="cropperImage" class="max-w-full max-h-[40vh] object-contain" />
        </div>
        <div class="flex gap-3 justify-end border-t border-zinc-800 pt-3">
          <button type="button" id="cancelCropBtn" class="px-5 py-2 text-sm text-zinc-300 hover:bg-zinc-800 border border-zinc-800 rounded-lg transition-colors">
            Cancel
          </button>
          <button type="button" id="saveCropBtn" class="px-5 py-2 text-sm text-zinc-950 bg-sky-500 hover:bg-sky-400 font-medium rounded-lg transition-colors">
            Apply Crop
          </button>
        </div>
      </div>
    </div>
</body>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
<script>
    (function () {
        // Profile picture upload via FileReader → base64 data URL
        const uploadBtn    = document.getElementById('avatar-upload-btn');
        const fileInput    = document.getElementById('avatar-file-input');
        const preview      = document.getElementById('avatar-preview');
        const imageData    = document.getElementById('profile-image-data');
        const avatarError  = document.getElementById('avatar-error');
        const MAX_BYTES    = 2 * 1024 * 1024; // 2 MB

        // Cropper elements
        const cropperWorkspace = document.getElementById('cropperWorkspace');
        const cropperImage = document.getElementById('cropperImage');
        const closeCropperBtn = document.getElementById('closeCropperBtn');
        const cancelCropBtn = document.getElementById('cancelCropBtn');
        const saveCropBtn = document.getElementById('saveCropBtn');
        let cropper = null;

        uploadBtn.addEventListener('click', () => fileInput.click());

        fileInput.addEventListener('change', () => {
            const file = fileInput.files[0];
            if (!file) return;

            avatarError.classList.add('hidden');

            if (!file.type.startsWith('image/')) {
                avatarError.textContent = 'Please select an image file (JPEG, PNG, WebP).';
                avatarError.classList.remove('hidden');
                return;
            }
            if (file.size > MAX_BYTES) {
                avatarError.textContent = 'Image must be smaller than 2 MB.';
                avatarError.classList.remove('hidden');
                return;
            }

            const reader = new FileReader();
            reader.onload = (e) => {
                cropperImage.src = e.target.result;
                cropperWorkspace.classList.remove('hidden');
                
                if (cropper) {
                    cropper.destroy();
                }
                
                cropper = new Cropper(cropperImage, {
                    aspectRatio: 1,
                    viewMode: 1,
                    dragMode: 'move',
                    autoCropArea: 0.9,
                    responsive: true,
                    restore: false,
                    guides: true,
                    center: true,
                    highlight: false,
                    cropBoxMovable: true,
                    cropBoxResizable: true,
                    toggleDragModeOnDblclick: false
                });
            };
            reader.readAsDataURL(file);
        });

        function closeCropper() {
            cropperWorkspace.classList.add('hidden');
            if (cropper) {
                cropper.destroy();
                cropper = null;
            }
            fileInput.value = '';
        }

        closeCropperBtn.addEventListener('click', closeCropper);
        cancelCropBtn.addEventListener('click', closeCropper);

        saveCropBtn.addEventListener('click', () => {
            if (!cropper) return;
            const canvas = cropper.getCroppedCanvas({
                width: 300,
                height: 300
            });
            const dataUrl = canvas.toDataURL('image/png');
            preview.src = dataUrl;
            preview.classList.remove('hidden');
            const fallback = document.getElementById('avatar-fallback');
            if (fallback) {
                fallback.classList.add('hidden');
            }
            
            // Convert cropped canvas to blob and set it to file input
            canvas.toBlob((blob) => {
                if (blob) {
                    const croppedFile = new File([blob], 'cropped-profile-image.png', { type: 'image/png' });
                    const dataTransfer = new DataTransfer();
                    dataTransfer.items.add(croppedFile);
                    fileInput.files = dataTransfer.files;
                }
            }, 'image/png');

            imageData.value = dataUrl; // Keep for client side preview references
            closeCropper();
        });

        // Email edit toggle
        const editBtn    = document.getElementById('email-edit-btn');
        const editLabel  = document.getElementById('email-edit-label');
        const penIcon    = document.getElementById('email-pen-icon');
        const lockIcon   = document.getElementById('email-lock-icon');
        const wrapper    = document.getElementById('email-input-wrapper');
        const input      = document.getElementById('email-address');
        const hint       = document.getElementById('email-edit-hint');
        const originalEmail = input ? input.value : '';

        let isEditing = false;

        function enableEdit() {
            if (!input || !wrapper || !lockIcon || !penIcon || !editLabel || !hint) return;
            isEditing = true;
            input.readOnly = false;
            input.classList.remove('text-zinc-400', 'cursor-not-allowed');
            input.classList.add('text-zinc-100', 'cursor-text');
            wrapper.classList.remove('opacity-60', 'border-zinc-700');
            wrapper.classList.add('border-sky-500', 'shadow-[0px_0px_0px_1px_#0ea5e9]');
            lockIcon.classList.add('hidden');
            penIcon.classList.add('text-sky-400');
            editLabel.textContent = 'Cancel';
            hint.classList.remove('hidden');
            input.focus();
        }

        function disableEdit() {
            if (!input || !wrapper || !lockIcon || !penIcon || !editLabel || !hint) return;
            isEditing = false;
            input.readOnly = true;
            input.value = originalEmail;
            input.classList.remove('text-zinc-100', 'cursor-text');
            input.classList.add('text-zinc-400', 'cursor-not-allowed');
            wrapper.classList.remove('border-sky-500', 'shadow-[0px_0px_0px_1px_#0ea5e9]');
            wrapper.classList.add('opacity-60', 'border-zinc-700');
            lockIcon.classList.remove('hidden');
            penIcon.classList.remove('text-sky-400');
            editLabel.textContent = 'Change';
            hint.classList.add('hidden');
        }

        if (editBtn) {
            editBtn.addEventListener('click', () => {
                isEditing ? disableEdit() : enableEdit();
            });
        }

        const profileForm = document.getElementById('profile-edit-form');
        if (profileForm) {
            profileForm.addEventListener('submit', function(e) {
                const phoneInput = document.getElementById('phone-number');
                if (phoneInput && phoneInput.value.trim()) {
                    const phoneVal = phoneInput.value.trim();
                    const cleanPhone = phoneVal.replace(/[\s-]/g, '');
                    const phoneRegex = /^(?:\+91|91|0)?[6-9]\d{9}$/;
                    let errEl = document.getElementById('profile-phone-error');
                    if (!phoneRegex.test(cleanPhone)) {
                        e.preventDefault();
                        e.stopPropagation();
                        if (!errEl) {
                            errEl = document.createElement('p');
                            errEl.id = 'profile-phone-error';
                            errEl.className = 'mt-1.5 text-xs text-red-500 font-medium';
                            phoneInput.parentNode.appendChild(errEl);
                        }
                        errEl.textContent = 'Please enter a valid phone number (10 to 12 digits, optional +91).';
                        phoneInput.parentNode.classList.add('border-red-500');
                    } else {
                        if (errEl) {
                            errEl.remove();
                        }
                        phoneInput.parentNode.classList.remove('border-red-500');
                        phoneInput.value = cleanPhone;
                    }
                }
            });
        }
    })();
</script>

</html>