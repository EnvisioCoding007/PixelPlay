<%- include('../partials/user/header') %>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet"/>

<style>
  .bg-pixel-bg { background-color: #0f0f11 !important; }
  .bg-pixel-card { background-color: #141416 !important; }
  .border-pixel-border { border-color: #2a2a2d !important; }
  .text-pixel-text { color: #e0e0e0 !important; }
  .text-pixel-muted { color: #8e8e93 !important; }
  .text-pixel-accent { color: #00b4ff !important; }
  .bg-pixel-accent { background-color: #00b4ff !important; }
  .bg-pixel-accentHover { background-color: #0090cc !important; }
  .hover\:bg-pixel-accentHover:hover { background-color: #0090cc !important; }
  
  .text-pixel-gold { color: #ffd700 !important; }
  .border-pixel-goldBorder { border-color: #ffb300 !important; }
  .text-pixel-danger { color: #ff4d4f !important; }
  .text-pixel-warning { color: #faad14 !important; }

  .text-pixel-cyan { color: #00b4ff !important; }
  .border-pixel-cyan { border-color: #00b4ff !important; }
  
  .bg-pixel-accent\/10 { background-color: rgba(0, 180, 255, 0.1) !important; }
  .border-pixel-accent\/30 { border-color: rgba(0, 180, 255, 0.3) !important; }
  .bg-pixel-gold\/10 { background-color: rgba(255, 215, 0, 0.1) !important; }
  .border-pixel-gold\/30 { border-color: rgba(255, 215, 0, 0.3) !important; }

  .dashed-line {
    border-bottom: 1px dashed #2a2a2d;
    flex-grow: 1;
    margin: 0 12px;
    position: relative;
    top: -4px;
  }
</style>

<body class="antialiased min-h-screen flex flex-col bg-pixel-bg text-pixel-text">

<%- include('../partials/user/navbar', { activeTab: 'cart', user: typeof user !== 'undefined' ? user : null }) %>

<!-- BEGIN: Main Content -->
<main class="flex-grow py-10 px-6">
  <div class="max-w-[1400px] mx-auto">
    <% if (typeof cart === 'undefined' || !cart || !cart.items || cart.items.length === 0) { %>
      <!-- Page Header -->
      <div class="mb-8 flex items-baseline gap-4">
        <h1 class="text-4xl font-bold text-white">Your Cart</h1>
        <span class="text-pixel-muted text-lg">0 Items</span>
      </div>
      
      <div class="bg-pixel-card border border-pixel-border rounded-lg p-12 text-center flex flex-col items-center justify-center max-w-2xl mx-auto my-10">
        <div class="w-24 h-24 rounded-full bg-pixel-bg border border-pixel-border flex items-center justify-center mb-6">
          <i class="fa-solid fa-cart-shopping text-4xl text-pixel-muted"></i>
        </div>
        <h2 class="text-2xl font-bold text-white mb-2">Your Cart is Empty</h2>
        <p class="text-pixel-muted mb-8 max-w-md">You haven't added any premium physical edition games to your catalog yet. Explore the shop to build your collection.</p>
        <a href="/browse" class="bg-pixel-accent hover:bg-pixel-accentHover text-[#0f0f11] font-bold py-3 px-8 rounded transition-colors tracking-wide flex items-center gap-2">
          <i class="fa-solid fa-gamepad"></i>
          BROWSE STORE
        </a>
      </div>
    <% } else { %>
      <!-- Page Header -->
      <div class="mb-8 flex items-baseline gap-4">
        <h1 class="text-4xl font-bold text-white">Your Cart</h1>
        <span class="text-pixel-muted text-lg"><%= cart.items.length %> <%= cart.items.length === 1 ? 'Physical Item' : 'Physical Items' %></span>
      </div>
      
      <div class="flex flex-col lg:flex-row gap-8 items-start">
        <!-- BEGIN: Cart Items List -->
        <div class="w-full lg:w-2/3 flex flex-col gap-4">
          <% cart.items.forEach(item => { %>
            <% 
              const isLegendary = (item.product.edition_type === 'LEGENDARY');
              const isUnavailable = (item.product.status === 'Hidden');
              const borderClass = isUnavailable ? 'border-l-red-600' : (isLegendary ? 'border-l-pixel-goldBorder' : 'border-l-pixel-accent');
              const textClass = isUnavailable ? 'text-red-500' : (isLegendary ? 'text-pixel-gold' : 'text-white');
              const formatText = isLegendary
                ? `Format: ${item.platform} Physical Collector's Vault Disk`
                : `Format: ${item.platform} Physical Disk`;
              const badgeText = isUnavailable ? 'UNAVAILABLE' : (isLegendary ? 'LEGENDARY DISK' : 'PHYSICAL DISK');
              const badgeClass = isUnavailable 
                ? 'text-red-500 bg-red-950/20 border-red-800/40' 
                : (isLegendary ? 'text-pixel-gold bg-pixel-gold/10 border-pixel-gold/30' : 'text-pixel-accent bg-pixel-accent/10 border-pixel-accent/30');
              const iconClass = isUnavailable
                ? 'fa-solid fa-circle-exclamation text-red-500'
                : (isLegendary ? 'fa-solid fa-box-open text-pixel-gold' : 'fa-solid fa-compact-disc text-pixel-accent');
              const itemCover = item.product.cover_image || item.product.coverImage || item.product.coverImageUrl || '/img/placeholder.png';
            %>
            <div class="bg-pixel-card border-l-4 <%= borderClass %> border-pixel-border rounded-lg p-5 flex gap-6 relative group hover:border-pixel-muted transition-colors <%= isUnavailable ? 'opacity-75' : '' %>">
              <!-- Product Image -->
              <div class="w-32 h-44 flex-shrink-0 bg-pixel-bg rounded overflow-hidden border border-pixel-border relative">
                <img alt="<%= item.product.title %> Cover" class="w-full h-full object-cover" src="<%= itemCover %>"/>
                <% if (isUnavailable) { %>
                  <div class="absolute inset-0 bg-black/60 flex items-center justify-center text-center p-2">
                    <span class="text-red-500 font-bold text-xs">UNAVAILABLE</span>
                  </div>
                <% } %>
              </div>
              <!-- Product Details -->
              <div class="flex-grow flex flex-col justify-between py-1">
                <div>
                  <div class="flex justify-between items-start">
                    <h2 class="text-xl font-bold text-white"><%= item.product.title %></h2>
                    <span class="text-xl font-bold <%= textClass %>">
                      <% if (isUnavailable) { %>
                        Unavailable
                      <% } else { %>
                        ₹<%= Number(item.product.price).toFixed(2) %>
                      <% } %>
                    </span>
                  </div>
                  <div class="flex items-center gap-2 mt-2 text-sm text-pixel-muted">
                    <i class="<%= iconClass %>"></i>
                    <span><%= formatText %></span>
                  </div>
                </div>
                
                <div class="flex items-end justify-between">
                  <div class="flex items-center gap-4">
                    <!-- Quantity Control -->
                    <div class="flex items-center gap-3 bg-pixel-bg rounded border border-pixel-border px-3 py-1">
                      <% const isMinQty = (item.quantity <= 1); %>
                      <button aria-label="Decrease quantity" 
                              class="text-pixel-muted transition-colors <%= isMinQty || isUnavailable ? 'opacity-30 cursor-not-allowed pointer-events-none' : 'hover:text-white cursor-pointer' %>" 
                              <%= isMinQty || isUnavailable ? 'disabled' : '' %>
                              onclick="<%= isMinQty || isUnavailable ? '' : `updateQty('${item.product._id}', '${item.platform}', 'decrease')` %>">
                        <i class="fa-solid fa-minus text-xs"></i>
                      </button>
                      <span class="text-white font-medium w-4 text-center"><%= item.quantity %></span>
                      <% const isMaxQty = (item.quantity >= 3); %>
                      <button aria-label="Increase quantity" 
                              class="text-pixel-muted transition-colors <%= isMaxQty || isUnavailable ? 'opacity-30 cursor-not-allowed pointer-events-none' : 'hover:text-white cursor-pointer' %>" 
                              <%= isMaxQty || isUnavailable ? 'disabled' : '' %>
                              onclick="<%= isMaxQty || isUnavailable ? '' : `updateQty('${item.product._id}', '${item.platform}', 'increase')` %>">
                        <i class="fa-solid fa-plus text-xs"></i>
                      </button>
                    </div>
                    <!-- Badges / Warnings -->
                    <div class="flex items-center gap-3">
                      <span class="text-xs font-bold <%= badgeClass %> border px-2 py-1 rounded tracking-wider"><%= badgeText %></span>
                      <% if (!isUnavailable && item.product.stock <= 5) { %>
                        <% if (isLegendary) { %>
                          <div class="flex items-center gap-1 text-pixel-warning text-sm">
                            <i class="fa-solid fa-circle-exclamation text-xs"></i>
                            <span>Only <%= item.product.stock %> left in Vault</span>
                          </div>
                        <% } else { %>
                          <div class="flex items-center gap-1 text-pixel-danger text-sm">
                            <i class="fa-solid fa-triangle-exclamation text-xs"></i>
                            <span>Only <%= item.product.stock %> left in operational facility</span>
                          </div>
                        <% } %>
                      <% } %>
                    </div>
                  </div>
                  <!-- Remove Button -->
                  <button class="text-pixel-muted hover:text-pixel-danger transition-colors flex items-center gap-2 text-sm font-medium cursor-pointer" onclick="removeCartItem('<%= item.product._id %>', '<%= item.platform %>', '<%= item.product.title.replace(/'/g, "\\'") %>')">
                    <i class="fa-regular fa-trash-can"></i>
                    Remove
                  </button>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
        <!-- END: Cart Items List -->

        <!-- BEGIN: Order Summary Sidebar -->
        <aside class="w-full lg:w-1/3 bg-pixel-card border border-pixel-border rounded-lg p-6 sticky top-24">
          <h3 class="text-lg font-bold text-white tracking-widest mb-6">ORDER SUMMARY</h3>
          <!-- Item Breakdown -->
          <div class="space-y-4 mb-6 font-mono text-sm">
            <% cart.items.forEach(item => { %>
              <div class="flex justify-between items-end text-pixel-text">
                <span><%= item.product.title %> (x<%= item.quantity %>)</span>
                <div class="dashed-line"></div>
                <span>₹<%= (item.product.price * item.quantity).toFixed(2) %></span>
              </div>
            <% }) %>
          </div>
          <!-- Totals Breakdown -->
          <div class="space-y-3 mb-6 pt-6 border-t border-pixel-border text-sm">
            <div class="flex justify-between text-pixel-muted">
              <span>Subtotal</span>
              <span>₹<%= Number(subtotal).toFixed(2) %></span>
            </div>
            <div class="flex justify-between text-pixel-muted">
              <span>GST (18%)</span>
              <span>₹<%= Number(tax).toFixed(2) %></span>
            </div>
            <div class="flex justify-between text-[#8e8e93]">
              <span>Shipping (Standard charge)</span>
              <span>₹<%= Number(shipping).toFixed(2) %></span>
            </div>
          </div>
          <!-- Grand Total -->
          <div class="flex justify-between items-center mb-8 pt-6 border-t border-pixel-border">
            <span class="text-xl font-bold text-white">Grand Total</span>
            <span class="text-3xl font-bold text-[#00b4ff]">₹<%= Number(grandTotal).toFixed(2) %></span>
          </div>
          <!-- Checkout Action -->
          <% if (typeof hasUnavailableProduct !== 'undefined' && hasUnavailableProduct) { %>
            <button disabled class="w-full bg-gray-800 text-gray-500 font-bold py-4 rounded flex items-center justify-center gap-2 mb-4 tracking-wide cursor-not-allowed opacity-50 select-none" style="pointer-events: none;">
              <i class="fa-solid fa-ban text-sm"></i>
              CHECKOUT UNAVAILABLE
            </button>
            <p class="text-xs text-red-500 text-center mb-4">
              Please remove unavailable products from your cart to proceed.
            </p>
          <% } else { %>
            <button class="w-full bg-[#00b4ff] hover:bg-[#0090cc] text-[#0f0f11] font-bold py-4 rounded transition-colors flex items-center justify-center gap-2 mb-4 tracking-wide">
              <i class="fa-solid fa-lock"></i>
              PROCEED TO CHECKOUT
            </button>
          <% } %>
          <!-- Security Footer -->
          <div class="flex items-center justify-center gap-2 text-xs text-[#8e8e93]">
            <i class="fa-solid fa-shield-halved text-[#00b4ff]"></i>
            <span>Secure Encrypted Transaction</span>
          </div>
        </aside>
        <!-- END: Order Summary Sidebar -->
      </div>
    <% } %>
  </div>
</main>
<!-- END: Main Content -->

<script>
  async function updateQty(productId, platform, action) {
    try {
      const response = await fetch('/auth/cart/update-quantity', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ productId, platform, action })
      });
      
      const data = await response.json();
      if (data.success) {
        window.location.reload();
      } else {
        console.error('Error updating quantity:', data.message);
      }
    } catch (err) {
      console.error('Network error updating quantity:', err);
    }
  }

  async function removeCartItem(productId, platform, productTitle) {
    try {
      const response = await fetch('/auth/cart/remove', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ productId, platform })
      });

      const data = await response.json();
      if (data.success) {
        showToast(`${productTitle} (${platform}) removed from cart.`, "success");
        setTimeout(() => {
          window.location.reload();
        }, 800);
      } else {
        console.error('Error removing item:', data.message);
      }
    } catch (err) {
      console.error('Network error removing item:', err);
    }
  }
</script>

<%- include('../partials/user/footer') %>