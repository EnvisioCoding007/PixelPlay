<!DOCTYPE html>
<html lang="en">

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta charset="utf-8" />
    <title><%= user.username %> — Saved Addresses · PixelPlay</title>
    <meta name="description" content="Manage your delivery locations for physical disk shipments." />
    <link rel="stylesheet" href="/globals.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {}
            },
            plugins: []
        };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-zinc-950 text-white min-h-screen flex flex-col">
    <!-- Navbar -->
    <%- include('../partials/user/navbar', { activeTab: 'profile' }) %>

    <!-- Sky blue gradient glow -->
    <div class="[background:radial-gradient(50%_50%_at_50%_75%,rgba(14,165,233,0.15)_0%,rgba(14,165,233,0)_60%)] fixed inset-0 pointer-events-none" aria-hidden="true"></div>

    <main class="relative z-10 flex-1 flex flex-col">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-10">
            <div class="flex flex-col md:flex-row items-start gap-8">

                <!-- ── Sidebar ───────────────────────────────────────────── -->
                <aside class="flex flex-col w-full md:w-72 shrink-0 items-start gap-5">

                    <!-- Profile summary card -->
                    <section aria-label="Profile summary"
                        class="relative w-full bg-[#071827] rounded-xl overflow-hidden border border-solid border-[#00000014] pt-1">
                        <!-- Sky accent bar -->
                        <div class="absolute w-full h-1 top-0 left-0 bg-sky-500 shadow-[0px_0px_15px_#0ea5e9]"></div>

                        <div class="flex flex-col items-center gap-3 px-6 pt-8 pb-6">
                            <!-- Avatar -->
                            <div class="relative w-24 h-24 rounded-full border-[3px] border-solid border-[#071827] shadow-[0px_0px_20px_#0ea5e966,0px_0px_0px_2px_#0ea5e9] overflow-hidden bg-[#1a2a3a]">
                                <% if (user.profile_image) { %>
                                    <img src="<%= user.profile_image %>" alt="<%= user.username %>'s avatar" class="w-full h-full object-cover" />
                                <% } else { %>
                                    <!-- Initials fallback -->
                                    <div class="w-full h-full flex items-center justify-center [font-family:'Inter-Bold',Helvetica] font-bold text-sky-400 text-3xl select-none">
                                        <%= user.username.charAt(0).toUpperCase() %>
                                    </div>
                                <% } %>
                                <!-- Online indicator -->
                                <span class="absolute right-1 bottom-1 w-4 h-4 bg-green-500 rounded-full border-[3px] border-solid border-[#071827]" aria-label="Online"></span>
                            </div>

                            <!-- Username & handle -->
                            <div class="flex flex-col items-center gap-0.5">
                                <h1 class="[font-family:'Inter-Bold',Helvetica] font-bold text-[#e6f7fb] text-xl text-center tracking-[0] leading-[normal]">
                                    <%= user.username %>
                                </h1>
                                <p class="[font-family:'Inter-Regular',Helvetica] font-normal text-[#98bfc9] text-sm text-center">
                                    <%= user.email %>
                                </p>
                            </div>
                        </div>
                    </section>

                    <!-- Account navigation -->
                    <nav aria-label="Account sections"
                        class="flex flex-col w-full py-3 bg-[#071827] rounded-xl border border-solid border-[#00000014]">
                        <a href="/user/profile"
                            class="flex items-center gap-3 px-6 py-3 self-stretch hover:bg-[#0ea5e90d] transition-colors">
                            <svg class="w-[18px] h-[18px] text-[#bfeaf6] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <span class="[font-family:'Inter-Medium',Helvetica] font-medium text-[#bfeaf6] text-sm">Account Overview</span>
                        </a>
                        <a href="/user/orders" class="flex items-center gap-3 px-6 py-3 self-stretch">
                            <svg class="w-[18px] h-[18px] text-[#bfeaf6] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 17H5a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v5"/><path d="M14 21l2 2 4-4"/></svg>
                            <span class="[font-family:'Inter-Medium',Helvetica] font-medium text-[#bfeaf6] text-sm">Order History</span>
                        </a>
                        <a href="#" class="flex items-center gap-3 px-6 py-3 self-stretch">
                            <svg class="w-[18px] h-[18px] text-[#bfeaf6] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2"/><path d="M1 10h22"/></svg>
                            <span class="[font-family:'Inter-Medium',Helvetica] font-medium text-[#bfeaf6] text-sm">Billing &amp; Payment</span>
                        </a>
                        <a href="/user/profile/addresses" aria-current="page"
                            class="flex items-center gap-3 pl-[21px] pr-6 py-3 self-stretch bg-[#0ea5e91a] border-l-[3px] border-l-sky-500">
                            <svg class="w-[18px] h-[18px] text-sky-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            <span class="[font-family:'Inter-Medium',Helvetica] font-medium text-sky-500 text-sm">Saved Addresses</span>
                        </a>
                        <% if (user.password_hash) { %>
                        <a href="/user/profile/password" class="flex items-center gap-3 px-6 py-3 self-stretch hover:bg-[#0ea5e90d] transition-colors">
                            <svg class="w-[18px] h-[18px] text-[#bfeaf6] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                            <span class="[font-family:'Inter-Medium',Helvetica] font-medium text-[#bfeaf6] text-sm">Password</span>
                        </a>
                        <% } %>
                        <!-- Sign out via POST to destroy session -->
                        <form action="/auth/logout" method="post" class="self-stretch">
                            <button type="submit"
                                class="all-[unset] box-border flex items-center gap-3 px-6 py-3 w-full cursor-pointer">
                                <svg class="w-[18px] h-[18px] text-red-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                                <span class="[font-family:'Inter-Medium',Helvetica] font-medium text-red-500 text-sm">Sign Out</span>
                            </button>
                        </form>
                    </nav>

                    <!-- Refer & Earn card -->
                    <% if (user.referral_code) { %>
                    <section aria-label="Refer and earn"
                        class="flex flex-col items-start gap-3 px-5 py-[18px] w-full bg-[#071827] rounded-xl border border-solid border-[#00000014]">
                        <div class="flex items-center gap-2 w-full">
                            <svg class="w-6 h-6 text-green-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            <h2 class="[font-family:'Inter-Bold',Helvetica] font-bold text-[#e6f7fb] text-[13px] leading-[16.9px]">Refer &amp; Earn</h2>
                        </div>
                        <p class="[font-family:'Inter-Regular',Helvetica] font-normal text-[#98bfc9] text-xs leading-[18px]">
                            Refer PixelPlay to friends and earn <span class="text-sky-400 font-semibold">₹10 PixelWallet</span> credit when they purchase a game.
                        </p>
                        <div class="inline-flex items-center gap-[5px] px-2.5 py-1 bg-[#22c55e14] rounded-full border border-solid border-[#22c55e33]">
                            <svg class="w-3 h-3 text-green-500" fill="currentColor" viewBox="0 0 12 12" aria-hidden="true"><path d="M10 2L4.5 8 2 5.5"/></svg>
                            <span class="[font-family:'Inter-SemiBold',Helvetica] font-semibold text-green-500 text-[11px]">+₹10 PixelWallet Credit</span>
                        </div>
                        <div class="flex items-center gap-2 w-full">
                            <div class="flex items-center gap-2 px-3 py-2 flex-1 bg-[#0f0f11] rounded border border-solid border-[#0ea5e940]">
                                <span class="[font-family:'Inter-SemiBold',Helvetica] font-semibold text-[#98bfc9] text-[10px] tracking-[0.60px] shrink-0">YOUR CODE</span>
                                <span class="[font-family:'Liberation_Mono-Bold',Helvetica] font-bold text-sky-500 text-[13px] tracking-[0.65px]">
                                    <%= user.referral_code.toUpperCase() %>
                                </span>
                            </div>
                            <button type="button" id="copy-referral-btn" aria-label="Copy referral code"
                                class="flex items-center justify-center w-8 h-8 bg-[#0ea5e91a] rounded border border-solid border-[#0ea5e933] cursor-pointer hover:bg-[#0ea5e933] transition-colors">
                                <svg class="w-4 h-4 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                            </button>
                        </div>
                    </section>
                    <% } %>
                </aside>

                <!-- ── Main Content Panel ─────────────────────────────────── -->
                <div class="flex flex-col items-start gap-8 flex-1 w-full min-w-0">

                    <!-- Saved addresses section header -->
                    <section class="flex flex-col items-start gap-4 w-full" aria-labelledby="shipping-addresses-heading">
                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between pb-6 w-full border-b border-zinc-800 gap-4">
                            <div class="flex flex-col gap-1">
                                <h1 id="shipping-addresses-heading"
                                    class="[font-family:'Inter-Bold',Helvetica] font-bold text-zinc-100 text-3xl tracking-tight">
                                    Shipping Addresses
                                </h1>
                                <p class="[font-family:'Inter-Regular',Helvetica] font-normal text-zinc-400 text-sm">
                                    Manage your delivery locations for shipping physical orders and merchandise.
                                </p>
                            </div>
                            <button type="button" id="open-add-modal-btn"
                                class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-sky-500 hover:bg-sky-400 text-zinc-950 font-bold text-sm rounded shadow-[0px_0px_15px_#0ea5e966] transition-colors cursor-pointer shrink-0">
                                <svg class="w-4.5 h-4.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                                <span>Add New Address</span>
                            </button>
                        </div>

                        <!-- Address List Loop Grid -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full pt-4">
                            <% if (user.addresses && user.addresses.length > 0) { %>
                                <% user.addresses.forEach(address => { %>
                                    <article id="address-card-<%= address._id %>" 
                                        class="relative flex flex-col justify-between p-6 bg-[#071827] rounded-xl border border-solid <%= address.isDefault ? 'border-sky-500 shadow-[0px_0px_20px_#0ea5e91a]' : 'border-zinc-800 hover:border-zinc-700' %> transition-all duration-300">
                                        
                                        <% if (address.isDefault) { %>
                                            <div class="absolute top-0 right-0 mt-4 mr-4">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-sky-500/20 text-sky-400 border border-sky-500/30 tracking-wider">PRIMARY</span>
                                            </div>
                                        <% } %>

                                        <div class="flex flex-col gap-3">
                                            <div class="flex items-center gap-2 pr-20">
                                                <span class="text-zinc-500">
                                                    <% if (address.address_type === 'home') { %>
                                                        <svg class="w-4 h-4 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
                                                    <% } else if (address.address_type === 'office') { %>
                                                        <svg class="w-4 h-4 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 16.5h1.5M13.5 16.5H15"/></svg>
                                                    <% } else { %>
                                                        <svg class="w-4 h-4 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25a7.5 7.5 0 1115 0z"/></svg>
                                                    <% } %>
                                                </span>
                                                <h2 class="[font-family:'Inter-SemiBold',Helvetica] font-semibold text-zinc-100 text-base truncate">
                                                    <%= address.fullName %>
                                                </h2>
                                            </div>

                                            <div class="flex flex-col gap-1 text-sm text-zinc-300">
                                                <p class="leading-relaxed [font-family:'Inter-Regular',Helvetica]">
                                                    <%= address.addressLine1 %>
                                                    <% if (address.addressLine2) { %>
                                                        <br /><%= address.addressLine2 %>
                                                    <% } %>
                                                    <br /><%= address.city %>, <%= address.state %> <%= address.postal_code %>
                                                    <br /><%= address.country %>
                                                </p>
                                                <div class="flex items-center gap-2 mt-2 text-zinc-400 text-xs [font-family:'Inter-Regular',Helvetica]">
                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.824-1.557-5.145-3.878-6.702-6.702l1.293-.97a1.125 1.125 0 00.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
                                                    <span><%= address.phone %></span>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Edit and Delete Actions -->
                                        <div class="flex items-center gap-4 pt-4 mt-6 border-t border-zinc-800/60">
                                            <button type="button" onclick="openEditModal(<%= JSON.stringify(address) %>)"
                                                class="flex items-center gap-1.5 text-xs font-semibold text-sky-400 hover:text-sky-300 transition-colors cursor-pointer">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
                                                <span>Edit</span>
                                            </button>
                                            <button type="button" onclick="deleteAddress('<%= address._id %>')"
                                                class="flex items-center gap-1.5 text-xs font-semibold text-red-400 hover:text-red-300 transition-colors cursor-pointer">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/></svg>
                                                <span>Remove</span>
                                            </button>
                                        </div>

                                    </article>
                                <% }); %>
                            <% } else { %>
                                <!-- Empty state fallback -->
                                <div class="col-span-full flex flex-col items-center justify-center p-12 bg-[#071827] rounded-xl border border-dashed border-zinc-800 text-center gap-4">
                                    <div class="w-12 h-12 rounded-full bg-zinc-900 flex items-center justify-center text-zinc-500">
                                        <svg class="w-6 h-6 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25a7.5 7.5 0 1115 0z"/></svg>
                                    </div>
                                    <div class="flex flex-col gap-1">
                                        <h3 class="font-bold text-zinc-200">No saved addresses</h3>
                                        <p class="text-sm text-zinc-500 max-w-sm">Please add a shipping address to facilitate physical deliveries and checkout.</p>
                                    </div>
                                    <button type="button" onclick="document.getElementById('open-add-modal-btn').click()"
                                        class="px-4 py-2 text-xs font-semibold bg-sky-500 hover:bg-sky-400 text-zinc-950 rounded transition-colors cursor-pointer">
                                        Add Your First Address
                                    </button>
                                </div>
                            <% } %>
                        </div>
                    </section>

                </div>
            </div>
        </div>
    </main>

    <!-- ── Modals Layer ─────────────────────────────────────────────────── -->

    <!-- Add Address Modal -->
    <div id="add-address-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-zinc-950/80 backdrop-blur-sm overflow-y-auto">
        <div class="relative bg-[#071827] border border-zinc-800 rounded-xl max-w-lg w-full p-6 shadow-2xl my-8">
            <!-- Close button -->
            <button type="button" class="absolute top-4 right-4 text-zinc-400 hover:text-white close-modal-btn cursor-pointer">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
            
            <h2 class="text-xl font-bold text-zinc-100 mb-6 flex items-center gap-2 [font-family:'Inter-Bold',Helvetica]">
                <svg class="w-5 h-5 text-sky-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                <span>Add New Address</span>
            </h2>
            <p class="text-xs text-zinc-400 mb-4 [font-family:'Inter-Regular',Helvetica]">Fields marked with <span class="text-red-500">*</span> are required to be filled.</p>
            
            <form id="add-address-form" class="space-y-4" novalidate>
                <div id="add-error" class="hidden text-red-500 text-xs bg-red-950/50 border border-red-500/20 p-3 rounded [font-family:'Inter-Regular',Helvetica]"></div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2 [font-family:'Inter-Medium',Helvetica]" for="add-fullName">Full Name *</label>
                        <input type="text" id="add-fullName" name="fullName" required
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                        <span class="validation-error text-red-500 text-xs mt-1 hidden font-medium block"></span>
                    </div>
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2 [font-family:'Inter-Medium',Helvetica]" for="add-phone">Phone Number *</label>
                        <input type="tel" id="add-phone" name="phone" required
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                        <span class="validation-error text-red-500 text-xs mt-1 hidden font-medium block"></span>
                    </div>
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2 [font-family:'Inter-Medium',Helvetica]" for="add-addressLine1">Address Line 1 *</label>
                    <input type="text" id="add-addressLine1" name="addressLine1" required placeholder="Street address, P.O. box, company name"
                        class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                    <span class="validation-error text-red-500 text-xs mt-1 hidden font-medium block"></span>
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2 [font-family:'Inter-Medium',Helvetica]" for="add-addressLine2">Address Line 2 (Optional)</label>
                    <input type="text" id="add-addressLine2" name="addressLine2" placeholder="Apartment, suite, unit, building, floor, etc."
                        class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2 [font-family:'Inter-Medium',Helvetica]" for="add-city">City *</label>
                        <input type="text" id="add-city" name="city" required
