    <!-- Toast Notifications Container -->
    <div id="toast-container" class="fixed top-5 right-5 z-[100] flex flex-col gap-3"></div>

    <script>
        (function () {
            // Refer-a-friend copy button action
            const copyBtn = document.getElementById('copy-referral-btn');
            if (copyBtn) {
                copyBtn.addEventListener('click', async () => {
                    const code = '<%= user.referral_code ? user.referral_code.toUpperCase() : "" %>';
                    try {
                        await navigator.clipboard.writeText(code);
                        const originalContent = copyBtn.innerHTML;
                        copyBtn.innerHTML = '<svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
                        setTimeout(() => {
                            copyBtn.innerHTML = originalContent;
                        }, 2000);
                    } catch (_) {}
                });
            }

            // Modal references
            const addModal = document.getElementById('add-address-modal');
            const editModal = document.getElementById('edit-address-modal');
            const addBtn = document.getElementById('open-add-modal-btn');
            const closeBtns = document.querySelectorAll('.close-modal-btn');
            const editCloseBtns = document.querySelectorAll('.edit-close-modal-btn');

            // Forms references
            const addForm = document.getElementById('add-address-form');
            const editForm = document.getElementById('edit-address-form');

            // Error displays
            const addError = document.getElementById('add-error');
            const editError = document.getElementById('edit-error');

            // Toast display elements
            const toastContainer = document.getElementById('toast-container');

            function showToast(message, type = 'success') {
                const toast = document.createElement('div');
                toast.className = `flex items-center gap-3 px-4 py-3 rounded-lg shadow-lg border text-sm transition-all duration-300 transform translate-y-2 opacity-0 [font-family:'Inter-Medium',Helvetica] ${
                    type === 'success' 
                        ? 'bg-[#072412] text-green-400 border-green-500/30' 
                        : 'bg-[#2a080c] text-red-400 border-red-500/30'
                }`;
                toast.innerHTML = `<span>${message}</span>`;
                toastContainer.appendChild(toast);
                
                setTimeout(() => {
                    toast.classList.remove('translate-y-2', 'opacity-0');
                }, 10);
                
                setTimeout(() => {
                    toast.classList.add('opacity-0', 'translate-y-2');
                    setTimeout(() => {
                        toast.remove();
                    }, 300);
                }, 3000);
            }

            // Modal actions
            if (addBtn) {
                addBtn.addEventListener('click', () => {
                    addForm.reset();
                    addError.classList.add('hidden');
                    addForm.querySelectorAll('.validation-error').forEach(span => {
                        span.textContent = '';
                        span.classList.add('hidden');
                    });
                    addForm.querySelectorAll('input').forEach(input => {
                        input.classList.remove('border-red-500');
                        input.classList.add('border-zinc-800');
                    });
                    addModal.classList.remove('hidden');
                    addModal.classList.add('flex');
                    document.body.classList.add('overflow-hidden');
                });
            }

            closeBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    addModal.classList.add('hidden');
                    addModal.classList.remove('flex');
                    document.body.classList.remove('overflow-hidden');
                });
            });

            editCloseBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    editModal.classList.add('hidden');
                    editModal.classList.remove('flex');
                    document.body.classList.remove('overflow-hidden');
                });
            });

            addModal.addEventListener('click', (e) => {
                if (e.target === addModal) {
                    addModal.classList.add('hidden');
                    addModal.classList.remove('flex');
                    document.body.classList.remove('overflow-hidden');
                }
            });

            editModal.addEventListener('click', (e) => {
                if (e.target === editModal) {
                    editModal.classList.add('hidden');
                    editModal.classList.remove('flex');
                    document.body.classList.remove('overflow-hidden');
                }
            });

            window.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') {
                    addModal.classList.add('hidden');
                    addModal.classList.remove('flex');
                    editModal.classList.add('hidden');
                    editModal.classList.remove('flex');
                    document.body.classList.remove('overflow-hidden');
                }
            });

            // Populate and open edit modal
            window.openEditModal = function(address) {
                editError.classList.add('hidden');
                editForm.querySelectorAll('.validation-error').forEach(span => {
                    span.textContent = '';
                    span.classList.add('hidden');
                });
                editForm.querySelectorAll('input').forEach(input => {
                    input.classList.remove('border-red-500');
                    input.classList.add('border-zinc-800');
                });
                
                document.getElementById('edit-id').value = address._id || '';
                document.getElementById('edit-fullName').value = address.fullName || '';
                document.getElementById('edit-phone').value = address.phone || '';
                document.getElementById('edit-addressLine1').value = address.addressLine1 || '';
                document.getElementById('edit-addressLine2').value = address.addressLine2 || '';
                document.getElementById('edit-city').value = address.city || '';
                document.getElementById('edit-state').value = address.state || '';
                document.getElementById('edit-postal_code').value = address.postal_code || '';
                document.getElementById('edit-country').value = address.country || 'India';
                document.getElementById('edit-address_type').value = address.address_type || 'home';
                document.getElementById('edit-isDefault').checked = address.isDefault === true || address.isDefault === 'true';

                editModal.classList.remove('hidden');
                editModal.classList.add('flex');
                document.body.classList.add('overflow-hidden');
            };

            // Form validation helper
            function validateAddressForm(form, errorDiv) {
                // Clear general error
                errorDiv.textContent = '';
                errorDiv.classList.add('hidden');

                // Clear all field-specific errors
                const errorSpans = form.querySelectorAll('.validation-error');
                errorSpans.forEach(span => {
                    span.textContent = '';
                    span.classList.add('hidden');
                });

                // Clear input highlight borders
                const inputs = form.querySelectorAll('input');
                inputs.forEach(input => {
                    input.classList.remove('border-red-500');
                    input.classList.add('border-zinc-800');
                });

                let isValid = true;

                const fullNameInput = form.querySelector('[name="fullName"]');
                const phoneInput = form.querySelector('[name="phone"]');
                const addressLine1Input = form.querySelector('[name="addressLine1"]');
                const cityInput = form.querySelector('[name="city"]');
                const stateInput = form.querySelector('[name="state"]');
                const postalCodeInput = form.querySelector('[name="postal_code"]');
                const countryInput = form.querySelector('[name="country"]');

                const requiredFields = [
                    { input: fullNameInput, name: 'Full Name' },
                    { input: phoneInput, name: 'Phone Number' },
                    { input: addressLine1Input, name: 'Address Line 1' },
                    { input: cityInput, name: 'City' },
                    { input: stateInput, name: 'State' },
                    { input: postalCodeInput, name: 'Postal Code' },
                    { input: countryInput, name: 'Country' }
                ];

                requiredFields.forEach(field => {
                    const val = field.input.value.trim();
                    if (!val) {
                        const errorSpan = field.input.parentNode.querySelector('.validation-error');
                        if (errorSpan) {
                            errorSpan.textContent = `${field.name} is required.`;
                            errorSpan.classList.remove('hidden');
                        }
                        field.input.classList.remove('border-zinc-800');
                        field.input.classList.add('border-red-500');
                        isValid = false;
                    }
                });

                if (!isValid) {
                    errorDiv.textContent = 'Please fill in all required fields marked with *';
                    errorDiv.classList.remove('hidden');
                    return false;
                }

                // Phone Validation
                const phone = phoneInput.value.trim();
                const cleanPhone = phone.replace(/[\s-]/g, '');
                const phoneRegex = /^(?:\+91|91|0)?[6-9]\d{9}$/;
                if (!phoneRegex.test(cleanPhone)) {
                    const errorSpan = phoneInput.parentNode.querySelector('.validation-error');
                    if (errorSpan) {
                        errorSpan.textContent = 'Please enter a valid phone number (10 to 12 digits, optional +91)';
                        errorSpan.classList.remove('hidden');
                    }
                    phoneInput.classList.remove('border-zinc-800');
                    phoneInput.classList.add('border-red-500');
                    isValid = false;
                }

                // Postal Code Validation
                const postal_code = postalCodeInput.value.trim();
                if (!/^\d{6}$/.test(postal_code)) {
                    const errorSpan = postalCodeInput.parentNode.querySelector('.validation-error');
                    if (errorSpan) {
                        errorSpan.textContent = 'Postal code must be exactly 6 digits';
                        errorSpan.classList.remove('hidden');
                    }
                    postalCodeInput.classList.remove('border-zinc-800');
                    postalCodeInput.classList.add('border-red-500');
                    isValid = false;
                }

                if (!isValid) {
                    return false;
                }

                errorDiv.classList.add('hidden');
                return {
                    fullName: fullNameInput.value.trim(),
                    phone: phoneInput.value.trim(),
                    addressLine1: addressLine1Input.value.trim(),
                    addressLine2: form.querySelector('[name="addressLine2"]').value.trim(),
                    city: cityInput.value.trim(),
                    state: stateInput.value.trim(),
                    postal_code: postalCodeInput.value.trim(),
                    country: countryInput.value.trim(),
                    address_type: form.querySelector('[name="address_type"]').value,
                    isDefault: form.querySelector('[name="isDefault"]').checked
                };
            }

            // Save Address Submit
            addForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const payload = validateAddressForm(addForm, addError);
                if (!payload) return;

                try {
                    const response = await fetch('/user/profile/addresses', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    const data = await response.json();
                    if (response.ok && data.success) {
                        showToast(data.message || 'Address added successfully.');
                        addModal.classList.add('hidden');
                        addModal.classList.remove('flex');
                        document.body.classList.remove('overflow-hidden');
                        setTimeout(() => {
                            location.reload();
                        }, 800);
                    } else {
                        addError.textContent = data.message || 'Failed to add address.';
                        addError.classList.remove('hidden');
                    }
                } catch (err) {
                    addError.textContent = 'Network error. Please try again.';
                    addError.classList.remove('hidden');
                }
            });

            // Update Address Submit
            editForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const payload = validateAddressForm(editForm, editError);
                if (!payload) return;
                
                const addressId = document.getElementById('edit-id').value;

                try {
                    const response = await fetch(`/user/profile/addresses/${addressId}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    const data = await response.json();
                    if (response.ok && data.success) {
                        showToast(data.message || 'Address updated successfully.');
                        editModal.classList.add('hidden');
                        editModal.classList.remove('flex');
                        document.body.classList.remove('overflow-hidden');
                        setTimeout(() => {
                            location.reload();
                        }, 800);
                    } else {
                        editError.textContent = data.message || 'Failed to update address.';
                        editError.classList.remove('hidden');
                    }
                } catch (err) {
                    editError.textContent = 'Network error. Please try again.';
                    editError.classList.remove('hidden');
                }
            });

            // Delete Address Fetch Action
            window.deleteAddress = async function (addressId) {
                const result = await Swal.fire({
                    title: 'Delete Address?',
                    text: 'Are you sure you want to delete this address?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, delete it!',
                    cancelButtonText: 'Cancel',
                    background: '#071827',
                    color: '#fff',
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#3f3f46'
                });
                if (!result.isConfirmed) return;

                try {
                    const response = await fetch(`/user/profile/addresses/${addressId}`, {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' }
                    });

                    const data = await response.json();
                    if (response.ok && data.success) {
                        showToast(data.message || 'Address deleted successfully.');
                        const card = document.getElementById(`address-card-${addressId}`);
                        if (card) {
                            card.classList.add('opacity-0', 'scale-95');
                            setTimeout(() => {
                                card.remove();
                                const cardsContainer = document.querySelector('.grid');
                                if (cardsContainer && cardsContainer.querySelectorAll('article').length === 0) {
                                    location.reload();
                                }
                            }, 300);
                        } else {
                            setTimeout(() => {
                                location.reload();
                            }, 800);
                        }
                    } else {
                        showToast(data.message || 'Failed to delete address.', 'error');
                    }
                } catch (err) {
                    showToast('Network error. Please try again.', 'error');
                }
            };
        })();
    </script>
</body>

</html>