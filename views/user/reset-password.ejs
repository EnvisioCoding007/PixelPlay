<!DOCTYPE html>
<html lang="en">

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta charset="utf-8" />
    <title>Establish New Credentials - CODEX ARC</title>
    <link rel="stylesheet" href="/globals.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        /** @type {import('tailwindcss').Config} */
        tailwind.config = {
            theme: {
                extend: {},
            },
            plugins: [],
        }
    </script>
</head>

<body>
    <main
        class="flex min-h-screen items-center justify-center px-10 py-20 relative [background:linear-gradient(0deg,rgba(19,19,21,1)_0%,rgba(19,19,21,1)_100%),linear-gradient(0deg,rgba(255,255,255,1)_0%,rgba(255,255,255,1)_100%)] w-full min-w-[1440px] overflow-hidden">
        <div class="flex-col h-full justify-center absolute inset-0 flex w-full items-start" aria-hidden="true">
            <div
                class="relative flex-1 self-stretch w-full grow opacity-30 bg-[url(legacy:image:md5:5:224-no-children)] bg-cover bg-[50%_50%]">
            </div>
            <div
                class="absolute w-full h-full top-0 left-0 bg-[#131315cc] backdrop-blur-[2px] backdrop-brightness-[100%] [-webkit-backdrop-filter:blur(2px)_brightness(100%)]">
            </div>
            <div
                class="absolute w-full h-full top-0 left-0 [background:linear-gradient(180deg,rgba(0,240,255,0.03)_3%,rgba(0,240,255,0)_3%),linear-gradient(90deg,rgba(0,240,255,0.03)_3%,rgba(0,240,255,0)_3%)]">
            </div>
        </div>
        <section class="flex flex-col max-w-[480px] w-full items-start relative z-10"
            aria-labelledby="new-credentials-title">
            <div
                class="flex flex-col items-start gap-8 p-8 relative self-stretch w-full flex-[0_0_auto] bg-[#18181bcc] rounded-lg overflow-hidden border border-solid border-[#3b494b] shadow-[0px_8px_32px_#00000080] backdrop-blur-[6px] backdrop-brightness-[100%] [-webkit-backdrop-filter:blur(6px)_brightness(100%)]">
                <header
                    class="flex flex-col items-center gap-2 pt-4 pb-0 px-0 relative self-stretch w-full flex-[0_0_auto]">
                    <div class="flex w-12 items-center justify-center px-0 py-[11px] relative flex-[0_0_auto] bg-[#00f0ff1a] rounded-xl border border-solid border-[#00f0ff4c]"
                        aria-hidden="true">
                        <div class="inline-flex flex-col items-center relative flex-[0_0_auto]">
                            <img class="relative w-5 h-5" src="/img/icon-4.svg" alt="" />
                        </div>
                    </div>
                    <div class="flex flex-col items-center pt-4 pb-0 px-0 relative self-stretch w-full flex-[0_0_auto]">
                        <h1 id="new-credentials-title"
                            class="relative flex items-center justify-center w-[390.31px] max-w-full h-[39px] mt-[-1.00px] [font-family:'Space_Grotesk-Bold',Helvetica] font-bold text-[#e5e1e4] text-[32px] text-center tracking-[-0.32px] leading-[38.4px] whitespace-nowrap">
                            Establish New Credentials</h1>
                    </div>
                    <div class="flex flex-col items-center relative self-stretch w-full flex-[0_0_auto]">
                        <p
                            class="justify-center w-[409.39px] max-w-full h-6 mt-[-1.00px] [font-family:'Inter-Regular',Helvetica] font-normal text-[#b9cacb] text-base text-center tracking-[0] leading-6 relative flex items-center whitespace-nowrap">
                            Secure your Codex Arc account with a new password.</p>
                    </div>
                </header>

                <%# Bug 4 & 7 Fix: standardised #alert-message container; JS validation drives
                    all error display; focus listeners clear the state on re-engagement. %>
                <div id="alert-message" class="hidden w-full px-4 py-3 rounded relative text-center text-sm font-medium"></div>

                <%# Bug 4 Fix: removed HTML `required` attributes from both inputs — JS handles validation. %>
                <form id="reset-password-form"
                    class="flex flex-col items-start gap-6 relative self-stretch w-full flex-[0_0_auto]" action="#"
                    method="post" novalidate>

                    <div class="flex flex-col items-start gap-2 relative self-stretch w-full flex-[0_0_auto]">
                        <label for="new-password"
                            class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                            <span
                                class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'Space_Grotesk-Bold',Helvetica] font-bold text-[#b9cacb] text-xs tracking-[1.20px] leading-3">NEW
                                PASSWORD</span>
                        </label>
                        <div
                            class="flex-col relative self-stretch flex-[0_0_auto] bg-[#131315] rounded-sm border border-solid border-[#3b494b] flex w-full items-start">
                            <div
                                class="flex items-start justify-center pt-3.5 pb-[13px] px-10 relative self-stretch w-full flex-[0_0_auto]">
                                <div class="flex flex-col items-start relative flex-1 grow">
                                    <input id="new-password" name="password" type="password"
                                        autocomplete="new-password" placeholder="Enter new password"
                                        aria-describedby="password-strength-text"
                                        class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'Space_Grotesk-Regular',Helvetica] font-normal text-[#b9cacb] placeholder:text-[#b9cacb80] text-base tracking-[1.60px] leading-[normal] bg-transparent border-0 outline-none p-0 w-full" />
                                </div>
                            </div>
                            <div class="inline-flex flex-col h-[48.00%] items-start absolute top-[26.00%] left-[13px] pointer-events-none"
                                aria-hidden="true">
                                <img class="relative w-[23px] h-3" src="/img/icon.svg" alt="" />
                            </div>
                            <button type="button" aria-label="Show password" id="toggle-new-password"
                                class="inline-flex flex-col items-center justify-center absolute h-[30.61%] top-[34.69%] right-[13px] bg-transparent border-0 p-0 cursor-pointer">
                                <span class="inline-flex items-start justify-center relative flex-[0_0_auto]">
                                    <img class="relative w-[22px] h-[15px]" src="/img/icon-3.svg" alt="" />
                                </span>
                            </button>
                        </div>
                    </div>
                    <div class="flex flex-col items-start gap-2 relative self-stretch w-full flex-[0_0_auto]">
                        <label for="confirm-password"
                            class="flex flex-col items-start relative self-stretch w-full flex-[0_0_auto]">
                            <span
                                class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'Space_Grotesk-Bold',Helvetica] font-bold text-[#b9cacb] text-xs tracking-[1.20px] leading-3">CONFIRM
                                NEW PASSWORD</span>
                        </label>
                        <div
                            class="flex-col relative self-stretch flex-[0_0_auto] bg-[#131315] rounded-sm border border-solid border-[#3b494b] flex w-full items-start">
                            <div
                                class="flex items-start justify-center pt-3.5 pb-[13px] px-10 relative self-stretch w-full flex-[0_0_auto]">
                                <div class="flex flex-col items-start relative flex-1 grow">
                                    <input id="confirm-password" name="confirmPassword" type="password"
                                        autocomplete="new-password" placeholder="Re-enter new password"
                                        class="relative flex items-center self-stretch mt-[-1.00px] [font-family:'Space_Grotesk-Regular',Helvetica] font-normal text-[#b9cacb] placeholder:text-[#b9cacb80] text-base tracking-[1.60px] leading-[normal] bg-transparent border-0 outline-none p-0 w-full" />
                                </div>
                            </div>
                            <div class="inline-flex flex-col h-[48.00%] items-start absolute top-[26.00%] left-[13px] pointer-events-none"
                                aria-hidden="true">
                                <img class="relative w-4 h-[21px]" src="/img/icon-5.svg" alt="" />
                            </div>
                            <button type="button" aria-label="Show confirm password" id="toggle-confirm-password"
                                class="inline-flex flex-col items-center justify-center absolute h-[30.61%] top-[34.69%] right-[13px] bg-transparent border-0 p-0 cursor-pointer">
                                <span class="inline-flex items-start justify-center relative flex-[0_0_auto]">
                                    <img class="relative w-[22px] h-[15px]" src="/img/icon-6.svg" alt="" />
                                </span>
                            </button>
                        </div>
                    </div>
                    <div
                        class="flex flex-col items-start gap-2 pt-2 pb-4 px-0 relative self-stretch w-full flex-[0_0_auto]">
                        <div class="h-1 gap-1 relative self-stretch bg-[#39393b] rounded-xl overflow-hidden flex w-full items-start"
                            aria-hidden="true">
                            <div class="relative flex-1 self-stretch grow bg-[#00f0ff4c] rounded-xl"></div>
                            <div class="relative flex-1 self-stretch grow bg-[#00f0ff4c] rounded-xl"></div>
                            <div class="relative flex-1 self-stretch grow bg-[#353437] rounded-xl"></div>
                            <div class="relative flex-1 self-stretch grow bg-[#353437] rounded-xl"></div>
                        </div>
                        <div class="flex flex-col items-end relative self-stretch w-full flex-[0_0_auto]">
                            <p id="password-strength-text"
                                class="justify-end w-[119.16px] h-3 mt-[-1.00px] [font-family:'Space_Grotesk-Bold',Helvetica] font-bold text-[#b9cacb] text-xs text-right tracking-[1.20px] leading-3 relative flex items-center whitespace-nowrap">
                                Medium Strength</p>
                        </div>
                    </div>
                    <button type="submit" id="submit-btn"
                        class="flex items-center justify-center gap-2 px-0 py-4 relative self-stretch w-full flex-[0_0_auto] bg-[#00f0ff] hover:bg-[#00c8d4] transition-colors rounded-sm border-0 cursor-pointer">
                        <span
                            class="justify-center w-[127.77px] h-3 [font-family:'Space_Grotesk-Bold',Helvetica] font-bold text-[#002022] text-xs text-center tracking-[1.20px] leading-3 relative flex items-center whitespace-nowrap">UPDATE
                            PASSWORD</span>
                        <span class="inline-flex flex-col items-center relative flex-[0_0_auto]" aria-hidden="true">
                            <img class="relative w-4 h-4" src="/img/icon-2.svg" alt="" />
                        </span>
                    </button>
                </form>
                <div class="flex flex-col items-center relative self-stretch w-full flex-[0_0_auto]">
                    <a href="/auth/login"
                        class="inline-flex items-center gap-1 relative flex-[0_0_auto] hover:opacity-80 transition-opacity">
                        <span class="inline-flex flex-col items-center relative flex-[0_0_auto]" aria-hidden="true">
                            <img class="relative w-[10.67px] h-[10.67px]" src="/img/image.svg" alt="" />
                        </span>
                        <span
                            class="justify-center w-[116.92px] h-3 mt-[-1.00px] [font-family:'Space_Grotesk-Bold',Helvetica] font-bold text-[#00f0ff] text-xs text-center tracking-[1.20px] leading-3 relative flex items-center whitespace-nowrap">RETURN
                            TO LOGIN</span>
                    </a>
                </div>
            </div>
        </section>
    </main>

    <script>
        // ── Bug 5 Fix: enforce strong password policy via regex ──────────────────
        // ≥8 chars | ≥1 uppercase | ≥1 lowercase | ≥1 digit | ≥1 special char
        const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]).{8,}$/;

        const resetForm = document.getElementById('reset-password-form');
        const alertMsg  = document.getElementById('alert-message');
        const submitBtn = document.getElementById('submit-btn');

        const displayAlert = (msg, type) => {
            alertMsg.textContent = msg;
            alertMsg.className = `w-full px-4 py-3 rounded relative text-center text-sm font-medium mb-4 ${
                type === 'success'
                    ? 'bg-green-100 border border-green-400 text-green-700'
                    : 'bg-red-100 border border-red-400 text-red-700'
            }`;
        };

        // ── Bug 7 Fix: clear alert on focus/input on any input field ─────────────
        document.querySelectorAll('input[type="text"], input[type="email"], input[type="password"]')
            .forEach(function (input) {
                ['focus', 'input'].forEach(function (evt) {
                    input.addEventListener(evt, function () {
                        alertMsg.classList.add('hidden');
                    });
                });
            });

        // ── Form submit handler ───────────────────────────────────────────────────
        resetForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            alertMsg.classList.add('hidden');

            const password        = document.getElementById('new-password').value;
            const confirmPassword = document.getElementById('confirm-password').value;

            // — JS validation (Bug 4 & 5) —
            if (!password) {
                displayAlert('New password is required.', 'error');
                return;
            }
            if (!passwordRegex.test(password)) {
                displayAlert('Password must be at least 8 characters and include an uppercase letter, lowercase letter, number, and special character.', 'error');
                return;
            }
            if (password !== confirmPassword) {
                displayAlert('Passwords do not match.', 'error');
                return;
            }

            submitBtn.disabled = true;
            submitBtn.style.opacity = '0.7';

            try {
                const response = await fetch('/auth/reset-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ password, confirmPassword })
                });

                const data = await response.json();

                if (response.ok) {
                    displayAlert(data.message || 'Password updated successfully.', 'success');
                    setTimeout(() => {
                        window.location.href = data.redirectUrl || '/auth/login';
                    }, 1500);
                } else {
                    displayAlert(data.message || 'Failed to reset password. Please try again.', 'error');
                    submitBtn.disabled = false;
                    submitBtn.style.opacity = '1';
                }
            } catch (error) {
                displayAlert('A network error occurred. Please try again.', 'error');
                submitBtn.disabled = false;
                submitBtn.style.opacity = '1';
            }
        });

        document.getElementById('toggle-new-password').addEventListener('click', () => {
            const pwdInput = document.getElementById('new-password');
            pwdInput.type = pwdInput.type === 'password' ? 'text' : 'password';
        });

        document.getElementById('toggle-confirm-password').addEventListener('click', () => {
            const confirmInput = document.getElementById('confirm-password');
            confirmInput.type = confirmInput.type === 'password' ? 'text' : 'password';
        });
    </script>
</body>

</html>