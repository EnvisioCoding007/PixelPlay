<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>PixelPlay - Order Details</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <style data-purpose="custom-fonts">
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        body {
            font-family: 'Inter', sans-serif;
            background-color: #0d0d0f;
            /* Darker background matching image */
            color: #e5e7eb;
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        pixelplay: {
                            bg: '#0d0d0f',
                            panel: '#151518',
                            accent: '#00b8ff',
                            accentHover: '#0099cc',
                            red: '#ff4d4f',
                            gold: '#d4af37',
                            goldBg: '#2a220c',
                            goldBorder: '#4a3a14',
                            textMuted: '#9ca3af',
                            border: '#27272a'
                        }
                    }
                }
            }
        }
    </script>
</head>

<body
    class="antialiased min-h-screen flex flex-col font-sans bg-pixelplay-bg text-gray-200 selection:bg-pixelplay-accent selection:text-white">
    <!-- BEGIN: MainHeader -->
    <%- include('../partials/user/navbar', { activeTab: 'profile', user: typeof user !== 'undefined' ? user : null }) %>
    <!-- END: MainHeader -->
    <!-- BEGIN: MainContent -->
    <main class="flex-grow w-full max-w-[1200px] mx-auto px-6 py-8">
        <!-- Top Navigation & Title -->
        <div class="mb-8">
            <a class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white mb-6 transition-colors font-medium"
                href="/user/orders">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                    <path d="M10 19l-7-7m0 0l7-7m-7 7h18" stroke-linecap="round" stroke-linejoin="round"
                        stroke-width="2"></path>
                </svg>
                Back to Order History
            </a>
            <div class="flex flex-col gap-1">
                <h1 class="text-3xl font-bold text-white tracking-tight">Order Details</h1>
                <div class="text-sm font-medium flex flex-wrap gap-x-6 gap-y-1 text-gray-400 font-mono">
                    <span>Order ID: <span class="text-gray-300">#<%= order.orderId %></span></span>
                    <span>Order Date: <span class="text-gray-300"><%= new Date(order.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span></span>
                    <% if (order.status === 'Cancelled' && order.cancellationDate) { %>
                        <span class="text-red-400">Cancellation Date: <span class="text-gray-300"><%= new Date(order.cancellationDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span></span>
                        <span class="text-red-400">Reason: <span class="text-gray-300"><%= order.cancellationReason || 'N/A' %></span></span>
                    <% } %>
                </div>
            </div>
        </div>
        <!-- Status Banner -->
        <%
            let bannerBg = 'bg-pixelplay-goldBg border-pixelplay-goldBorder';
            let bannerIcon = 'bg-pixelplay-gold/20 text-pixelplay-gold';
            let bannerText = 'text-pixelplay-gold';
            let bannerDot = 'bg-pixelplay-gold';

            if (order.status === 'Processing' || order.status === 'Return Requested') {
                bannerBg = 'bg-[#2a220c] border-[#4a3a14]';
                bannerIcon = 'bg-pixelplay-gold/20 text-pixelplay-gold';
                bannerText = 'text-pixelplay-gold';
                bannerDot = 'bg-pixelplay-gold';
            } else if (order.status === 'Shipped') {
                bannerBg = 'bg-[#0c242a] border-[#143d47]';
                bannerIcon = 'bg-pixelplay-accent/20 text-pixelplay-accent';
                bannerText = 'text-pixelplay-accent';
                bannerDot = 'bg-pixelplay-accent';
            } else if (order.status === 'Delivered' || order.status === 'Returned') {
                bannerBg = 'bg-[#0e271c] border-[#153f2c]';
                bannerIcon = 'bg-green-500/20 text-green-400';
                bannerText = 'text-green-400';
                bannerDot = 'bg-green-400';
            } else if (order.status === 'Cancelled') {
                bannerBg = 'bg-[#2a0e0e] border-[#471515]';
                bannerIcon = 'bg-pixelplay-red/20 text-pixelplay-red';
                bannerText = 'text-pixelplay-red';
                bannerDot = 'bg-pixelplay-red';
            }
        %>
        <div
            class="<%= bannerBg %> border rounded-xl p-5 mb-10 flex gap-4 items-start shadow-sm">
            <div class="p-2 <%= bannerIcon %> rounded-lg shrink-0 mt-0.5">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                    <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" stroke-linecap="round"
                        stroke-linejoin="round" stroke-width="2"></path>
                </svg>
            </div>
            <div>
                <h3 class="<%= bannerText %> font-semibold text-lg flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full <%= bannerDot %> animate-pulse"></span>
                    Status: <%= order.status %>
                </h3>
                <p class="text-gray-300 mt-1 text-sm">
                    <% if (order.status === 'Processing') { %>
                        Our team is currently packing your physical disks. You can cancel items before they are assigned to a courier.
                    <% } else if (order.status === 'Shipped') { %>
                        Your package has been handed over to the courier and is on its way to you.
                    <% } else if (order.status === 'Delivered') { %>
                        Your package has been successfully delivered. Thank you for shopping with PixelPlay!
                    <% } else if (order.status === 'Return Requested') { %>
                        Your return request has been submitted and is currently pending approval.
                    <% } else if (order.status === 'Returned') { %>
                        The items have been returned and your refund has been processed.
                    <% } else if (order.status === 'Cancelled') { %>
                        This order has been cancelled.
                    <% } %>
                </p>
            </div>
        </div>
        <!-- Main Layout Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
            <!-- BEGIN: Left Column (Items) -->
            <div class="lg:col-span-2 flex flex-col gap-6">
                <!-- Section Title -->
                <h2 class="text-xs font-bold text-pixelplay-accent tracking-widest uppercase">Items In This Order</h2>
                <!-- Items Container -->
                <div class="bg-pixelplay-panel rounded-xl border border-pixelplay-border overflow-hidden">
                    <!-- Items Header -->
                    <div class="p-5 border-b border-pixelplay-border flex justify-between items-center bg-[#1a1a1f]">
                        <h3 class="font-semibold text-white">Physical Disks in This Order</h3>
                        <% 
                            let orderedQty = 0;
                            let deliveredQty = 0;
                            let returnRequestedQty = 0;
                            let returnedQty = 0;
                            let cancelledQty = 0;

                            if (order.items && order.items.length > 0) {
                                order.items.forEach(item => {
                                    const qty = item.quantity;
                                    if (item.status === 'Cancelled') {
                                        cancelledQty += qty;
                                    } else if (item.status === 'Return Requested') {
                                        returnRequestedQty += qty;
                                    } else if (item.status === 'Returned') {
                                        returnedQty += qty;
                                    } else {
                                        // status is 'Ordered' or undefined
                                        if (order.status === 'Delivered' || order.status === 'Return Requested' || order.status === 'Returned') {
                                            deliveredQty += qty;
                                        } else {
                                            orderedQty += qty;
                                        }
                                    }
                                });
                            }
                        %>
                        <div class="flex gap-2 flex-wrap">
                            <% if (order.status === 'Processing' || order.status === 'Shipped') { %>
                                <% const displayStatus = order.status; %>
                                <% const badgeClass = displayStatus === 'Shipped' ? 'bg-pixelplay-accent/10 border border-pixelplay-accent/30 text-pixelplay-accent' : 'bg-pixelplay-gold/10 border border-pixelplay-gold/30 text-pixelplay-gold'; %>
                                <span class="px-3 py-1 <%= badgeClass %> text-xs font-medium rounded-full">
                                    <%= orderedQty %> <%= orderedQty === 1 ? 'Disk' : 'Disks' %> - <%= displayStatus %>
                                </span>
                            <% } else if (order.status === 'Cancelled') { %>
                                <span class="px-3 py-1 bg-pixelplay-red/10 border border-pixelplay-red/30 text-pixelplay-red text-xs font-medium rounded-full">
                                    <%= cancelledQty %> <%= cancelledQty === 1 ? 'Disk' : 'Disks' %> - Cancelled
                                </span>
                            <% } else { %>
                                <!-- Delivered, Return Requested, or Returned orders -->
                                <% if (deliveredQty > 0) { %>
                                    <span class="px-3 py-1 bg-green-500/10 border border-green-500/30 text-green-400 text-xs font-medium rounded-full">
                                        <%= deliveredQty %> <%= deliveredQty === 1 ? 'Disk' : 'Disks' %> - Delivered
                                    </span>
                                <% } %>
                                <% if (returnRequestedQty > 0) { %>
                                    <span class="px-3 py-1 bg-pixelplay-gold/10 border border-pixelplay-gold/30 text-pixelplay-gold text-xs font-medium rounded-full">
                                        <%= returnRequestedQty %> <%= returnRequestedQty === 1 ? 'Disk' : 'Disks' %> - Return Requested
                                    </span>
                                <% } %>
                                <% if (returnedQty > 0) { %>
                                    <span class="px-3 py-1 bg-green-500/10 border border-green-500/30 text-green-400 text-xs font-medium rounded-full">
                                        <%= returnedQty %> <%= returnedQty === 1 ? 'Disk' : 'Disks' %> - Returned
                                    </span>
                                <% } %>
                            <% } %>
                        </div>
                    </div>
                    <!-- Items Loop -->
                    <% order.items.forEach((item, index) => { %>
                        <%
                            const isLegendary = item.product.edition_type === 'LEGENDARY';
                            const itemThemeColor = isLegendary ? 'pixelplay-gold' : 'pixelplay-accent';
                        %>
                        <div class="p-5 <%= index < order.items.length - 1 ? 'border-b border-pixelplay-border' : '' %> flex gap-5 relative pl-6 border-l-4 border-l-<%= itemThemeColor %>">
                            <img alt="<%= item.product.title %> Cover"
                                class="w-24 h-32 object-cover rounded shadow-md border border-gray-700"
                                src="<%= item.product.cover_image || '/placeholder.jpg' %>" />
                            <div class="flex flex-col flex-grow py-1">
                                <div class="flex items-center gap-2 mb-1">
                                    <h4 class="text-white font-semibold text-lg leading-tight"><%= item.product.title %></h4>
                                    <% if (isLegendary) { %>
                                        <span class="px-1.5 py-0.5 bg-yellow-600/20 text-yellow-500 text-[10px] uppercase font-bold rounded border border-yellow-600/40">Legend</span>
                                    <% } %>
                                </div>
                                <p class="text-sm text-gray-400 mb-2"><%= item.platform || 'PC' %> Disk • Factory Sealed</p>
                                <div class="flex items-center gap-3 mt-auto">
                                    <span class="text-<%= itemThemeColor %> font-bold">₹<%= (item.price / 100).toFixed(2) %></span>
                                    <span class="text-xs text-gray-500">Qty: <%= item.quantity %></span>
                                </div>
                                <div class="mt-4">
                                    <% if (item.status === 'Cancelled') { %>
                                        <div class="flex flex-col gap-1">
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-pixelplay-red/10 border border-pixelplay-red/30 text-pixelplay-red text-xs font-semibold rounded-full select-none w-fit">
                                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                                                    <path d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"
                                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                                                </svg>
                                                Item Cancelled <%= item.quantity > 1 ? `(${item.quantity} copies)` : '' %>
                                            </span>
                                            <% if (item.cancellationDate) { %>
                                                <p class="text-xs text-gray-400">Cancelled: <span class="text-gray-300 font-mono"><%= new Date(item.cancellationDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span></p>
                                                <p class="text-xs text-gray-400 font-medium">Reason: <span class="text-gray-300"><%= item.cancellationReason %></span></p>
                                            <% } %>
                                        </div>
                                    <% } else if (item.status === 'Return Requested') { %>
                                        <div class="flex flex-col gap-1">
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-yellow-600/10 border border-yellow-600/30 text-yellow-500 text-xs font-semibold rounded-full select-none w-fit">
                                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                                                    <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                                                </svg>
                                                Return Request Pending Approval <%= item.quantity > 1 ? `(${item.quantity} copies)` : '' %>
                                            </span>
                                            <% if (item.returnReason) { %>
                                                <p class="text-xs text-gray-400">Reason: <span class="text-gray-300"><%= item.returnReason === 'other' ? item.returnComments : item.returnReason %></span></p>
                                            <% } %>
                                        </div>
                                    <% } else if (item.status === 'Returned') { %>
                                        <div class="flex flex-col gap-1">
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-green-500/10 border border-green-500/30 text-green-400 text-xs font-semibold rounded-full select-none w-fit">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                                                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                                                </svg>
                                                Item Returned & Refunded <%= item.quantity > 1 ? `(${item.quantity} copies)` : '' %>
                                            </span>
                                            <% if (item.returnReason) { %>
                                                <p class="text-xs text-gray-400">Reason: <span class="text-gray-300"><%= item.returnReason === 'other' ? item.returnComments : item.returnReason %></span></p>
                                            <% } %>
                                        </div>
                                    <% } else if (item.status === 'Ordered' && item.adminReturnComment) { %>
                                        <div class="flex flex-col gap-1.5">
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-pixelplay-red/10 border border-pixelplay-red/30 text-pixelplay-red text-xs font-semibold rounded-full select-none w-fit">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                                                    <path d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"
                                                        stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                                                </svg>
                                                Return Rejected <%= item.quantity > 1 ? `(${item.quantity} copies)` : '' %>
                                            </span>
                                            <div class="text-xs text-pixelplay-red bg-pixelplay-red/10 border border-pixelplay-red/20 rounded p-3 max-w-md break-words">
                                                <span class="font-bold block mb-1 uppercase tracking-wider text-[10px] text-pixelplay-red">Rejection Reason</span>
                                                <span class="text-gray-300 font-sans"><%= item.adminReturnComment %></span>
                                            </div>
                                            <% if (order.status === 'Delivered' || order.status === 'Return Requested' || order.status === 'Returned') { %>
                                                <button onclick="window.location.href='/user/orders/<%= order._id %>/items/<%= item.product._id %>/returns?platform=<%= encodeURIComponent(item.platform) %>'"
                                                    class="mt-2 px-4 py-1.5 text-xs font-medium text-pixelplay-gold border border-pixelplay-gold/40 rounded-md hover:bg-pixelplay-gold/10 transition-colors flex items-center gap-1.5 w-fit">
                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                                                        <path d="M16 15v-6a4 4 0 00-4-4H4m12 10l3-3m-3 3l-3-3"
                                                            stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                                                    </svg>
                                                    Retry Return
                                                </button>
                                            <% } %>
                                        </div>
                                    <% } else { %>
                                        <div class="flex flex-col gap-2">
                                            <% if (order.status === 'Processing') { %>
                                                <button onclick="window.location.href='/user/orders/<%= order._id %>/items/<%= item.product._id %>/cancellation?platform=<%= encodeURIComponent(item.platform) %>'"
                                                    class="px-4 py-1.5 text-xs font-medium text-pixelplay-red border border-pixelplay-red/40 rounded-md hover:bg-pixelplay-red/10 transition-colors flex items-center gap-1.5 w-fit">
                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                                                        <path d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"
                                                            stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                                                    </svg>
                                                    Cancel Item
                                                </button>
                                            <% } else if (order.status === 'Shipped') { %>
                                                <!-- No buttons or links for Shipped status -->
                                            <% } else if (order.status === 'Delivered' || order.status === 'Return Requested' || order.status === 'Returned') { %>
                                                <button onclick="window.location.href='/user/orders/<%= order._id %>/items/<%= item.product._id %>/returns?platform=<%= encodeURIComponent(item.platform) %>'"
                                                    class="px-4 py-1.5 text-xs font-medium text-pixelplay-gold border border-pixelplay-gold/40 rounded-md hover:bg-pixelplay-gold/10 transition-colors flex items-center gap-1.5 w-fit">
                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                                                        <path d="M16 15v-6a4 4 0 00-4-4H4m12 10l3-3m-3 3l-3-3"
                                                            stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                                                    </svg>
                                                    Return This Disk
                                                </button>
                                            <% } %>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
            <!-- END: Left Column (Items) -->
            <!-- BEGIN: Right Column (Summary) -->
            <div class="flex flex-col gap-6 sticky top-24">
                <!-- Section Title -->
                <h2 class="text-xs font-bold text-pixelplay-accent tracking-widest uppercase">Logistics &amp; Financials</h2>
                <!-- Summary Panel -->
                <div class="bg-pixelplay-panel rounded-xl border border-pixelplay-border overflow-hidden">
                    <div class="p-5 border-b border-pixelplay-border bg-[#1a1a1f]">
                        <h3 class="font-semibold text-white">Order Summary</h3>
                    </div>
                    <div class="p-6 flex flex-col gap-8">
                        <!-- Address -->
                        <div>
                            <h4 class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-3">Destination Address</h4>
                            <p class="text-white font-medium mb-1"><%= order.address.fullName %></p>
                            <p class="text-sm text-gray-400 leading-relaxed">
                                <%= order.address.addressLine1 %>
                                <% if (order.address.addressLine2) { %>
                                    , <%= order.address.addressLine2 %>
                                <% } %>
                                <br />
                                <%= order.address.city %>, <%= order.address.state %> <%= order.address.postal_code %><br />
                                <%= order.address.country %>
                            </p>
                        </div>
                        <!-- Payment Method -->
                        <div>
                            <h4 class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-3">Payment Method</h4>
                            <div class="flex items-center gap-3">
                                <div
                                    class="w-10 h-6 bg-gray-800 rounded border border-gray-700 flex items-center justify-center shrink-0">
                                    <svg class="w-5 h-5 text-pixelplay-accent" fill="none" stroke="currentColor"
                                        viewbox="0 0 24 24">
                                        <path
                                            d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
                                            stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                                    </svg>
                                </div>
                                <div>
                                    <% if (order.paymentMethod === 'COD') { %>
                                        <p class="text-sm font-medium text-white">Pay on Delivery via COD</p>
                                    <% } else { %>
                                        <p class="text-sm font-medium text-white">Paid via <%= order.paymentMethod %></p>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                        <hr class="border-pixelplay-border" />
                        <!-- Pricing Breakdown -->
                        <div>
                            <h4 class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-4">Pricing Breakdown</h4>
                            <div class="flex flex-col gap-3 text-sm">
                                <div class="flex justify-between text-gray-400">
                                    <span>Items Subtotal</span>
                                    <span class="font-mono text-white">₹<%= (order.subtotal / 100).toFixed(2) %></span>
                                </div>
                                <% if (order.couponDiscount && order.couponDiscount > 0) { %>
                                    <div class="flex justify-between text-green-400">
                                        <span>Coupon Discount</span>
                                        <span class="font-mono">-₹<%= (order.couponDiscount / 100).toFixed(2) %></span>
                                    </div>
                                    <div class="h-px bg-pixelplay-border my-1"></div>
                                    <div class="flex justify-between text-gray-400">
                                        <span>Subtotal After Promos</span>
                                        <span class="font-mono text-white">₹<%= ((order.subtotal - order.couponDiscount) / 100).toFixed(2) %></span>
                                    </div>
                                <% } %>
                                <div class="flex justify-between text-gray-400">
                                    <span>GST (18%)</span>
                                    <span class="font-mono text-white">₹<%= (order.tax / 100).toFixed(2) %></span>
                                </div>
                                <div class="flex justify-between text-gray-400">
                                    <span>Shipping Charges</span>
                                    <span class="font-mono text-white">₹<%= (order.shipping / 100).toFixed(2) %></span>
                                </div>
                            </div>
                            <!-- Grand Total -->
                            <div class="mt-6 pt-4 border-t border-pixelplay-border flex justify-between items-center">
                                <span class="font-bold text-white">Grand Total</span>
                                <span class="text-xl font-bold text-pixelplay-accent font-mono">₹<%= (order.grandTotal / 100).toFixed(2) %></span>
                            </div>

                            <% 
                                let totalCancelledAmount = 0;
                                let totalReturnedAmount = 0;
                                let allCancelled = true;
                                if (order.items && order.items.length > 0) {
                                    order.items.forEach(item => {
                                        if (item.status === 'Cancelled') {
                                            totalCancelledAmount += Math.round(item.price * item.quantity / 0.82);
                                        } else {
                                            allCancelled = false;
                                            if (item.status === 'Returned') {
                                                totalReturnedAmount += Math.round(item.price * item.quantity / 0.82);
                                            }
                                        }
                                    });
                                } else {
                                    allCancelled = false;
                                }
                            %>
                            <% if (allCancelled) { %>
                                <div class="mt-3 flex justify-between items-center text-pixelplay-red text-sm">
                                    <span>Cancelled Item(s) Deduction</span>
                                    <span class="font-mono font-bold">-₹<%= (totalCancelledAmount / 100).toFixed(2) %></span>
                                </div>
                                <div class="mt-3 flex justify-between items-center text-pixelplay-red text-sm">
                                    <span>Shipping Charge Waiver</span>
                                    <span class="font-mono font-bold">-₹<%= (order.shipping / 100).toFixed(2) %></span>
                                </div>
                                <div class="mt-3 pt-3 border-t border-dashed border-pixelplay-border flex justify-between items-center text-green-400">
                                    <span class="font-bold text-white">Net Final Amount</span>
                                    <span class="text-xl font-bold font-mono">₹0.00</span>
                                </div>
                            <% } else { %>
                                <% if (totalCancelledAmount > 0) { %>
                                    <div class="mt-3 flex justify-between items-center text-pixelplay-red text-sm">
                                        <span>Cancelled Item(s) Deduction</span>
                                        <span class="font-mono font-bold">-₹<%= (totalCancelledAmount / 100).toFixed(2) %></span>
                                    </div>
                                <% } %>
                                <% if (totalReturnedAmount > 0) { %>
                                    <div class="mt-3 flex justify-between items-center text-pixelplay-red text-sm">
                                        <span>Returned Item(s) Deduction</span>
                                        <span class="font-mono font-bold">-₹<%= (totalReturnedAmount / 100).toFixed(2) %></span>
                                    </div>
                                <% } %>
                                <% if (totalCancelledAmount > 0 || totalReturnedAmount > 0) { %>
                                    <div class="mt-3 pt-3 border-t border-dashed border-pixelplay-border flex justify-between items-center text-green-400">
                                        <span class="font-bold text-white">Net Final Amount</span>
                                        <span class="text-xl font-bold font-mono">₹<%= ((order.grandTotal - totalCancelledAmount - totalReturnedAmount) / 100).toFixed(2) %></span>
                                    </div>
                                <% } %>
                            <% } %>
                            
                            <% if (order.status === 'Delivered' || order.status === 'Return Requested' || order.status === 'Returned') { %>
                                <div class="mt-4 pt-4 border-t border-pixelplay-border">
                                    <button onclick="window.location.href='/user/orders/<%= order._id %>/invoice'" 
                                        class="w-full bg-pixelplay-accent hover:bg-pixelplay-accentHover text-black font-bold py-2.5 px-4 rounded transition-colors flex items-center justify-center gap-2 text-sm shadow-md">
                                        <i class="fa-solid fa-download text-xs"></i>
                                        Download Invoice
                                    </button>
                                </div>
                            <% } %>
                        </div>
                        <% if (order.status !== 'Shipped' && order.status !== 'Delivered') { %>
                        <!-- Notice -->
                        <div class="bg-[#1e1a12] border border-pixelplay-gold/30 rounded-lg p-4 mt-2">
                            <p class="text-xs text-gray-300 leading-relaxed">
                                <span class="text-pixelplay-gold font-semibold inline-flex items-center gap-1">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                                        <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round"
                                            stroke-linejoin="round" stroke-width="2"></path>
                                    </svg>
                                    Instant Refund:
                                </span>
                                Cancelled items will be refunded immediately and directly to your <span
                                    class="text-pixelplay-gold font-medium">PixelWallet</span>.
                            </p>
                        </div>
                        <% } %>

                        <% if (order.status === 'Delivered') { %>
                        <!-- Return Disclaimer Notice -->
                        <div class="bg-[#101c26] border border-[#00b8ff]/30 rounded-lg p-4 mt-2">
                            <p class="text-xs text-gray-300 leading-relaxed">
                                <span class="text-pixelplay-accent font-semibold inline-flex items-center gap-1 mb-1">
                                    <i class="fa-solid fa-circle-info text-pixelplay-accent"></i>
                                    Return Refund Policy:
                                </span>
                                If a product is returned, the amount will be credited to the <span class="text-pixelplay-accent font-medium">PixelWallet</span> once the return is being confirmed.
                            </p>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
            <!-- END: Right Column (Summary) -->
        </div>
    </main>
    <!-- END: MainContent -->

    <script>
        (function() {
            const urlParams = new URLSearchParams(window.location.search);
            const notification = urlParams.get('notification');
            const error = urlParams.get('error');
            if (notification) {
                Swal.fire({
                    title: 'Success!',
                    text: notification,
                    icon: 'success',
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 3000,
                    background: '#151518',
                    color: '#e5e7eb',
                    iconColor: '#00b8ff'
                });
                window.history.replaceState({}, document.title, window.location.pathname);
            } else if (error) {
                Swal.fire({
                    title: 'Error',
                    text: error,
                    icon: 'error',
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 3000,
                    background: '#151518',
                    color: '#e5e7eb',
                    iconColor: '#ef4444'
                });
                window.history.replaceState({}, document.title, window.location.pathname);
            }
        })();
    </script>
</body>

</html>