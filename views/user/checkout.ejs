<!DOCTYPE html>

<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Payment Details Checkout</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        'dark-bg': '#0a0d14',
                        'dark-surface': '#11151c',
                        'dark-surface-2': '#171b22',
                        'dark-border': '#222730',
                        'cyber-blue': '#00b0ff',
                        'cyber-green': '#00e676',
                        'text-primary': '#e2e8f0',
                        'text-secondary': '#94a3b8',
                        'text-tertiary': '#64748b'
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        mono: ['Fira Code', 'monospace']
                    }
                }
            }
        }
    </script>
    <style data-purpose="custom-styles" type="text/tailwindcss">
        @layer utilities {
      .glass-panel {
        @apply bg-dark-surface/80 backdrop-blur-md border border-dark-border;
      }
      .cyber-input {
        @apply bg-dark-surface-2 border border-dark-border text-text-primary rounded-md focus:border-cyber-blue focus:ring-1 focus:ring-cyber-blue outline-none transition-colors;
      }
    }
    body {
      background: radial-gradient(circle at top right, #0d121a 0%, #05070a 100%);
    }
  </style>
</head>

<body
    class="bg-dark-bg text-text-primary min-h-screen font-sans antialiased overflow-x-hidden p-4 md:p-8 flex justify-center items-start pt-12">
    <!-- BEGIN: Checkout Container -->
    <div class="w-full max-w-6xl mx-auto flex flex-col lg:flex-row gap-8 relative">
        <!-- Close Button -->
        <a href="/auth/cart"
            class="absolute top-0 right-0 text-text-secondary hover:text-white mt-[-2rem] mr-[-1rem] lg:mt-0 lg:mr-0 z-50">
            <i class="fa-solid fa-xmark text-xl"></i>
        </a>
        <!-- BEGIN: Left Column (Payment Details) -->
        <div class="flex-1 max-w-[600px] flex flex-col gap-8">
            <!-- Header -->
            <div>
                <h1 class="text-2xl font-bold mb-1">Payment Details</h1>
                <p class="text-text-secondary text-sm">Complete your purchase to add the game to your library.</p>
            </div>
            <!-- Payment Method Tabs -->
            <div class="flex flex-nowrap gap-2 overflow-x-auto pb-2 text-sm font-medium">
                <button id="tab-card"
                    class="px-4 py-2 rounded border border-cyber-blue text-cyber-blue bg-cyber-blue/10 flex items-center gap-2 whitespace-nowrap">
                    <i class="fa-regular fa-credit-card"></i> Credit/Debit Card
                </button>
                <button id="tab-upi"
                    class="px-4 py-2 rounded border border-transparent text-text-secondary hover:text-white flex items-center gap-2 transition-colors whitespace-nowrap">
                    <i class="fa-solid fa-mobile-screen"></i> UPI Options
                </button>
                <button id="tab-cod"
                    class="px-4 py-2 rounded border border-transparent text-text-secondary hover:text-white flex items-center gap-2 transition-colors whitespace-nowrap">
                    <i class="fa-solid fa-money-bill-wave"></i> Cash On Delivery
                </button>
                <button id="tab-wallet"
                    class="px-4 py-2 rounded border border-transparent text-text-secondary hover:text-white flex items-center gap-2 transition-colors whitespace-nowrap">
                    <i class="fa-solid fa-wallet"></i> PixelWallet
                </button>
            </div>
            <p class="text-center text-text-secondary text-xs uppercase tracking-wider">Or pay with card or netbanking
            </p>
            <!-- Contact Information -->
            <div class="flex flex-col gap-3">
                <h2 class="font-semibold text-sm">Contact Information</h2>
                <div class="flex flex-col rounded-md overflow-hidden border border-dark-border">
                    <input
                        class="w-full bg-dark-surface-2 p-3 text-sm text-text-primary border-b border-dark-border focus:outline-none"
                        placeholder="Email" type="email" value="<%= user.email %>" />
                    <input id="checkout-phone" class="w-full bg-dark-surface-2 p-3 text-sm text-text-primary focus:outline-none"
                        placeholder="Phone Number" type="text" value="<%= user.phone || '' %>" />
                </div>
            </div>
            <!-- Credit/Debit Card Form -->
            <div id="card-form-container" class="flex flex-col gap-3">
                <h2 class="font-semibold text-sm">Credit/Debit Card</h2>
                <div class="flex flex-col rounded-md overflow-hidden border border-dark-border relative">
                    <div class="relative border-b border-dark-border">
                        <i
                            class="fa-regular fa-credit-card absolute left-3 top-1/2 -translate-y-1/2 text-text-secondary"></i>
                        <input class="w-full bg-dark-surface-2 p-3 pl-10 text-sm text-text-primary focus:outline-none"
                            placeholder="Card number" type="text" />
                    </div>
                    <div class="flex">
                        <input
                            class="w-1/2 bg-dark-surface-2 p-3 text-sm text-text-primary border-r border-dark-border focus:outline-none"
                            placeholder="MM / YY" type="text" />
                        <div class="relative w-1/2">
                            <input class="w-full bg-dark-surface-2 p-3 text-sm text-text-primary focus:outline-none"
                                placeholder="CVV" type="text" />
                            <i
                                class="fa-regular fa-circle-question absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary cursor-pointer"></i>
                        </div>
                    </div>
                </div>
                <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer mt-1">
                    <input checked=""
                        class="rounded border-dark-border bg-dark-surface text-cyber-blue focus:ring-cyber-blue focus:ring-offset-dark-bg w-4 h-4"
                        type="checkbox" />
                    Save card securely for future payments
                </label>
            </div>
            <!-- Billing Address -->
            <div class="flex flex-col gap-3">
                <h2 class="font-semibold text-xs tracking-wider text-text-secondary uppercase flex items-center gap-2">
                    <i class="fa-solid fa-location-dot"></i> <span id="address-label-text">BILLING ADDRESS</span>
                </h2>
                <div class="flex gap-4 overflow-x-auto pb-2 -mx-2 px-2 snap-x">
                    <% if (user.addresses && user.addresses.length > 0) { %>
                        <% user.addresses.forEach((address, index) => { %>
                            <% const isSelected = index === 0; %>
                            <!-- Address Card -->
                            <div data-address-id="<%= address._id %>"
                                class="address-card min-w-[240px] rounded-lg border p-4 flex flex-col gap-2 relative snap-start cursor-pointer transition-all <%= isSelected ? 'border-cyber-blue bg-cyber-blue/5 text-text-primary' : 'border-dark-border bg-dark-surface opacity-70 hover:opacity-100' %>">
                                <div class="flex justify-between items-center text-xs font-semibold <%= isSelected ? 'text-cyber-blue' : 'text-[#c084fc]' %>">
                                    <span class="flex items-center gap-1">
                                        <% if (address.address_type && address.address_type.toLowerCase() === 'home') { %>
                                            <i class="fa-solid fa-house"></i>
                                        <% } else if (address.address_type && address.address_type.toLowerCase() === 'office') { %>
                                            <i class="fa-solid fa-building"></i>
                                        <% } else { %>
                                            <i class="fa-solid fa-location-dot"></i>
                                        <% } %>
                                        <%= address.address_type ? address.address_type.toUpperCase() : 'ADDRESS' %>
                                    </span>
                                    <div class="flex items-center gap-2">
                                        <!-- Edit Address Button -->
                                        <button type="button" class="edit-address-btn text-text-secondary hover:text-white transition-colors" data-address='<%- JSON.stringify(address) %>'>
                                            <i class="fa-solid fa-pen text-[10px]"></i>
                                        </button>
                                        <i class="select-indicator <%= isSelected ? 'fa-regular fa-circle-dot' : 'fa-regular fa-circle' %>"></i>
                                    </div>
                                </div>
                                <div class="text-sm">
                                    <div class="font-semibold mb-1"><%= address.fullName %></div>
                                    <div class="text-text-secondary text-xs leading-relaxed">
                                        <%= address.addressLine1 %><br />
                                        <%= address.city %>, <%= address.state %> — <%= address.postal_code %><br />
                                        India
                                    </div>
                                </div>
                                <div class="mt-auto pt-2 primary-badge <%= isSelected ? '' : 'hidden' %>">
                                    <span class="text-xs text-cyber-blue flex items-center gap-1"><i
                                            class="fa-regular fa-star"></i> Selected Address</span>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                    <!-- Add New Address -->
                    <button type="button" id="open-add-modal-btn"
                        class="min-w-[100px] rounded-lg border border-dashed border-dark-border bg-dark-surface/50 p-4 flex flex-col items-center justify-center gap-2 cursor-pointer hover:border-cyber-blue hover:text-cyber-blue transition-colors snap-start group text-center">
                        <div
                            class="w-8 h-8 rounded-full border border-dark-border flex items-center justify-center text-text-secondary group-hover:border-cyber-blue group-hover:text-cyber-blue transition-colors mx-auto">
                            <i class="fa-solid fa-plus text-xs"></i>
                        </div>
                        <span
                            class="text-xs text-center text-text-secondary font-medium group-hover:text-cyber-blue block mt-1">Add
                            New<br />Address</span>
                    </button>
                </div>
            </div>
            <!-- Coupons & Promos -->
            <div class="flex flex-col gap-3 rounded-lg border border-dark-border bg-[#0d1219] p-4">
                <h2
                    class="font-semibold text-xs tracking-wider text-cyber-green uppercase flex items-center gap-2 mb-2">
                    <i class="fa-solid fa-ticket"></i> AVAILABLE COUPONS FOR YOUR TERMINAL
                </h2>
                <div class="flex flex-col gap-2">
                    <div class="text-text-secondary text-sm py-2">No coupons available</div>
                </div>
                <h2
                    class="font-semibold text-xs tracking-wider text-text-primary uppercase flex items-center gap-2 mt-4 mb-2">
                    <i class="fa-solid fa-tag text-text-secondary"></i> APPLY OPERATIONAL PROMO CODE
                </h2>
                <div class="flex gap-2">
                    <div class="relative flex-1">
                        <input
                            class="w-full bg-dark-surface-2 border border-dark-border rounded p-2.5 text-sm font-mono uppercase focus:border-cyber-blue focus:outline-none"
                            placeholder="ENTER COUPON CODE" type="text" />
                        <div class="absolute right-3 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-cyber-green">
                        </div>
                    </div>
                    <button
                        class="bg-cyber-blue hover:bg-blue-400 text-black font-bold text-xs px-4 rounded whitespace-nowrap transition-colors">
                        APPLY CODE
                    </button>
                </div>
            </div>
            <!-- Pay Button Area -->
            <div class="mt-4 flex flex-col gap-3">
                <button id="submit-pay-btn"
                    class="w-full bg-cyber-blue hover:bg-blue-400 text-black font-bold py-3.5 rounded-lg transition-colors flex justify-center items-center gap-2 shadow-[0_0_15px_rgba(0,176,255,0.3)]">
                    Pay ₹<%= (cart.grandTotal / 100).toFixed(2) %>
                </button>
                <div id="razorpay-secure-badge" class="text-center text-xs text-text-tertiary flex items-center justify-center gap-1">
                    <i class="fa-solid fa-shield-halved"></i> Secured by Razorpay
                </div>
            </div>
        </div>
        <!-- END: Left Column -->
        <!-- BEGIN: Right Column (Order Summary) -->
        <div class="w-full lg:w-[420px] shrink-0">
            <div class="glass-panel rounded-xl p-6 border border-[#1f2937]">
                <h2 class="font-bold text-sm tracking-widest text-white uppercase mb-6">ADVANCED ORDER LEDGER</h2>
                <% if (cart && cart.items && cart.items.length > 0) { %>
                    <% cart.items.forEach(item => { %>
                        <% if (item.product) { %>
                            <!-- Product Item -->
                            <div class="flex gap-4 mb-8">
                                <img alt="<%= item.product.title %> Cover"
                                    class="w-[72px] h-[96px] object-cover rounded shadow-lg border border-dark-border"
                                    src="<%= item.product.cover_image || item.product.coverImage || item.product.coverImageUrl || '' %>" />
                                <div class="flex flex-col justify-center">
                                    <div class="font-bold text-base text-white leading-tight mb-1"><%= item.product.title %></div>
                                    <div class="text-[10px] font-mono text-cyber-blue flex items-center gap-1 mb-2">
                                        <i class="fa-regular fa-circle-play"></i> <%= (item.platform || '').toUpperCase() %> PHYSICAL DISK
                                    </div>
                                    <div class="text-xs text-text-secondary">
                                        Price: ₹<%= (item.product.price / 100).toFixed(2) %>
                                    </div>
                                </div>
                            </div>
                        <% } %>
                    <% }) %>
                <% } %>
                <!-- Receipt Lines -->
                <div class="space-y-4 font-mono text-xs border-t border-dashed border-dark-border pt-6 pb-6">
                    <% if (cart && cart.items && cart.items.length > 0) { %>
                        <% cart.items.forEach(item => { %>
                            <% if (item.product) { %>
                                <div class="flex justify-between items-center">
                                    <span class="text-text-secondary"><%= item.product.title %> (x<%= item.quantity %>)</span>
                                    <span class="text-white">₹<%= ((item.product.price * item.quantity) / 100).toFixed(2) %></span>
                                </div>
                            <% } %>
                        <% }) %>
                    <% } %>
                    <% if (cart && cart.discount > 0) { %>
                        <!-- Promos Box -->
                        <div
                            class="border border-cyber-green/30 bg-cyber-green/5 rounded-md p-3 space-y-2 relative overflow-hidden">
                            <div class="absolute top-0 left-0 w-1 h-full bg-cyber-green"></div>
                            <div class="text-cyber-green font-bold text-[10px] uppercase flex items-center gap-1 mb-1">
                                <i class="fa-solid fa-tags"></i> OPERATIONAL PROMOS APPLIED
                            </div>
                            <div class="flex justify-between items-center text-text-secondary">
                                <span>Discount</span>
                                <span class="text-cyber-green">-₹<%= (cart.discount / 100).toFixed(2) %></span>
                            </div>
                        </div>
                    <% } %>
                    <div class="flex justify-between items-center pt-2">
                        <span class="text-text-secondary">Subtotal</span>
                        <span class="text-white">₹<%= (cart.subtotal / 100).toFixed(2) %></span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-text-secondary">GST</span>
                        <span class="text-white">₹<%= (cart.tax / 100).toFixed(2) %></span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-text-secondary">Shipping</span>
                        <span class="text-white">₹<%= (cart.shipping / 100).toFixed(2) %></span>
                    </div>
                </div>
                <!-- Total -->
                <div class="border-t border-dark-border pt-6 pb-2 flex justify-between items-end">
                    <div class="font-bold text-sm text-white">Grand Total Due</div>
                    <div class="text-3xl font-bold text-cyber-blue font-mono font-semibold">₹<%= (cart.grandTotal / 100).toFixed(2) %></div>
                </div>
                <!-- Disclaimer -->
                <div class="text-[11px] text-text-secondary leading-relaxed mb-4 pb-2 border-b border-dark-border/40 flex items-start gap-1">
                    <i class="fa-solid fa-circle-info text-cyber-blue mt-0.5 shrink-0"></i>
                    <span>If a product is returned or cancelled, the amount will be credited to the pixelWallet once the return/cancellation is being confirmed.</span>
                </div>
                <!-- Security Badge -->
                <div id="encrypted-channel-badge" class="border border-[#166534] bg-[#064e3b]/30 rounded-lg p-4 flex gap-3 items-start mt-2">
                    <i class="fa-solid fa-shield-check text-cyber-green text-lg mt-0.5"></i>
                    <div>
                        <div class="text-white font-semibold text-sm mb-1">100% Encrypted Channel</div>
                        <div class="text-text-secondary text-xs leading-relaxed">
                            Your checkout sequence is authorized safely via the Razorpay Network. PixelPlay does not
                            store raw credit card credentials in local memory cores.
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- END: Right Column -->
    </div>
    <!-- END: Checkout Container -->
    <!-- Add Address Modal -->
    <div id="add-address-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-zinc-950/80 backdrop-blur-sm overflow-y-auto">
        <div class="relative bg-[#071827] border border-zinc-800 rounded-xl max-w-lg w-full p-6 shadow-2xl my-8 text-left">
            <!-- Close button -->
            <button type="button" class="absolute top-4 right-4 text-zinc-400 hover:text-white close-modal-btn cursor-pointer">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
            
            <h2 class="text-xl font-bold text-zinc-100 mb-6 flex items-center gap-2">
                <svg class="w-5 h-5 text-sky-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                <span>Add New Address</span>
            </h2>
            
            <form id="add-address-form" class="space-y-4" novalidate>
                <div id="add-error" class="hidden text-red-500 text-xs bg-red-950/50 border border-red-500/20 p-3 rounded"></div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="add-fullName">Full Name *</label>
                        <input type="text" id="add-fullName" name="fullName" required
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                    </div>
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="add-phone">Phone Number *</label>
                        <input type="tel" id="add-phone" name="phone" required
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                    </div>
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="add-addressLine1">Address Line 1 *</label>
                    <input type="text" id="add-addressLine1" name="addressLine1" required placeholder="Street address, P.O. box, company name"
                        class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="add-addressLine2">Address Line 2 (Optional)</label>
                    <input type="text" id="add-addressLine2" name="addressLine2" placeholder="Apartment, suite, unit, building, floor, etc."
                        class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="add-city">City *</label>
                        <input type="text" id="add-city" name="city" required
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                    </div>
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="add-state">State *</label>
                        <input type="text" id="add-state" name="state" required
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                    </div>
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="add-postal_code">Postal Code *</label>
                        <input type="text" id="add-postal_code" name="postal_code" required maxlength="6" oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                    </div>
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="add-country">Country *</label>
                        <input type="text" id="add-country" name="country" required value="India"
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                    </div>
                </div>
                
                <div class="grid grid-cols-2 gap-4 pt-2">
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="add-address_type">Address Type</label>
                        <select id="add-address_type" name="address_type"
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 focus:border-sky-500 focus:outline-none transition-colors cursor-pointer">
                            <option value="home">Home</option>
                            <option value="office">Office</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div class="col-span-2 sm:col-span-1 flex items-center pt-6">
                        <input type="checkbox" id="add-isDefault" name="isDefault"
                            class="w-4 h-4 rounded bg-zinc-900 border-zinc-800 text-sky-500 focus:ring-sky-500 focus:ring-opacity-25 focus:ring-offset-0 focus:outline-none cursor-pointer" />
                        <label class="ml-2 text-sm text-zinc-300 font-medium cursor-pointer select-none" for="add-isDefault">
                            Set as Default Address
                        </label>
                    </div>
                </div>
                
                <div class="flex items-center justify-end gap-3 pt-6 border-t border-zinc-800/60">
                    <button type="button" class="px-5 py-2.5 border border-zinc-800 text-zinc-400 hover:text-white rounded text-sm transition-colors close-modal-btn cursor-pointer">
                        Cancel
                    </button>
                    <button type="submit" class="px-5 py-2.5 bg-sky-500 hover:bg-sky-400 text-[#0a0d14] font-bold rounded text-sm shadow-[0px_0px_15px_#0ea5e940] transition-colors cursor-pointer">
                        Save Address
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Address Modal -->
    <div id="edit-address-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-zinc-950/80 backdrop-blur-sm overflow-y-auto">
        <div class="relative bg-[#071827] border border-zinc-800 rounded-xl max-w-lg w-full p-6 shadow-2xl my-8 text-left">
            <!-- Close button -->
            <button type="button" class="absolute top-4 right-4 text-zinc-400 hover:text-white edit-close-modal-btn cursor-pointer">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
            
            <h2 class="text-xl font-bold text-zinc-100 mb-6 flex items-center gap-2">
                <svg class="w-5 h-5 text-sky-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
                <span>Edit Address</span>
            </h2>
            
            <form id="edit-address-form" class="space-y-4" novalidate>
                <input type="hidden" id="edit-id" name="id" />
                <div id="edit-error" class="hidden text-red-500 text-xs bg-red-950/50 border border-red-500/20 p-3 rounded"></div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="edit-fullName">Full Name *</label>
                        <input type="text" id="edit-fullName" name="fullName" required
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                    </div>
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="edit-phone">Phone Number *</label>
                        <input type="tel" id="edit-phone" name="phone" required
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                    </div>
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="edit-addressLine1">Address Line 1 *</label>
                    <input type="text" id="edit-addressLine1" name="addressLine1" required placeholder="Street address, P.O. box, company name"
                        class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="edit-addressLine2">Address Line 2 (Optional)</label>
                    <input type="text" id="edit-addressLine2" name="addressLine2" placeholder="Apartment, suite, unit, building, floor, etc."
                        class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="edit-city">City *</label>
                        <input type="text" id="edit-city" name="city" required
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                    </div>
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="edit-state">State *</label>
                        <input type="text" id="edit-state" name="state" required
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                    </div>
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="edit-postal_code">Postal Code *</label>
                        <input type="text" id="edit-postal_code" name="postal_code" required maxlength="6" oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                    </div>
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="edit-country">Country *</label>
                        <input type="text" id="edit-country" name="country" required
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 placeholder-zinc-600 focus:border-sky-500 focus:outline-none transition-colors" />
                    </div>
                </div>
                
                <div class="grid grid-cols-2 gap-4 pt-2">
                    <div class="col-span-2 sm:col-span-1">
                        <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" for="edit-address_type">Address Type</label>
                        <select id="edit-address_type" name="address_type"
                            class="w-full px-3.5 py-2.5 bg-zinc-900 border border-zinc-800 rounded text-sm text-zinc-100 focus:border-sky-500 focus:outline-none transition-colors cursor-pointer">
                            <option value="home">Home</option>
                            <option value="office">Office</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div class="col-span-2 sm:col-span-1 flex items-center pt-6">
                        <input type="checkbox" id="edit-isDefault" name="isDefault"
                            class="w-4 h-4 rounded bg-zinc-900 border-zinc-800 text-sky-500 focus:ring-sky-500 focus:ring-opacity-25 focus:ring-offset-0 focus:outline-none cursor-pointer" />
                        <label class="ml-2 text-sm text-zinc-300 font-medium cursor-pointer select-none" for="edit-isDefault">
                            Set as Default Address
                        </label>
                    </div>
                </div>
                
                <div class="flex items-center justify-end gap-3 pt-6 border-t border-zinc-800/60">
                    <button type="button" class="px-5 py-2.5 border border-zinc-800 text-zinc-400 hover:text-white rounded text-sm transition-colors edit-close-modal-btn cursor-pointer">
                        Cancel
                    </button>
                    <button type="submit" class="px-5 py-2.5 bg-sky-500 hover:bg-sky-400 text-zinc-950 font-bold rounded text-sm shadow-[0px_0px_15px_#0ea5e940] transition-colors cursor-pointer">
                        Update Address
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Toast Notifications Container -->
    <div id="toast-container" class="fixed top-5 right-5 z-[100] flex flex-col gap-3"></div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Modal references
            const addModal = document.getElementById('add-address-modal');
            const editModal = document.getElementById('edit-address-modal');
            const addBtn = document.getElementById('open-add-modal-btn');
            const closeBtns = document.querySelectorAll('.close-modal-btn');
            const editCloseBtns = document.querySelectorAll('.edit-close-modal-btn');

            // Forms references
            const addForm = document.getElementById('add-address-form');
            const editForm = document.getElementById('edit-address-form');

            // Error displays
            const addError = document.getElementById('add-error');
            const editError = document.getElementById('edit-error');

            // Toast display elements
            const toastContainer = document.getElementById('toast-container');

            function showToast(message, type = 'success') {
                const toast = document.createElement('div');
                toast.className = `flex items-center gap-3 px-4 py-3 rounded-lg shadow-lg border text-sm transition-all duration-300 transform translate-y-2 opacity-0 ${
                    type === 'success' 
                        ? 'bg-[#072412] text-green-400 border-green-500/30' 
                        : 'bg-[#2a080c] text-red-400 border-red-500/30'
                }`;
                toast.innerHTML = `<span>${message}</span>`;
                toastContainer.appendChild(toast);
                
                setTimeout(() => {
                    toast.classList.remove('translate-y-2', 'opacity-0');
                }, 10);
                
                setTimeout(() => {
                    toast.classList.add('opacity-0', 'translate-y-2');
                    setTimeout(() => {
                        toast.remove();
                    }, 300);
                }, 3000);
            }

            // Open Add Modal
            if (addBtn) {
                addBtn.addEventListener('click', () => {
                    addForm.reset();
                    addError.classList.add('hidden');
                    addModal.classList.remove('hidden');
                    addModal.classList.add('flex');
                    document.body.classList.add('overflow-hidden');
                });
            }

            // Close modals
            closeBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    addModal.classList.add('hidden');
                    addModal.classList.remove('flex');
                    document.body.classList.remove('overflow-hidden');
                });
            });

            editCloseBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    editModal.classList.add('hidden');
                    editModal.classList.remove('flex');
                    document.body.classList.remove('overflow-hidden');
                });
            });

            // Close modal on background click
            addModal.addEventListener('click', (e) => {
                if (e.target === addModal) {
                    addModal.classList.add('hidden');
                    addModal.classList.remove('flex');
                    document.body.classList.remove('overflow-hidden');
                }
            });

            editModal.addEventListener('click', (e) => {
                if (e.target === editModal) {
                    editModal.classList.add('hidden');
                    editModal.classList.remove('flex');
                    document.body.classList.remove('overflow-hidden');
                }
            });

            // Close modal on escape key
            window.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') {
                    addModal.classList.add('hidden');
                    addModal.classList.remove('flex');
                    editModal.classList.add('hidden');
                    editModal.classList.remove('flex');
                    document.body.classList.remove('overflow-hidden');
                }
            });

            // Populate and open edit modal
            window.openEditModal = function(address) {
                editError.classList.add('hidden');
                
                document.getElementById('edit-id').value = address._id || '';
                document.getElementById('edit-fullName').value = address.fullName || '';
                document.getElementById('edit-phone').value = address.phone || '';
                document.getElementById('edit-addressLine1').value = address.addressLine1 || '';
                document.getElementById('edit-addressLine2').value = address.addressLine2 || '';
                document.getElementById('edit-city').value = address.city || '';
                document.getElementById('edit-state').value = address.state || '';
                document.getElementById('edit-postal_code').value = address.postal_code || '';
                document.getElementById('edit-country').value = address.country || 'India';
                document.getElementById('edit-address_type').value = address.address_type || 'home';
                document.getElementById('edit-isDefault').checked = address.isDefault === true || address.isDefault === 'true';

                editModal.classList.remove('hidden');
                editModal.classList.add('flex');
                document.body.classList.add('overflow-hidden');
            };

            // Setup edit button click handlers
            const editButtons = document.querySelectorAll('.edit-address-btn');
            editButtons.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.stopPropagation(); // prevent selecting the card when clicking edit
                    const addressData = JSON.parse(btn.getAttribute('data-address'));
                    openEditModal(addressData);
                });
            });

            // Form validation helper
            function validateAddressForm(form, errorDiv) {
                const fullName = form.querySelector('[name="fullName"]').value.trim();
                const phone = form.querySelector('[name="phone"]').value.trim();
                const addressLine1 = form.querySelector('[name="addressLine1"]').value.trim();
                const city = form.querySelector('[name="city"]').value.trim();
                const state = form.querySelector('[name="state"]').value.trim();
                const postal_code = form.querySelector('[name="postal_code"]').value.trim();
                const country = form.querySelector('[name="country"]').value.trim();

                if (!fullName || !phone || !addressLine1 || !city || !state || !postal_code || !country) {
                    errorDiv.textContent = 'Please fill in all required fields marked with *';
                    errorDiv.classList.remove('hidden');
                    return false;
                }

                if (!/^\d{6}$/.test(postal_code)) {
                    errorDiv.textContent = 'Postal code must be exactly 6 digits';
                    errorDiv.classList.remove('hidden');
                    return false;
                }

                errorDiv.classList.add('hidden');
                return {
                    fullName,
                    phone,
                    addressLine1,
                    addressLine2: form.querySelector('[name="addressLine2"]').value.trim(),
                    city,
                    state,
                    postal_code: Number(postal_code),
                    country,
                    address_type: form.querySelector('[name="address_type"]').value,
                    isDefault: form.querySelector('[name="isDefault"]').checked
                };
            }

            // Save Address Submit
            addForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const payload = validateAddressForm(addForm, addError);
                if (!payload) return;

                try {
                    const response = await fetch('/auth/profile/addresses/add', {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    const data = await response.json();
                    if (response.ok && data.success) {
                        showToast(data.message || 'Address added successfully.');
                        addModal.classList.add('hidden');
                        addModal.classList.remove('flex');
                        document.body.classList.remove('overflow-hidden');
                        setTimeout(() => {
                            location.reload();
                        }, 800);
                    } else {
                        addError.textContent = data.message || 'Failed to add address.';
                        addError.classList.remove('hidden');
                    }
                } catch (err) {
                    addError.textContent = 'Network error. Please try again.';
                    addError.classList.remove('hidden');
                }
            });

            // Update Address Submit
            editForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const payload = validateAddressForm(editForm, editError);
                if (!payload) return;
                
                const addressId = document.getElementById('edit-id').value;

                try {
                    const response = await fetch(`/auth/profile/addresses/edit/${addressId}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    const data = await response.json();
                    if (response.ok && data.success) {
                        showToast(data.message || 'Address updated successfully.');
                        editModal.classList.add('hidden');
                        editModal.classList.remove('flex');
                        document.body.classList.remove('overflow-hidden');
                        setTimeout(() => {
                            location.reload();
                        }, 800);
                    } else {
                        editError.textContent = data.message || 'Failed to update address.';
                        editError.classList.remove('hidden');
                    }
                } catch (err) {
                    editError.textContent = 'Network error. Please try again.';
                    editError.classList.remove('hidden');
                }
            });

            const addressCards = document.querySelectorAll('.address-card');
            addressCards.forEach(card => {
                card.addEventListener('click', () => {
                    // Deselect all cards
                    addressCards.forEach(c => {
                        c.classList.remove('border-cyber-blue', 'bg-cyber-blue/5');
                        c.classList.add('border-dark-border', 'bg-dark-surface', 'opacity-70');
                        
                        // Update header text color
                        const header = c.querySelector('.text-cyber-blue, .text-\\[\\#c084fc\\]');
                        if (header) {
                            header.classList.remove('text-cyber-blue');
                            header.classList.add('text-[#c084fc]');
                        }
                        
                        // Update circle icon
                        const indicator = c.querySelector('.select-indicator');
                        if (indicator) {
                            indicator.className = 'select-indicator fa-regular fa-circle';
                        }
                        
                        // Hide badge
                        const badge = c.querySelector('.primary-badge');
                        if (badge) {
                            badge.classList.add('hidden');
                        }
                    });
                    
                    // Select clicked card
                    card.classList.remove('border-dark-border', 'bg-dark-surface', 'opacity-70');
                    card.classList.add('border-cyber-blue', 'bg-cyber-blue/5');
                    
                    // Update header text color
                    const header = card.querySelector('.text-cyber-blue, .text-\\[\\#c084fc\\]');
                    if (header) {
                        header.classList.remove('text-[#c084fc]');
                        header.classList.add('text-cyber-blue');
                    }
                    
                    // Update circle icon
                    const indicator = card.querySelector('.select-indicator');
                    if (indicator) {
                        indicator.className = 'select-indicator fa-regular fa-circle-dot';
                    }
                    
                    // Show badge
                    const badge = card.querySelector('.primary-badge');
                    if (badge) {
                        badge.classList.remove('hidden');
                    }
                    
                    // Optional: Store selected address ID in a variable or input
                    const addressId = card.getAttribute('data-address-id');
                    console.log('Selected Address ID:', addressId);
                });
            });

            // Payment method tab toggling
            const cardFormContainer = document.getElementById('card-form-container');
            const addressLabelText = document.getElementById('address-label-text');
            const submitPayBtn = document.getElementById('submit-pay-btn');
            const razorpaySecureBadge = document.getElementById('razorpay-secure-badge');
            const encryptedChannelBadge = document.getElementById('encrypted-channel-badge');

            const tabs = {
                'tab-card': {
                    showCardForm: true,
                    showRazorpay: true,
                    showEncrypted: true,
                    addressLabel: "BILLING ADDRESS",
                    buttonText: "Pay ₹<%= (cart.grandTotal / 100).toFixed(2) %>"
                },
                'tab-upi': {
                    showCardForm: false,
                    showRazorpay: true,
                    showEncrypted: true,
                    addressLabel: "BILLING ADDRESS",
                    buttonText: "Pay ₹<%= (cart.grandTotal / 100).toFixed(2) %>"
                },
                'tab-cod': {
                    showCardForm: false,
                    showRazorpay: false,
                    showEncrypted: false,
                    addressLabel: "DELIVERY ADDRESS",
                    buttonText: "Place Order"
                },
                'tab-wallet': {
                    showCardForm: false,
                    showRazorpay: false,
                    showEncrypted: false,
                    addressLabel: "BILLING ADDRESS",
                    buttonText: "Pay ₹<%= (cart.grandTotal / 100).toFixed(2) %>"
                }
            };

            let activePaymentMethod = 'Card'; // default

            Object.keys(tabs).forEach(tabId => {
                const tabEl = document.getElementById(tabId);
                if (tabEl) {
                    tabEl.addEventListener('click', () => {
                        const config = tabs[tabId];
                        activePaymentMethod = tabId === 'tab-card' ? 'Card' : tabId === 'tab-cod' ? 'COD' : tabId === 'tab-upi' ? 'UPI' : 'PixelWallet';
                        
                        // Toggle elements visibility
                        if (config.showCardForm) cardFormContainer.classList.remove('hidden');
                        else cardFormContainer.classList.add('hidden');
                        
                        if (config.showRazorpay) razorpaySecureBadge.classList.remove('hidden');
                        else razorpaySecureBadge.classList.add('hidden');
                        
                        if (config.showEncrypted) encryptedChannelBadge.classList.remove('hidden');
                        else encryptedChannelBadge.classList.add('hidden');
                        
                        // Update texts
                        addressLabelText.innerText = config.addressLabel;
                        submitPayBtn.innerText = config.buttonText;
                        
                        // Update tab styles
                        Object.keys(tabs).forEach(id => {
                            const el = document.getElementById(id);
                            if (el) {
                                if (id === tabId) {
                                    el.classList.remove('border-transparent', 'text-text-secondary', 'hover:text-white');
                                    el.classList.add('border-cyber-blue', 'text-cyber-blue', 'bg-cyber-blue/10');
                                } else {
                                    el.classList.remove('border-cyber-blue', 'text-cyber-blue', 'bg-cyber-blue/10');
                                    el.classList.add('border-transparent', 'text-text-secondary', 'hover:text-white');
                                }
                            }
                        });
                    });
                }
            });

            // Submit Payment / Place Order
            if (submitPayBtn) {
                submitPayBtn.addEventListener('click', async () => {
                    const phoneInput = document.getElementById('checkout-phone');
                    const phoneVal = phoneInput ? phoneInput.value.trim() : '';
                    const phoneRegex = /^[6-9]\d{9}$/;
                    if (!phoneVal || !phoneRegex.test(phoneVal)) {
                        showToast('Please enter a valid 10-digit phone number in Contact Information.', 'error');
                        return;
                    }

                    if (activePaymentMethod === 'COD') {
                        // Get selected address ID
                        const selectedAddressCard = document.querySelector('.address-card.border-cyber-blue');
                        if (!selectedAddressCard) {
                            showToast('Please select a delivery address.', 'error');
                            return;
                        }
                        const addressId = selectedAddressCard.getAttribute('data-address-id');

                        // Disable button to prevent double submission
                        submitPayBtn.disabled = true;
                        submitPayBtn.innerText = 'Processing Order...';

                        try {
                            const response = await fetch('/auth/orders/place', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ paymentMethod: 'COD', addressId })
                            });

                            const data = await response.json();
                            if (response.ok && data.success) {
                                showToast(data.message || 'Order placed successfully.');
                                setTimeout(() => {
                                    window.location.href = `/auth/orders/success/${data.orderId}`;
                                }, 800);
                            } else {
                                showToast(data.message || 'Failed to place order.', 'error');
                                submitPayBtn.disabled = false;
                                submitPayBtn.innerText = 'Place Order';
                            }
                        } catch (err) {
                            showToast('Network error. Please try again.', 'error');
                            submitPayBtn.disabled = false;
                            submitPayBtn.innerText = 'Place Order';
                        }
                    } else {
                        showToast('Only Cash On Delivery is available at this time.', 'error');
                    }
                });
            }
        });
    </script>
</body>

</html>