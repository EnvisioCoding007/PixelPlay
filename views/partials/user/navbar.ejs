<header
    class="flex h-[72px] items-center justify-between px-10 py-0 relative self-stretch w-full z-[1] bg-[#09090be6] border-b [border-bottom-style:solid] border-[#00000014] backdrop-blur backdrop-brightness-[100%] [-webkit-backdrop-filter:blur(8px)_brightness(100%)]">
    <nav class="flex items-center justify-between w-full gap-6" aria-label="Primary">
        <div class="inline-flex items-center gap-10 relative flex-[0_0_auto]">
            <a href="/" class="relative block w-[180px] h-17 flex items-center" aria-label="PixelPlay home">
                <img src="/icons/brand_logo/pixelplay-logo.png" alt="PixelPlay Logo" class="w-full h-full object-contain" />
            </a>
            <ul class="inline-flex items-center gap-[7.6px] relative flex-[0_0_auto]">
                <li><a href="/"
                        class="inline-flex flex-col items-start px-4 py-2 relative flex-[0_0_auto] rounded-md <%= activeTab === 'home' ? 'bg-[#ffffff10]' : '' %>"><span
                            class="relative flex items-center w-fit mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium <%= activeTab === 'home' ? 'text-white' : 'text-[#9aa6b3]' %> text-sm tracking-[0] leading-[normal]">Home</span></a>
                </li>
                <li><a href="/browse"
                        class="inline-flex flex-col items-start px-4 py-2 relative flex-[0_0_auto] rounded-md <%= activeTab === 'browse' ? 'bg-[#ffffff10]' : '' %>"><span
                            class="mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium <%= activeTab === 'browse' ? 'text-white' : 'text-[#9aa6b3]' %> text-sm tracking-[0] relative flex items-center w-fit leading-[normal]">Browse</span></a>
                </li>
                <% if (typeof user !== 'undefined' && user) { %>
                <li><a href="/auth/wishlist"
                        class="inline-flex flex-col items-start px-4 py-2 relative flex-[0_0_auto] rounded-md <%= activeTab === 'wishlist' ? 'bg-[#ffffff10]' : '' %>"><span
                            class="mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium <%= activeTab === 'wishlist' ? 'text-white' : 'text-[#9aa6b3]' %> text-sm tracking-[0] relative flex items-center w-fit leading-[normal]">Wishlist</span></a>
                </li>
                <% } %>
                <li><a href="#"
                        class="inline-flex flex-col items-start px-4 py-2 relative flex-[0_0_auto] rounded-md <%= activeTab === 'offers' ? 'bg-[#ffffff10]' : '' %>"><span
                            class="mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium <%= activeTab === 'offers' ? 'text-white' : 'text-[#9aa6b3]' %> text-sm tracking-[0] relative flex items-center w-fit leading-[normal]">Offers</span></a>
                </li>
                <% if (typeof user !== 'undefined' && user) { %>
                <li><a href="#"
                        class="inline-flex flex-col items-start px-4 py-2 relative flex-[0_0_auto] rounded-md <%= activeTab === 'library' ? 'bg-[#ffffff10]' : '' %>"><span
                            class="relative flex items-center w-fit mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium <%= activeTab === 'library' ? 'text-white' : 'text-[#9aa6b3]' %> text-sm tracking-[0] leading-[normal]">Library</span></a>
                </li>
                <li><a href="#"
                        class="inline-flex flex-col items-start px-4 py-2 relative flex-[0_0_auto] rounded-md <%= activeTab === 'wallet' ? 'bg-[#ffffff10]' : '' %>"><span
                            class="relative flex items-center w-fit mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium <%= activeTab === 'wallet' ? 'text-white' : 'text-[#9aa6b3]' %> text-sm tracking-[0] leading-[normal]">Wallet</span></a>
                </li>
                <% } %>
                <li><a href="#"
                        class="inline-flex flex-col items-start px-4 py-2 relative flex-[0_0_auto] rounded-md <%= activeTab === 'support' ? 'bg-[#ffffff10]' : '' %>"><span
                            class="mt-[-1.00px] [font-family:'Inter-Medium',Helvetica] font-medium <%= activeTab === 'support' ? 'text-white' : 'text-[#9aa6b3]' %> text-sm tracking-[0] relative flex items-center w-fit leading-[normal]">Support</span></a>
                </li>
            </ul>
        </div>
        <div class="inline-flex items-center gap-5 relative flex-[0_0_auto]">
            <form action="/browse" method="GET" id="navbarSearchForm"
                class="flex w-60 items-center gap-3 px-4 py-2 relative bg-[#0f1113] rounded-full border border-solid border-[#00000014]"
                role="search">
                <label for="store-search" class="sr-only">Search store</label>
                <button type="submit" class="p-0 border-0 bg-transparent flex items-center justify-center cursor-pointer focus:outline-none text-[#9aa6b3] hover:text-white" aria-label="Submit search">
                    <i class="fa-solid fa-magnifying-glass text-xs"></i>
                </button>
                <div class="flex items-center relative flex-1 grow w-full">
                    <input id="store-search" name="search" value="<%= (typeof query !== 'undefined' && query.search) ? query.search : '' %>"
                        class="relative flex items-center self-stretch [font-family:'Inter-Regular',Helvetica] font-normal text-[#9aa6b3] text-sm tracking-[0] bg-transparent border-0 p-0 outline-none placeholder:text-[#9aa6b3] w-full pr-6"
                        placeholder="Search store..." type="text" autocomplete="off" />
                    <button type="button" id="clear-search-btn" class="absolute right-0 top-1/2 -translate-y-1/2 text-gray-500 hover:text-white cursor-pointer bg-transparent border-0 p-0 hidden" aria-label="Clear search">
                        <i class="fa-solid fa-circle-xmark"></i>
                    </button>
                </div>
            </form>
            <% if (typeof user !== 'undefined' && user) { %>
            <%# Authenticated: show cart, bell, and profile avatar %>
            <a href="/auth/cart" class="flex w-10 h-10 items-center justify-center relative rounded-[20px] hover:bg-[#ffffff10] transition-colors"
                aria-label="Cart">
                <i class="fa-solid fa-cart-shopping text-[#9aa6b3] hover:text-white transition-colors text-lg"></i>
                <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
                    <span id="cart-badge" class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-red-600 text-[10px] font-bold text-white border border-[#0d0d0d] scale-100 transition-all duration-300 animate-pulse">
                        <%= cartCount %>
                    </span>
                <% } %>
            </a>
            <button type="button" class="flex w-10 h-10 items-center justify-center relative rounded-[20px]"
                aria-label="Notifications">
                <img class="relative w-5 h-5" src="/icons/notification-bell.svg" alt="Notifications" />
            </button>
            <a href="/auth/profile"
                class="relative w-9 h-9 rounded-[18px] border-2 border-solid border-[#00000014] flex items-center justify-center transition-transform duration-200 hover:scale-105 active:scale-95 cursor-pointer overflow-hidden bg-[#1a2a3a] text-sky-400 font-bold"
                aria-label="Profile">
                <% if (user.profile_image) { %>
                    <img src="<%= user.profile_image %>" alt="Profile" class="w-full h-full object-cover" />
                <% } else { %>
                    <span class="text-sm select-none [font-family:'Inter-Bold',Helvetica]"><%= user.username.charAt(0).toUpperCase() %></span>
                <% } %>
            </a>
            <% } else { %>
            <%# Unauthenticated: show Log In and Sign Up CTAs %>
            <div class="inline-flex items-center gap-3 relative flex-[0_0_auto]">
                <a href="/auth/login"
                    class="inline-flex h-9 items-center justify-center px-5 py-0 relative rounded-md border border-solid border-[#ffffff22] text-[#9aa6b3] hover:text-white hover:border-[#ffffff44] transition-colors [font-family:'Inter-Medium',Helvetica] font-medium text-sm tracking-[0] leading-[normal]">
                    Log In
                </a>
                <a href="/auth/signup"
                    class="inline-flex h-9 items-center justify-center px-5 py-0 relative rounded-md bg-sky-500 hover:bg-sky-400 shadow-[0px_0px_16px_#0ea5e94c] transition-colors [font-family:'Inter-SemiBold',Helvetica] font-semibold text-[#061323] text-sm tracking-[0] leading-[normal]">
                    Sign Up
                </a>
            </div>
            <% } %>
        </div>
    </nav>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchForm = document.getElementById('navbarSearchForm');
    const searchInput = document.getElementById('store-search');
    const clearBtn = document.getElementById('clear-search-btn');

    const updateClearBtnVisibility = () => {
      if (searchInput && clearBtn) {
        if (searchInput.value.trim().length > 0) {
          clearBtn.classList.remove('hidden');
        } else {
          clearBtn.classList.add('hidden');
        }
      }
    };

    if (searchInput && clearBtn) {
      searchInput.addEventListener('input', updateClearBtnVisibility);
      updateClearBtnVisibility();

      clearBtn.addEventListener('click', () => {
        searchInput.value = '';
        clearBtn.classList.add('hidden');
        searchInput.focus();
        
        // If on browse page, clear search query and submit filterForm
        const hiddenSearch = document.getElementById('hiddenSearchInput');
        if (hiddenSearch) {
          hiddenSearch.value = '';
          const filterForm = document.getElementById('filterForm');
          if (filterForm) {
            if (typeof triggerFilterFormSubmit === 'function') {
              triggerFilterFormSubmit();
            } else {
              filterForm.submit();
            }
          }
        } else {
          // If on other pages, redirect to browse
          window.location.href = '/browse';
        }
      });
    }

    if (searchForm) {
      searchForm.addEventListener('submit', (e) => {
        const hiddenSearch = document.getElementById('hiddenSearchInput');
        if (hiddenSearch) {
          e.preventDefault();
          hiddenSearch.value = searchInput.value;
          const filterForm = document.getElementById('filterForm');
          if (filterForm) {
            if (typeof triggerFilterFormSubmit === 'function') {
              triggerFilterFormSubmit();
            } else {
              filterForm.submit();
            }
          }
        }
      });
    }
  });
</script>
