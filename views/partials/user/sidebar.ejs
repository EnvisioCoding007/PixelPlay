<%
  const isChecked = (field, val) => {
    if (!query || !query[field]) return false;
    const active = query[field];
    if (Array.isArray(active)) {
      return active.includes(val);
    }
    return active === val;
  };
%>

<aside class="w-64 flex-shrink-0 bg-[#0d0d0d] border-r border-[#2A2A2A] overflow-y-auto scrollbar-hide hidden md:block sticky top-[72px] h-[calc(100vh-72px)]">
<div class="p-6 pb-24">
  <!-- Filter Category: Genre -->
  <div class="mb-8">
    <h3 class="text-xs font-bold text-gray-500 tracking-wider mb-4 uppercase">Genre</h3>
    <div class="space-y-3">
      <% if (typeof categories !== 'undefined' && categories && categories.length > 0) { %>
        <% categories.forEach(cat => { %>
          <label class="flex items-center gap-3 cursor-pointer group">
            <input name="genre" value="<%= cat %>" class="form-checkbox" type="checkbox" <%= isChecked('genre', cat) ? 'checked' : '' %>/>
            <span class="text-sm text-gray-300 group-hover:text-white transition-colors"><%= cat %></span>
          </label>
        <% }) %>
      <% } else { %>
        <p class="text-xs text-zinc-500">No genres found</p>
      <% } %>
    </div>
  </div>

  <!-- Filter Category: Platform -->
  <div class="mb-8">
    <h3 class="text-xs font-bold text-gray-500 tracking-wider mb-4 uppercase">Platform</h3>
    <div class="space-y-3">
      <% if (typeof platforms !== 'undefined' && platforms && platforms.length > 0) { %>
        <% platforms.forEach(plat => { %>
          <label class="flex items-center gap-3 cursor-pointer group">
            <input name="platform" value="<%= plat %>" class="form-checkbox" type="checkbox" <%= isChecked('platform', plat) ? 'checked' : '' %>/>
            <span class="text-sm text-gray-300 group-hover:text-white transition-colors"><%= plat %></span>
          </label>
        <% }) %>
      <% } else { %>
        <p class="text-xs text-zinc-500">No platforms found</p>
      <% } %>
    </div>
  </div>

  <!-- Filter Category: Publisher -->
  <div class="mb-8">
    <h3 class="text-xs font-bold text-gray-500 tracking-wider mb-4 uppercase">Publisher</h3>
    <div class="space-y-3">
      <% if (typeof publishers !== 'undefined' && publishers && publishers.length > 0) { %>
        <% publishers.forEach(pub => { %>
          <label class="flex items-center gap-3 cursor-pointer group">
            <input name="publisher" value="<%= pub %>" class="form-checkbox" type="checkbox" <%= isChecked('publisher', pub) ? 'checked' : '' %>/>
            <span class="text-sm text-gray-300 group-hover:text-white transition-colors"><%= pub %></span>
          </label>
        <% }) %>
      <% } else { %>
        <p class="text-xs text-zinc-500">No publishers found</p>
      <% } %>
    </div>
  </div>

  <!-- Filter Category: Price Range -->
  <div class="mb-8">
    <h3 class="text-xs font-bold text-gray-500 tracking-wider mb-4 uppercase">Price Range</h3>
    <div class="space-y-3">
      <label class="flex items-center gap-3 cursor-pointer group">
        <input name="price" value="under-20" class="form-checkbox" type="checkbox" <%= isChecked('price', 'under-20') ? 'checked' : '' %>/>
        <span class="text-sm text-gray-300 group-hover:text-white transition-colors">Under ₹20</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer group">
        <input name="price" value="20-40" class="form-checkbox" type="checkbox" <%= isChecked('price', '20-40') ? 'checked' : '' %>/>
        <span class="text-sm text-gray-300 group-hover:text-white transition-colors">₹20 - ₹40</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer group">
        <input name="price" value="40-70" class="form-checkbox" type="checkbox" <%= isChecked('price', '40-70') ? 'checked' : '' %>/>
        <span class="text-sm text-gray-300 group-hover:text-white transition-colors">₹40 - ₹70</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer group">
        <input name="price" value="70+" class="form-checkbox" type="checkbox" <%= isChecked('price', '70+') ? 'checked' : '' %>/>
        <span class="text-sm text-gray-300 group-hover:text-white transition-colors">₹70+</span>
      </label>
    </div>
  </div>

  <!-- Filter Category: Rating -->
  <div class="mb-8">
    <h3 class="text-xs font-bold text-gray-500 tracking-wider mb-4 uppercase">Rating</h3>
    <div class="space-y-3">
      <label class="flex items-center gap-3 cursor-pointer group">
        <input name="rating" value="4" class="form-checkbox" type="checkbox" <%= isChecked('rating', '4') ? 'checked' : '' %>/>
        <span class="text-sm text-gray-300 group-hover:text-white transition-colors flex items-center gap-1">4+ <svg class="w-4 h-4 text-legend" fill="currentColor" viewbox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg></span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer group">
        <input name="rating" value="3" class="form-checkbox" type="checkbox" <%= isChecked('rating', '3') ? 'checked' : '' %>/>
        <span class="text-sm text-gray-300 group-hover:text-white transition-colors flex items-center gap-1">3+ <svg class="w-4 h-4 text-legend" fill="currentColor" viewbox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg></span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer group">
        <input name="rating" value="2" class="form-checkbox" type="checkbox" <%= isChecked('rating', '2') ? 'checked' : '' %>/>
        <span class="text-sm text-gray-300 group-hover:text-white transition-colors flex items-center gap-1">2+ <svg class="w-4 h-4 text-legend" fill="currentColor" viewbox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg></span>
      </label>
    </div>
  </div>
</div>

<!-- Fixed Bottom Action Area in Sidebar -->
<div class="fixed bottom-0 w-64 bg-[#0d0d0d] border-t border-[#2A2A2A] p-4 flex items-center justify-between z-10">
  <a href="/browse" class="text-sm text-gray-400 hover:text-white transition-colors font-medium text-center py-2 flex-1 hover:underline cursor-pointer">Clear</a>
  <button type="submit" class="bg-brand hover:bg-brand-light text-white text-sm font-medium py-2 px-6 rounded transition-colors shadow-[0_0_15px_rgba(0,163,255,0.3)] flex-1 text-center cursor-pointer">Apply</button>
</div>
</aside>
